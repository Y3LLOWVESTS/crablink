{
  "name": "@crablink/crablink-tv",
  "version": "0.1.0",
  "private": true,
  "description": "Remote-first CrabLink TV Tauri client.",
  "type": "module",
  "scripts": {
    "dev": "vite --host 127.0.0.1 --port 1430",
    "build": "vite build",
    "preview": "vite preview --host 127.0.0.1 --port 1430",
    "tauri": "tauri",
    "tauri:dev": "tauri dev",
    "tauri:build": "tauri build",
    "check:boundary": "node ../../scripts/check-crablink-tv-command-boundary.mjs",
    "check": "npm run check:boundary && npm run build && cargo test --manifest-path src-tauri/Cargo.toml --offline && cargo clippy --manifest-path src-tauri/Cargo.toml --all-targets --offline -- -D warnings"
  },
  "dependencies": {
    "@tauri-apps/api": "^2",
    "react": "^18.2.0",
    "react-dom": "^18.2.0"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2",
    "@vitejs/plugin-react": "^4.3.0",
    "vite": "^5.4.0"
  },
  "license": "MIT OR Apache-2.0",
  "author": "Stevan White"
}
