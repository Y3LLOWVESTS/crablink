    "check:quickchain-phase5-external-posture-boundary": "node ../../scripts/check-quickchain-phase5-client-external-posture-boundary.mjs",
    "check:internal-roc-paid-content-boundary": "node ../../scripts/check-internal-roc-paid-content-boundary.mjs",
