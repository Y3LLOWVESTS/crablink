{
  "name": "@crablink/crablink-tauri",
  "version": "0.1.0",
  "private": true,
  "description": "CrabLink Tauri native client scaffold.",
  "type": "module",
  "scripts": {
    "dev": "vite --host 127.0.0.1 --port 1420",
    "build": "vite build",
    "preview": "vite preview --host 127.0.0.1 --port 1420",
    "tauri": "tauri",
    "tauri:dev": "tauri dev",
    "tauri:build": "tauri build",
    "check": "npm run check:quickchain-boundary && npm run check:quickchain-paid-cache-boundary && npm run check:quickchain-readiness-boundary && npm run build && npm run check:rust:mac-media",
    "check:quickchain-boundary": "node ../../scripts/check-quickchain-client-boundary.mjs",
    "tauri:dev:mac-media": "tauri dev --config src-tauri/tauri.macos.dev-media.conf.json",
    "check:rust:mac-media": "TAURI_CONFIG=\"$(cat src-tauri/tauri.macos.dev-media.conf.json)\" cargo check --manifest-path src-tauri/Cargo.toml",
    "check:quickchain-paid-cache-boundary": "node ../../scripts/check-quickchain-paid-cache-boundary.mjs",
    "check:quickchain-readiness-boundary": "node ../../scripts/check-quickchain-readiness-boundary.mjs",
    "park:quickchain": "../../scripts/dev-quickchain-tauri-park.sh"
  },
  "dependencies": {
    "@mediapipe/tasks-vision": "^0.10.34",
    "@tauri-apps/api": "^2",
    "react": "^18.2.0",
    "react-dom": "^18.2.0"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2",
    "@vitejs/plugin-react": "^4.3.0",
    "vite": "^5.4.0"
  },
  "license": "MIT OR Apache-2.0",
  "author": "Stevan White"
}
