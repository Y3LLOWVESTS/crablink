/*
 * RO:WHAT — Styles for the React-owned crab://video workspace.
 * RO:WHY — CrabLink refactor; keeps video route polish local while shared layout components carry common structure.
 * RO:INTERACTS — VideoPage.jsx, VideoDraft.jsx, shared theme/form/card/layout styles, shell layout.
 * RO:INVARIANTS — use CSS variables; local draft styling only; no hard-coded backend truth.
 * RO:TEST — visual/manual checks in CrabLink full-tab browser in light and dark mode.
 */

.video-page {
  display: grid;
  gap: 1rem;
}

.video-draft-card {
  min-width: 0;
}

.video-draft-intro {
  display: flex;
  flex-wrap: wrap;
  gap: 0.5rem;
  margin-bottom: 1rem;
}

.video-form-grid,
.video-reference-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 0.9rem;
  margin-bottom: 0.9rem;
}

.video-form-section {
  display: grid;
  gap: 0.8rem;
  margin: 1rem 0;
  padding: 1rem;
  border: 1px solid var(--cl-border);
  border-radius: 22px;
  background: var(--cl-surface);
}

[data-theme='dark'] .video-form-section {
  background: #050505;
}

.video-form-section-head {
  display: flex;
  flex-wrap: wrap;
  align-items: start;
  justify-content: space-between;
  gap: 0.75rem;
}

.video-form-section-head h3 {
  margin: 0;
  color: var(--cl-text);
  font-size: 1rem;
  line-height: 1.25;
}

.video-inline-dev {
  margin-top: 1rem;
}

.video-actions {
  margin-top: 1rem;
  padding-top: 1rem;
  border-top: 1px solid var(--cl-border);
}

.video-action-status {
  display: flex;
  flex-wrap: wrap;
  gap: 0.55rem;
  align-items: center;
  color: var(--cl-muted);
  font-size: 0.85rem;
  font-weight: 750;
}

.video-action-buttons {
  display: flex;
  flex-wrap: wrap;
  gap: 0.55rem;
  justify-content: flex-end;
}

.video-preview {
  display: grid;
  gap: 0.8rem;
}

.video-preview-frame {
  display: grid;
  min-height: 180px;
  place-items: center;
  border: 1px solid var(--cl-border);
  border-radius: 22px;
  background:
    linear-gradient(135deg, rgba(255, 255, 255, 0.08), transparent 48%),
    var(--cl-surface);
  color: var(--cl-muted);
  font-weight: 850;
  text-align: center;
}

[data-theme='dark'] .video-preview-frame {
  background:
    linear-gradient(135deg, rgba(255, 255, 255, 0.045), transparent 48%),
    #050505;
}

.video-preview-meta,
.video-preview-description {
  margin: 0;
}

.video-preview-meta {
  color: var(--cl-muted);
  font-weight: 750;
}

.video-preview-description {
  color: var(--cl-text);
  line-height: 1.55;
  white-space: pre-wrap;
}

.video-preview-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 0.45rem;
}

.video-preview-facts {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 0.65rem;
}

.video-preview-fact {
  display: grid;
  gap: 0.2rem;
  min-width: 0;
  padding: 0.75rem;
  border: 1px solid var(--cl-border);
  border-radius: 16px;
  background: var(--cl-card);
}

.video-preview-fact span {
  color: var(--cl-muted);
  font-size: 0.76rem;
  font-weight: 850;
  letter-spacing: 0.04em;
  text-transform: uppercase;
}

.video-preview-fact strong {
  overflow: hidden;
  color: var(--cl-text);
  font-size: 0.92rem;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.video-reference-list {
  display: grid;
  gap: 0.55rem;
  padding: 0.85rem;
  border: 1px solid var(--cl-border);
  border-radius: 18px;
  background: var(--cl-surface);
}

[data-theme='dark'] .video-reference-list {
  background: #050505;
}

.video-reference-list h3,
.video-reference-list p {
  margin: 0;
}

.video-reference-list h3 {
  color: var(--cl-text);
  font-size: 0.95rem;
}

.video-reference-list p {
  color: var(--cl-muted);
  line-height: 1.45;
}

.video-reference-list div {
  display: flex;
  flex-wrap: wrap;
  gap: 0.45rem;
}

.video-reference-list span {
  display: inline-flex;
  max-width: 100%;
  padding: 0.35rem 0.55rem;
  border: 1px solid var(--cl-border);
  border-radius: 999px;
  background: var(--cl-card);
  color: var(--cl-muted);
  font-size: 0.78rem;
  font-weight: 800;
}

.video-local-player {
  display: grid;
  gap: 0.85rem;
  margin: 1rem 0;
  padding: 1rem;
  border: 1px solid var(--cl-border);
  border-radius: 22px;
  background:
    linear-gradient(135deg, rgba(255, 255, 255, 0.08), transparent 44%),
    var(--cl-surface);
}

[data-theme='dark'] .video-local-player {
  background:
    linear-gradient(135deg, rgba(255, 255, 255, 0.045), transparent 44%),
    #050505;
}

.video-local-player-head {
  display: flex;
  flex-wrap: wrap;
  align-items: start;
  justify-content: space-between;
  gap: 0.75rem;
}

.video-local-player-head h3,
.video-local-player-head p {
  margin: 0;
}

.video-local-player-head h3 {
  color: var(--cl-text);
  font-size: 1rem;
  line-height: 1.25;
}

.video-local-player-head p {
  margin-top: 0.35rem;
  max-width: 72ch;
  color: var(--cl-muted);
  line-height: 1.5;
}

.video-local-player-controls,
.video-local-player-actions {
  display: flex;
  flex-wrap: wrap;
  align-items: center;
  gap: 0.65rem;
  justify-content: space-between;
}

.video-local-file-picker {
  display: inline-grid;
  gap: 0.35rem;
  min-width: min(100%, 20rem);
  color: var(--cl-muted);
  font-size: 0.78rem;
  font-weight: 850;
  letter-spacing: 0.04em;
  text-transform: uppercase;
}

.video-local-file-picker input {
  width: 100%;
  max-width: 100%;
  color: var(--cl-text);
  font: inherit;
  letter-spacing: 0;
  text-transform: none;
}

.video-local-player-frame {
  overflow: hidden;
  border: 1px solid var(--cl-border);
  border-radius: 22px;
  background: #050505;
}

.video-local-player-frame video {
  display: block;
  width: 100%;
  max-height: 58vh;
  background: #050505;
}

.video-local-player-empty,
.video-local-player-problem {
  display: grid;
  gap: 0.35rem;
  min-height: 9rem;
  place-items: center;
  padding: 1rem;
  border: 1px dashed var(--cl-border);
  border-radius: 22px;
  color: var(--cl-muted);
  text-align: center;
}

.video-local-player-empty strong,
.video-local-player-problem strong {
  color: var(--cl-text);
}

.video-local-player-problem {
  border-style: solid;
  border-color: rgba(255, 145, 77, 0.45);
  background: rgba(255, 145, 77, 0.08);
}

.video-local-player-grid {
  display: grid;
  grid-template-columns: repeat(4, minmax(0, 1fr));
  gap: 0.65rem;
}

.video-local-player-meta {
  display: grid;
  gap: 0.22rem;
  min-width: 0;
  padding: 0.7rem;
  border: 1px solid var(--cl-border);
  border-radius: 16px;
  background: var(--cl-card);
}

.video-local-player-meta span {
  color: var(--cl-muted);
  font-size: 0.72rem;
  font-weight: 850;
  letter-spacing: 0.04em;
  text-transform: uppercase;
}

.video-local-player-meta strong {
  overflow: hidden;
  color: var(--cl-text);
  font-size: 0.88rem;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.video-local-player-actions p {
  flex: 1 1 18rem;
  margin: 0;
  color: var(--cl-muted);
  font-size: 0.82rem;
  line-height: 1.45;
}

@media (max-width: 760px) {
  .video-form-grid,
  .video-reference-grid,
  .video-preview-facts,
  .video-local-player-grid {
    grid-template-columns: 1fr;
  }

  .video-actions {
    display: grid;
    justify-content: stretch;
  }

  .video-local-player-controls,
  .video-local-player-actions {
    display: grid;
    justify-content: stretch;
  }

  .video-action-buttons {
    justify-content: stretch;
  }

  .video-action-buttons .cl-button,
  .video-local-player-actions .cl-button,
  .video-local-player-controls .cl-button {
    width: 100%;
  }
}

.video-publish-card {
  min-width: 0;
  margin-top: 1rem;
}

.video-publish-badges,
.video-publish-actions,
.video-publish-controls,
.video-action-buttons,
.video-upload-success {
  display: flex;
  flex-wrap: wrap;
  gap: 0.55rem;
  align-items: center;
}

.video-publish-actions,
.video-action-buttons {
  justify-content: flex-start;
}

.video-section-copy {
  margin: 0 0 1rem;
  color: var(--cl-muted);
  line-height: 1.55;
}

.video-publish-grid {
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 0.65rem;
  margin: 0.75rem 0;
}

.video-publish-fact {
  display: grid;
  gap: 0.22rem;
  min-width: 0;
  padding: 0.75rem;
  border: 1px solid var(--cl-border);
  border-radius: 16px;
  background: var(--cl-card);
}

.video-publish-fact span {
  color: var(--cl-muted);
  font-size: 0.72rem;
  font-weight: 850;
  letter-spacing: 0.04em;
  text-transform: uppercase;
}

.video-publish-fact strong {
  overflow: hidden;
  color: var(--cl-text);
  font-size: 0.9rem;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.video-publish-fact strong.is-monospace {
  font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace;
  font-size: 0.78rem;
}

.video-publish-step {
  display: grid;
  gap: 0.85rem;
  margin-top: 1rem;
  padding: 1rem;
  border: 1px solid var(--cl-border);
  border-radius: 22px;
  background: var(--cl-surface);
}

[data-theme='dark'] .video-publish-step {
  background: #050505;
}

.video-publish-step header {
  display: flex;
  align-items: start;
  justify-content: space-between;
  gap: 0.75rem;
}

.video-publish-step h3,
.video-publish-step p {
  margin: 0;
}

.video-publish-step h3 {
  color: var(--cl-text);
  font-size: 1rem;
}

.video-publish-step p {
  color: var(--cl-muted);
  line-height: 1.5;
}

.video-publish-controls {
  align-items: end;
}

.video-publish-controls .cl-field {
  flex: 1 1 12rem;
}

.video-publish-warning {
  display: grid;
  gap: 0.35rem;
  padding: 0.8rem;
  border: 1px solid rgba(255, 145, 77, 0.45);
  border-radius: 18px;
  background: rgba(255, 145, 77, 0.08);
  color: var(--cl-muted);
  line-height: 1.45;
}

.video-publish-warning strong {
  color: var(--cl-text);
}

.video-upload-success {
  padding: 0.75rem;
  border: 1px solid var(--cl-border);
  border-radius: 18px;
  background: var(--cl-card);
}

@media (max-width: 760px) {
  .video-publish-grid {
    grid-template-columns: 1fr;
  }

  .video-publish-actions,
  .video-action-buttons,
  .video-upload-success {
    display: grid;
    justify-content: stretch;
  }

  .video-publish-actions .cl-button,
  .video-action-buttons .cl-button {
    width: 100%;
  }
}
.video-converter-card {
  margin: 1rem 0;
}

.video-converter-badges {
  display: flex;
  flex-wrap: wrap;
  gap: 0.45rem;
  justify-content: flex-end;
}

.video-converter-source {
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 0.65rem;
  margin: 0.85rem 0;
}

.video-converter-empty,
.video-converter-alert,
.video-converter-skips {
  display: grid;
  gap: 0.35rem;
  padding: 0.85rem;
  border: 1px solid var(--cl-border);
  border-radius: 18px;
  background: var(--cl-surface);
  color: var(--cl-muted);
  line-height: 1.45;
}

[data-theme='dark'] .video-converter-empty,
[data-theme='dark'] .video-converter-alert,
[data-theme='dark'] .video-converter-skips {
  background: #050505;
}

.video-converter-empty strong,
.video-converter-alert strong,
.video-converter-skips strong {
  color: var(--cl-text);
}

.video-converter-alert ul {
  margin: 0;
  padding-left: 1.1rem;
}

.video-converter-plan {
  display: grid;
  gap: 0.75rem;
  margin-top: 1rem;
}

.video-converter-plan > header {
  display: flex;
  align-items: start;
  justify-content: space-between;
  gap: 0.75rem;
}

.video-converter-plan h3,
.video-converter-plan p {
  margin: 0;
}

.video-converter-plan h3 {
  color: var(--cl-text);
  font-size: 1rem;
}

.video-converter-renditions {
  display: grid;
  gap: 0.65rem;
}

.video-converter-rendition {
  display: grid;
  gap: 0.7rem;
  padding: 0.85rem;
  border: 1px solid var(--cl-border);
  border-radius: 18px;
  background: var(--cl-card);
}

.video-converter-rendition > div {
  display: grid;
  gap: 0.25rem;
}

.video-converter-rendition strong {
  color: var(--cl-text);
  font-size: 0.95rem;
}

.video-converter-rendition span {
  color: var(--cl-muted);
  line-height: 1.45;
}

.video-converter-rendition dl {
  display: grid;
  grid-template-columns: repeat(4, minmax(0, 1fr));
  gap: 0.5rem;
  margin: 0;
}

.video-converter-rendition dl div {
  display: grid;
  gap: 0.2rem;
  min-width: 0;
  padding: 0.65rem;
  border: 1px solid var(--cl-border);
  border-radius: 14px;
  background: var(--cl-surface);
}

[data-theme='dark'] .video-converter-rendition dl div {
  background: #050505;
}

.video-converter-rendition dt {
  color: var(--cl-muted);
  font-size: 0.72rem;
  font-weight: 850;
  letter-spacing: 0.04em;
  text-transform: uppercase;
}

.video-converter-rendition dd {
  overflow: hidden;
  margin: 0;
  color: var(--cl-text);
  font-size: 0.84rem;
  font-weight: 800;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.video-converter-skips {
  margin-top: 0.85rem;
}

.video-converter-skips span {
  display: block;
  color: var(--cl-muted);
}

.video-converter-actions {
  display: flex;
  flex-wrap: wrap;
  gap: 0.55rem;
  margin-top: 1rem;
}

@media (max-width: 920px) {
  .video-converter-source,
  .video-converter-rendition dl {
    grid-template-columns: repeat(2, minmax(0, 1fr));
  }
}

@media (max-width: 640px) {
  .video-converter-source,
  .video-converter-rendition dl {
    grid-template-columns: 1fr;
  }

  .video-converter-actions .cl-button {
    width: 100%;
  }
}
.video-job-panel {
  display: grid;
  gap: 0.8rem;
  margin-top: 1rem;
  padding: 0.9rem;
  border: 1px solid var(--cl-border);
  border-radius: 20px;
  background:
    radial-gradient(circle at 12% 0%, rgba(34, 197, 94, 0.12), transparent 28%),
    var(--cl-card);
}

.video-job-panel > header {
  display: flex;
  align-items: start;
  justify-content: space-between;
  gap: 0.75rem;
}

.video-job-panel h3,
.video-job-panel p {
  margin: 0;
}

.video-job-panel h3 {
  color: var(--cl-text);
  font-size: 1rem;
}

.video-job-progress {
  overflow: hidden;
  height: 0.75rem;
  border: 1px solid var(--cl-border);
  border-radius: 999px;
  background: var(--cl-surface);
}

.video-job-progress span {
  display: block;
  height: 100%;
  border-radius: inherit;
  background: linear-gradient(90deg, rgba(34, 197, 94, 0.72), rgba(14, 165, 233, 0.72));
  transition: width 180ms ease;
}

.video-job-meta {
  display: grid;
  grid-template-columns: repeat(4, minmax(0, 1fr));
  gap: 0.65rem;
}

.video-job-outputs {
  display: grid;
  gap: 0.55rem;
}

.video-job-outputs article {
  display: grid;
  gap: 0.22rem;
  min-width: 0;
  padding: 0.75rem;
  border: 1px solid var(--cl-border);
  border-radius: 16px;
  background: var(--cl-surface);
}

[data-theme='dark'] .video-job-outputs article,
[data-theme='dark'] .video-job-progress {
  background: #050505;
}

.video-job-outputs strong {
  color: var(--cl-text);
  font-size: 0.9rem;
}

.video-job-outputs span {
  overflow: hidden;
  color: var(--cl-muted);
  font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, 'Liberation Mono', monospace;
  font-size: 0.78rem;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.video-job-outputs em,
.video-job-note {
  color: var(--cl-muted);
  font-size: 0.84rem;
  font-style: normal;
  line-height: 1.45;
}

@media (max-width: 920px) {
  .video-job-meta {
    grid-template-columns: repeat(2, minmax(0, 1fr));
  }
}

@media (max-width: 640px) {
  .video-job-meta {
    grid-template-columns: 1fr;
  }
}
.video-native-source-panel {
  display: grid;
  gap: 0.8rem;
  margin: 0.95rem 0;
  padding: 0.9rem;
  border: 1px solid var(--cl-border);
  border-radius: 20px;
  background:
    radial-gradient(circle at 0% 0%, rgba(14, 165, 233, 0.12), transparent 28%),
