}

.video-native-source-panel p,
.video-native-source-actions span {
  color: var(--cl-muted);
  font-size: 0.88rem;
  line-height: 1.45;
}

.video-native-source-form {
  display: grid;
  grid-template-columns: minmax(0, 1fr) auto;
  gap: 0.6rem;
}

.video-native-source-input {
  min-width: 0;
  width: 100%;
}

.video-native-source-registered {
  display: grid;
  grid-template-columns: repeat(4, minmax(0, 1fr));
  gap: 0.65rem;
}

.video-native-source-actions {
  display: flex;
  flex-wrap: wrap;
  align-items: center;
  gap: 0.65rem;
}

@media (max-width: 920px) {
  .video-native-source-form,
