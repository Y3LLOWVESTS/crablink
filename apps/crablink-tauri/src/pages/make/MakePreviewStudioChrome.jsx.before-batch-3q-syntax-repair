/**
 * RO:WHAT — Preview studio chrome for the crab://make route.
 * RO:WHY — App Integration; Concerns: DX/SEC/RES; keeps the route shell smaller while preserving local creator-studio UX.
 * RO:INTERACTS — MakePage.jsx, make timeline/audio/sequence models, linked video preview, cutout/preset/mode cards.
 * RO:INVARIANTS — display/user intent only; no fake CIDs; no fake receipts; no wallet mutation; no paid unlock from cache.
 * RO:METRICS — none.
 * RO:CONFIG — local draft settings and timeline editor state only.
 * RO:SECURITY — no private keys, capabilities, balances, receipts, or backend truth are created here.
 * RO:TEST — npm run build; manual crab://make preview/timeline/audio/linked-video smoke.
 */

import { useCallback, useEffect, useMemo, useRef, useState } from 'react';
import MakeLinkedMediaComposerPopover from './MakeLinkedMediaComposerPopover.jsx';
import MakeLinkedVideoPaymentInspector from './MakeLinkedVideoPaymentInspector.jsx';
import MakePreviewAudioLane from './MakePreviewAudioLane.jsx';
import MakePreviewDrawer from './MakePreviewDrawer.jsx';
import MakePreviewRecordControls from './MakePreviewRecordControls.jsx';
import MakePreviewTimelineMarker from './MakePreviewTimelineMarker.jsx';
import MakePreviewMiniTimelineHeader from './MakePreviewMiniTimelineHeader.jsx';
import MakePreviewLinkedVideoTimelineClip from './MakePreviewLinkedVideoTimelineClip.jsx';
import {
  makeOverlayClipDurationMs,
  makeOverlayClipLookLabel,
} from './MakePreviewOverlayWidgets.jsx';
import {
  createTimelineItemKeys,
  idFromTimelineItemKey,
  isLinkedVideoTimelineItemKey,
  isLocalTimelineItemKey,
  makeLinkedVideoTimelineItemKey,
  makeLocalTimelineItemKey,
  normalizeTimelineItemOrderKeys,
  timelineOrderSignature,
} from './makePageConstants.js';
import {
  getClipTrimEndMs,
  getClipTrimStartMs,
  timelineEffectCssFilter,
} from './makeTimelineModel.js';
import {
  activeAudioTimeForTimelineMs,
  prepareAudioTracksForTimeline,
} from './makeAudioTimelineModel.js';
import { formatDurationMs } from './makeDraftModel.js';
import {
  clamp,
  formatTimelinePreciseTimeMs,
  getTimelineAbsolutePositionMs,
  getTimelineClipVisibleDurationMs,
  snapTimelineFrameMs,
  sourceMsToVisiblePct,
  sourceRangeToVisiblePlate,
} from './makeSequenceModel.js';

export default function MakePreviewStudioChrome({
  app,
  backgroundImageUrl,
  backgroundVideoUrl,
  canRecord,
  clips,
  countdown,
  draft,
  inputReady,
  inputState,
  isCountingDown,
  isRecording,
  onApplyPreset,
  onAddTimelineClip,
  onAddLinkedVideoDraft,
  onRemoveLinkedVideoDraft,
  onReorderClips,
  timelineItemOrder = [],
  onReorderTimelineItems,
  onUpdateLinkedVideoDraftTiming,
  onLinkedVideoPreviewReady,
  audioTracks = [],
  linkedVideoDrafts = [],
  onRequestAddAudioTrack,
  onAddLinkedAudioDraft,
  onRemoveAudioTrack,
  onUpdateAudioTrackVolume,
  onUpdateAudioTrackTiming,
  totalTimelineDurationMs = 0,
  audioPreviewRefs,
  onChooseBackgroundImage,
  onChooseBackgroundVideo,
  onClearBackgroundMedia,
  onCloseDrawer,
  onModeChange,
  onOpenVideo,
  onPauseSequence,
  onPlaySequence,
  onRestartSequence,
  onApproveSequence,
  onSelectClip,
  onStartInputs,
  onStartRecording,
  onStopInputs,
  onStopRecording,
  onUpdateDraft,
  onUpdateSelectedTimeline,
  onUpdateClipTimeline,
  onCaptureTimelineHistory,
  onSplitTimelineAt,
  onDeleteTimelineRange,
  onTimelineUndo,
  onTimelineRedo,
  timelineCanUndo = false,
  timelineCanRedo = false,
  outputPreset,
  previewDrawer,
  recorderState,
  recordingElapsedMs,
  sequenceState,
  selectedClip,
  selectedClipId,
  selectedMode,
  subjectEditAvailable = false,
  subjectEditMode = false,
  onToggleSubjectEdit,
  onTimelineHoverChange,
  setPreviewDrawer,
  totalDurationMs,
}) {
  const timelinePreviewVideoRef = useRef(null);
  const [trimEditorClipId, setTrimEditorClipId] = useState('');
  const [timelineTool, setTimelineTool] = useState('select');
  const [timelineZoom, setTimelineZoom] = useState(1);
  const [timelineSelection, setTimelineSelection] = useState(null);
  const [timelinePreview, setTimelinePreview] = useState(null);
  const [linkedMediaComposer, setLinkedMediaComposer] = useState(null);
  const [linkedVideoPreviewId, setLinkedVideoPreviewId] = useState('');
  const [selectedLinkedVideoId, setSelectedLinkedVideoId] = useState('');
  const previewTimelineRailRef = useRef(null);
  const [previewClipMoveDrag, setPreviewClipMoveDrag] = useState(null);
  const [audioMoveDrag, setAudioMoveDrag] = useState(null);
  const [audioTrimDrag, setAudioTrimDrag] = useState(null);
  const [selectedAudioTrackId, setSelectedAudioTrackId] = useState('');
  const [selectedTimelineMediaKind, setSelectedTimelineMediaKind] = useState('video');
  const audioAutoSpreadSignatureRef = useRef('');

  const hasClips = clips.length > 0;
  const activeDrawer = previewDrawer === 'effects' || previewDrawer === 'settings' || previewDrawer === 'modes';
  const sequenceStatus = sequenceState?.status || 'idle';
  const sequenceActive = hasClips && ['playing', 'paused', 'reviewed', 'approved'].includes(sequenceStatus);
  const sequencePlaying = sequenceStatus === 'playing';
  const sequenceCanApprove = hasClips && sequenceStatus === 'reviewed' && !isRecording;
  const sequenceCurrentIndex = Math.max(0, Number(sequenceState?.currentIndex || 0));
  const sequenceClip = clips[sequenceCurrentIndex] || clips[0] || null;
  const visibleTotalDurationMs = clips.reduce((sum, clip) => sum + Math.max(1, makeOverlayClipDurationMs(clip)), 0);
  const selectedClipDurationMs = selectedClip ? makeOverlayClipDurationMs(selectedClip) : 0;
  const canApplyTimelineEffect = Boolean(selectedClip && typeof onUpdateSelectedTimeline === 'function');
  const sourceModeLocked = inputReady || isRecording || isCountingDown;
  const selectedModeLabel = selectedMode?.shortLabel || selectedMode?.label || 'Mode';
  const editedClip = clips.find((clip) => clip.id === trimEditorClipId) || null;
  const editTargetClipId = selectedClip?.id || sequenceClip?.id || clips[0]?.id || '';
  const trimEditorActive = Boolean(editedClip);
  const cursorToolActive = timelineTool === 'cursor';
  const timelineSelectionClip = timelineSelection?.clipId
    ? clips.find((clip) => clip.id === timelineSelection.clipId) || null
    : null;
  const timelineSelectionStartMs = timelineSelection ? Math.min(timelineSelection.startMs, timelineSelection.endMs) : 0;
  const timelineSelectionEndMs = timelineSelection ? Math.max(timelineSelection.startMs, timelineSelection.endMs) : 0;
  const timelineSelectionRangeMs = Math.max(0, timelineSelectionEndMs - timelineSelectionStartMs);
  const canSplitTimelineSelection = Boolean(cursorToolActive && timelineSelectionClip && timelineSelection?.mode !== 'range');
  const canDeleteTimelineSelection = Boolean(cursorToolActive && timelineSelectionClip && timelineSelectionRangeMs >= 80);
  const timelinePreviewClip = timelinePreview?.clipId
    ? clips.find((clip) => clip.id === timelinePreview.clipId) || null
    : null;
  const timelinePreviewActive = Boolean(timelinePreviewClip && timelinePreview?.visible);
  const timelineLoopPlaying = timelinePreviewActive && timelinePreview?.status === 'looping';
  const timelineRangeLoopAvailable = Boolean(cursorToolActive && timelineSelectionClip && timelineSelection?.mode === 'range' && timelineSelectionRangeMs >= 80);
  const hasLinkedVideoDrafts = linkedVideoDrafts.length > 0;
  const linkedVideoTimelineDurationMs = useMemo(
    () => linkedVideoDrafts.reduce((sum, item) => {
      const explicitDuration = Number(item?.timelineDurationMs || 0);
      const sourceStartMs = Number(item?.sourceStartMs || 0);
      const sourceEndMs = Number(item?.sourceEndMs || 0);
      const rangedDuration = sourceEndMs > sourceStartMs ? sourceEndMs - sourceStartMs : 0;

      return sum + Math.max(1, explicitDuration || rangedDuration || 30_000);
    }, 0),
    [linkedVideoDrafts],
  );
  const timelineHasItems = hasClips || hasLinkedVideoDrafts;
  const timelineVisualTotalDurationMs = Math.max(
    1,
    visibleTotalDurationMs + linkedVideoTimelineDurationMs,
  );
  const timelineSummaryLabel = timelineHasItems
    ? [
        hasClips ? `${clips.length} local clip${clips.length === 1 ? '' : 's'}` : '',
        hasLinkedVideoDrafts
          ? `${linkedVideoDrafts.length} linked video ref${linkedVideoDrafts.length === 1 ? '' : 's'}`
          : '',
        hasClips ? formatDurationMs(totalDurationMs) : '',
        `${Math.round(timelineZoom * 100)}%`,
      ].filter(Boolean).join(' · ')
    : 'No clips yet';
  const timelineVisualItemKeys = useMemo(
    () => normalizeTimelineItemOrderKeys(
      timelineItemOrder,
      createTimelineItemKeys(clips, linkedVideoDrafts),
    ),
    [clips, linkedVideoDrafts, timelineItemOrder],
  );
  const timelineVisualOrderMap = useMemo(
    () => new Map(timelineVisualItemKeys.map((key, index) => [key, index])),
    [timelineVisualItemKeys],
  );
  const timelineVisualOrderForKey = (key) => (
    timelineVisualOrderMap.has(key) ? timelineVisualOrderMap.get(key) * 4 : 10_000
  );
  const linkedVideoPreviewItem = useMemo(() => {
    if (!linkedVideoDrafts.length) {
      return null;
    }

    return linkedVideoDrafts.find((item) => item.id === linkedVideoPreviewId) || null;
  }, [linkedVideoDrafts, linkedVideoPreviewId]);

  useEffect(() => {
    if (!linkedVideoPreviewId) {
      return;
    }

    if (!linkedVideoDrafts.some((item) => item.id === linkedVideoPreviewId)) {
      setLinkedVideoPreviewId('');
    }
  }, [linkedVideoDrafts, linkedVideoPreviewId]);

  const audioLaneRawEndMs = (audioTracks || []).reduce((max, track) => {
    const startMs = Math.max(0, Number(track?.offsetMs || 0));
    const rawDurationMs = Math.max(0, Number(track?.durationMs || 0));
    const trimStartMs = Math.max(0, Number(track?.trimStartMs || 0));
    const trimEndMs = Math.max(trimStartMs, Number(track?.trimEndMs || rawDurationMs || 1000));
    const effectiveMs = Math.max(500, Number(track?.effectiveDurationMs || 0) || (trimEndMs - trimStartMs) || rawDurationMs || 1000);

    return Math.max(max, startMs + effectiveMs);
  }, 0);
  const audioLaneVisualDurationMs = Math.max(
    1,
    Number(totalTimelineDurationMs || 0),
    audioLaneRawEndMs,
  );
  const preparedAudioTracks = prepareAudioTracksForTimeline(audioTracks, audioLaneVisualDurationMs);
  const hasAudioTracks = preparedAudioTracks.length > 0;
  const selectedAudioTrack = useMemo(
    () => preparedAudioTracks.find((track) => track.id === selectedAudioTrackId) || preparedAudioTracks[0] || null,
    [preparedAudioTracks, selectedAudioTrackId],
  );
  const audioEditActive = selectedTimelineMediaKind === 'audio' && Boolean(selectedAudioTrack);
  const editTimelineButtonDisabled = isRecording || cursorToolActive || (
    audioEditActive ? !selectedAudioTrack?.id : !editTargetClipId
  );
  const editTimelineButtonTitle = audioEditActive
    ? 'Edit selected audio clip using the start, length, and volume controls below the audio lane'
    : (trimEditorActive ? 'Done trimming selected clip' : 'Trim selected clip by dragging the clip edges');
  const editTimelineButtonLabel = audioEditActive
    ? 'Edit audio'
    : (trimEditorActive ? 'Done trim' : 'Edit clip');

  useEffect(() => {
    if (!preparedAudioTracks.length) {
      if (selectedAudioTrackId) {
        setSelectedAudioTrackId('');
      }

      if (selectedTimelineMediaKind === 'audio') {
        setSelectedTimelineMediaKind('video');
      }

      return;
    }

    if (!preparedAudioTracks.some((track) => track.id === selectedAudioTrackId)) {
      setSelectedAudioTrackId(preparedAudioTracks[0]?.id || '');
    }
  }, [preparedAudioTracks, selectedAudioTrackId, selectedTimelineMediaKind]);

  const audioLaneSpreadSignature = preparedAudioTracks
    .map((track) => [
      track.id,
      Math.round(Number(track.offsetMs || 0)),
      Math.round(Number(track.effectiveDurationMs || track.durationMs || 0)),
    ].join(':'))
    .join('|');

  useEffect(() => {
    if (
      preparedAudioTracks.length < 2 ||
      typeof onUpdateAudioTrackTiming !== 'function' ||
      !preparedAudioTracks.every((track) => Math.abs(Number(track.offsetMs || 0)) < 10)
    ) {
      return;
    }

    if (audioAutoSpreadSignatureRef.current === audioLaneSpreadSignature) {
      return;
    }

    audioAutoSpreadSignatureRef.current = audioLaneSpreadSignature;

    let cursorMs = 0;

    for (const [index, track] of preparedAudioTracks.entries()) {
      const effectiveMs = Math.max(500, Number(track.effectiveDurationMs || track.durationMs || 1000));

      if (index > 0) {
        onUpdateAudioTrackTiming(track.id, { offsetMs: cursorMs });
      }

      cursorMs += effectiveMs;
    }
  }, [audioLaneSpreadSignature, onUpdateAudioTrackTiming, preparedAudioTracks.length]);

  const openLinkedMediaComposer = (kind) => {
    setLinkedMediaComposer({
      kind,
      url: '',
      sourceStartText: '0:00',
      sourceEndText: kind === 'video' ? '0:30' : '',
      useEntireSource: kind !== 'video',
    });
  };

  const closeLinkedMediaComposer = () => {
    setLinkedMediaComposer(null);
  };

  const setAudioPreviewNode = (trackId, node) => {
    if (!audioPreviewRefs?.current || !trackId) {
      return;
    }

    if (node) {
      audioPreviewRefs.current.set(trackId, node);
      return;
    }

    audioPreviewRefs.current.delete(trackId);
  };

  const updateLinkedMediaComposerUrl = (url) => {
    setLinkedMediaComposer((current) => current
      ? {
          ...current,
          url,
        }
      : current);
  };

  const updateLinkedMediaComposerField = (patch) => {
    setLinkedMediaComposer((current) => current
      ? {
          ...current,
          ...patch,
        }
      : current);
  };

  const submitLinkedMediaComposer = () => {
    const rawUrl = String(linkedMediaComposer?.url || linkedMediaComposer?.value || '').trim();

    if (!rawUrl) {
      return;
    }

    const saved = linkedMediaComposer?.kind === 'audio'
      ? onAddLinkedAudioDraft?.(rawUrl)
      : onAddLinkedVideoDraft?.(rawUrl, {
          sourceStartText: linkedMediaComposer?.sourceStartText || '0:00',
          sourceEndText: linkedMediaComposer?.sourceEndText || '0:30',
          useEntireSource: Boolean(linkedMediaComposer?.useEntireSource),
        });

    if (saved !== false) {
      if (linkedMediaComposer?.kind === 'video') {
        const savedId = typeof saved === 'object' && saved ? saved.id : '';
        if (savedId) {
          setSelectedLinkedVideoId(savedId);
          setLinkedVideoPreviewId(savedId);
        }
      }

      closeLinkedMediaComposer();
    }
  };

  const handleLinkedMediaComposerSubmit = (event) => {
    event?.preventDefault?.();
    submitLinkedMediaComposer();
  };

  useEffect(() => {
    if (trimEditorClipId && !clips.some((clip) => clip.id === trimEditorClipId)) {
      setTrimEditorClipId('');
    }
  }, [clips, trimEditorClipId]);

  useEffect(() => {
    const refs = audioPreviewRefs?.current;

    if (!refs) {
      return;
    }

    const timelineMs = Number(sequenceState.totalElapsedMs || 0);
    const shouldPlay = sequenceState.status === 'playing';

    const activeAudioCandidate = shouldPlay
      ? [...preparedAudioTracks]
          .sort((a, b) => {
            const offsetDelta = Number(a?.offsetMs || 0) - Number(b?.offsetMs || 0);

            if (offsetDelta !== 0) {
              return offsetDelta;
            }

            return String(a?.id || '').localeCompare(String(b?.id || ''));
          })
          .map((track) => ({
            track,
            active: activeAudioTimeForTimelineMs(track, timelineMs),
          }))
          .find((candidate) => Boolean(candidate.active))
      : null;
    const activeAudioTrackId = activeAudioCandidate?.track?.id || '';

    for (const track of preparedAudioTracks) {
      const audio = refs.get(track.id);

      if (!audio) {
        continue;
      }

      const active = track.id === activeAudioTrackId ? activeAudioCandidate.active : null;

      if (!active) {
        try {
          audio.pause();
        } catch (_error) {
          // Local audio preview cleanup is best effort.
        }
        continue;
      }

      audio.volume = Math.max(0, Math.min(1, Number(active.volume || 0)));
      audio.muted = Boolean(track.muted);
      audio.playbackRate = 1;

      if (Math.abs(Number(audio.currentTime || 0) - active.trackTimeSeconds) > 0.42) {
        try {
          audio.currentTime = active.trackTimeSeconds;
        } catch (_error) {
          // Best-effort seek.
        }
      }

      if (audio.paused) {
        const playResult = audio.play?.();

        if (playResult && typeof playResult.catch === 'function') {
          playResult.catch(() => {
            // Browsers may require a user gesture. The Play button is a gesture in normal use.
          });
        }
      }
    }

    for (const [trackId, audio] of refs.entries()) {
      if (!preparedAudioTracks.some((track) => track.id === trackId)) {
        try {
          audio.pause();
        } catch (_error) {
          // Best-effort cleanup.
        }
      }
    }
  }, [audioPreviewRefs, preparedAudioTracks, sequenceState.status, sequenceState.totalElapsedMs]); // sync local audio preview

  useEffect(() => {
    if (timelineSelection?.clipId && !clips.some((clip) => clip.id === timelineSelection.clipId)) {
      setTimelineSelection(null);
      setTimelinePreview(null);
    }
  }, [clips, timelineSelection]);

  useEffect(() => {
    if (timelinePreview?.clipId && !clips.some((clip) => clip.id === timelinePreview.clipId)) {
      setTimelinePreview(null);
    }
  }, [clips, timelinePreview]);

  useEffect(() => {
    if (isRecording || inputState.status === 'starting') {
      setTimelineSelection(null);
      setTimelinePreview(null);
    }
  }, [inputState.status, isRecording]);

  const getTimelinePreviewProgressPct = (clip, sourceMs) => {
    const trimStartMs = getClipTrimStartMs(clip);
    const trimEndMs = getClipTrimEndMs(clip);
    const visibleMs = Math.max(1, trimEndMs - trimStartMs);

    return clamp(((Number(sourceMs || trimStartMs) - trimStartMs) / visibleMs) * 100, 0, 100, 0);
  };

  const seekTimelinePreviewVideo = useCallback(async (targetMs, { play = false } = {}) => {
    const video = timelinePreviewVideoRef.current;

    if (!video) {
      return;
    }

    try {
      await waitForSequenceVideoReady(video);
      await settleSequenceVideoSeek(video, Math.max(0, Number(targetMs || 0)) / 1000);

      if (play) {
        const playResult = video.play?.();

        if (playResult && typeof playResult.then === 'function') {
          await playResult;
        }
      }
    } catch (_error) {
      // Local marker/range preview is best-effort. Timeline editing should keep working.
    }
  }, []);

  useEffect(() => {
    if (!timelinePreviewActive || !timelinePreviewClip) {
      return undefined;
    }

    let cancelled = false;
    const targetMs = timelinePreview.status === 'looping'
      ? Number(timelinePreview.startMs || getClipTrimStartMs(timelinePreviewClip))
      : Number(timelinePreview.focusMs || timelinePreview.startMs || getClipTrimStartMs(timelinePreviewClip));

    window.requestAnimationFrame(() => {
      if (!cancelled) {
        seekTimelinePreviewVideo(targetMs, { play: timelinePreview.status === 'looping' });
      }
    });

    return () => {
      cancelled = true;
    };
  }, [
    seekTimelinePreviewVideo,
    timelinePreview?.clipId,
    timelinePreview?.updatedAt,
    timelinePreview?.status,
    timelinePreviewActive,
    timelinePreviewClip,
    timelinePreviewClip?.objectUrl,
  ]);

  const recordDisabled =
    inputState.status === 'starting' ||
    (inputReady && !isRecording && !canRecord) ||
    (isCountingDown && countdown <= 0);

  const recordLabel = isRecording
    ? `Stop ${formatDurationMs(recordingElapsedMs)}`
    : isCountingDown
      ? `${countdown}`
      : inputReady
        ? 'Record'
        : inputState.status === 'starting'
          ? 'Starting'
          : 'Start';

  const recordTitle = isRecording
    ? 'Stop recording'
    : inputReady
      ? 'Record a clip'
      : 'Start preview';

  const handleRecordClick = () => {
    if (recordDisabled) {
      return;
    }

    if (isRecording) {
      onStopRecording();
      return;
    }

    if (!inputReady) {
      onStartInputs();
      return;
    }

    onStartRecording();
  };

  const toggleDrawer = (drawer) => {
    setPreviewDrawer((current) => (current === drawer ? '' : drawer));
    setTrimEditorClipId('');
    setTimelineTool('select');
    setTimelineSelection(null);
  };

  const toggleTrimEditor = (clipId = editTargetClipId) => {
    if (!clipId || isRecording) {
      return;
    }

    onSelectClip(clipId);
    setTimelineTool('select');
    setTimelineSelection(null);
    onTimelineHoverChange?.(true);
    setTrimEditorClipId((current) => (current === clipId ? '' : clipId));
  };

  const beginPreviewTrimDrag = (event, clip, edge) => {
    if (!clip?.id || isRecording || typeof onUpdateClipTimeline !== 'function') {
      return;
    }

    const shell = event.currentTarget.closest('.make-preview-mini-clip');
    const rect = shell?.getBoundingClientRect?.();

    if (!rect || rect.width <= 0 || clip.durationMs <= 0) {
      return;
    }

    event.preventDefault();
    event.stopPropagation();

    onSelectClip(clip.id);
    setPreviewDrawer('');
    setTrimEditorClipId('');
    setTimelineTool('select');
    setTimelineSelection(null);
    setTrimEditorClipId(clip.id);
    onCaptureTimelineHistory?.();
    onTimelineHoverChange?.(true);

    const durationMs = Math.max(1, Number(clip.durationMs || 0));
    const minClipMs = 350;
    const originalStartMs = getClipTrimStartMs(clip);
    const originalEndMs = getClipTrimEndMs(clip);
    const originalVisibleMs = Math.max(minClipMs, originalEndMs - originalStartMs);

    const pointerToSourceMs = (clientX) => {
      const pct = (Number(clientX || rect.left) - rect.left) / Math.max(1, rect.width);
      return Math.round(originalStartMs + (pct * originalVisibleMs));
    };

    const applyPointer = (clientX) => {
      const sourceMs = pointerToSourceMs(clientX);

      if (edge === 'start') {
        onUpdateClipTimeline(clip.id, {
          trimStartMs: clamp(sourceMs, 0, Math.max(0, originalEndMs - minClipMs), 0),
        });
        return;
      }

      onUpdateClipTimeline(clip.id, {
        trimEndMs: clamp(sourceMs, Math.min(durationMs, originalStartMs + minClipMs), durationMs, durationMs),
      });
    };

    const handleMove = (moveEvent) => {
      applyPointer(moveEvent.clientX);
      moveEvent.preventDefault();
    };

    const handleEnd = () => {
      window.removeEventListener('pointermove', handleMove);
      window.removeEventListener('pointerup', handleEnd);
      window.removeEventListener('pointercancel', handleEnd);
    };

    window.addEventListener('pointermove', handleMove);
    window.addEventListener('pointerup', handleEnd, { once: true });
    window.addEventListener('pointercancel', handleEnd, { once: true });

    try {
      event.currentTarget.setPointerCapture(event.pointerId);
    } catch (_error) {
      // Pointer capture is best effort.
    }

    applyPointer(event.clientX);
  };

  const beginLinkedVideoTrimDrag = (event, item, edge) => {
    if (!item?.id || isRecording || typeof onUpdateLinkedVideoDraftTiming !== 'function') {
      return;
    }

    const shell = event.currentTarget.closest('.make-preview-linked-video-clip');
    const rect = shell?.getBoundingClientRect?.();

    if (!rect || rect.width <= 0) {
      return;
    }

    event.preventDefault();
    event.stopPropagation();

    setPreviewDrawer('');
    setTimelineTool('select');
    setTimelineSelection(null);
    onTimelineHoverChange?.(true);

    const minWindowMs = 1_000;
    const originalStartMs = Math.max(0, Number(item.sourceStartMs || 0));
    const originalEndMs = Math.max(originalStartMs + minWindowMs, Number(item.sourceEndMs || originalStartMs + 30_000));
    const originalDurationMs = Math.max(minWindowMs, originalEndMs - originalStartMs);

    const pointerToWindowMs = (clientX) => {
      const pct = (Number(clientX || rect.left) - rect.left) / Math.max(1, rect.width);
      return Math.round(originalStartMs + (Math.max(0, Math.min(1, pct)) * originalDurationMs));
    };

    const applyPointer = (clientX) => {
      const sourceMs = pointerToWindowMs(clientX);

      if (edge === 'start') {
        onUpdateLinkedVideoDraftTiming(item.id, {
          sourceStartMs: clamp(sourceMs, 0, Math.max(0, originalEndMs - minWindowMs), originalStartMs),
          sourceEndMs: originalEndMs,
          useEntireSource: false,
        });
        return;
      }

      onUpdateLinkedVideoDraftTiming(item.id, {
        sourceStartMs: originalStartMs,
        sourceEndMs: clamp(sourceMs, originalStartMs + minWindowMs, originalStartMs + (6 * 60 * 60 * 1000), originalEndMs),
        useEntireSource: false,
      });
    };

    const handleMove = (moveEvent) => {
      applyPointer(moveEvent.clientX);
      moveEvent.preventDefault();
    };

    const handleEnd = () => {
      window.removeEventListener('pointermove', handleMove);
      window.removeEventListener('pointerup', handleEnd);
      window.removeEventListener('pointercancel', handleEnd);
    };

    window.addEventListener('pointermove', handleMove);
    window.addEventListener('pointerup', handleEnd, { once: true });
    window.addEventListener('pointercancel', handleEnd, { once: true });

    try {
      event.currentTarget.setPointerCapture(event.pointerId);
    } catch (_error) {
      // Pointer capture is best effort.
    }

    applyPointer(event.clientX);
