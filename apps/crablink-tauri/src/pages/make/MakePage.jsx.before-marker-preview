/**
 * RO:WHAT — Route-owned local creator studio for crab://make recording and clip assembly.
 * RO:WHY — App Integration; Concerns: DX/SEC/RES; makes Make feel like the CrabLink centerpiece without making UI backend authority.
 * RO:INTERACTS — makeDraftModel, shared creator components, browser MediaDevices/MediaRecorder, future crab://video handoff.
 * RO:INVARIANTS — local clips only; no fake CIDs; no fake receipts; no wallet mutation; no paid unlock from cache.
 * RO:METRICS — none.
 * RO:CONFIG — local draft settings, MediaRecorder MIME support, browser capture permissions.
 * RO:SECURITY — no private paths, secrets, capabilities, tokens, balances, or receipt truth are stored in React state.
 * RO:TEST — npm run build; manual crab://make camera/screen/PiP record-stop-download smoke.
 */

import { useCallback, useEffect, useMemo, useRef, useState } from 'react';
import Badge from '../../shared/components/Badge.jsx';
import Button from '../../shared/components/Button.jsx';
import Card from '../../shared/components/Card.jsx';
import CreatorWorkspaceLayout from '../../shared/components/CreatorWorkspaceLayout.jsx';
import Field from '../../shared/components/Field.jsx';
import JsonPreview from '../../shared/components/JsonPreview.jsx';
import StatChip from '../../shared/components/StatChip.jsx';
import TextArea from '../../shared/components/TextArea.jsx';
import TextInput from '../../shared/components/TextInput.jsx';
import {
  MAKE_BACKGROUND_KINDS,
  MAKE_CUTOUT_POLARITIES,
  MAKE_MODES,
  MAKE_OUTPUT_PRESETS,
  MAKE_PIP_STYLES,
  MAKE_SCENE_PRESETS,
  MAKE_SCENES,
  applyMakePreset,
  buildMakeSessionPlan,
  clearStoredMakeDraft,
  createMakeDraft,
  deriveMakeReadiness,
  findMakeMode,
  findOutputPreset,
  formatBytes,
  formatDurationMs,
  readStoredMakeDraft,
  selectRecorderMimeType,
  writeLatestMakeSessionPlan,
  writeStoredMakeDraft,
} from './makeDraftModel.js';
import { createMakeExportClient, writeLatestMakeExportHandoff } from '../../shared/api/makeExportClient.js';
import {
  clearMakeCompositorState,
  drawMakeFrame,
  getMakeCompositorStatus,
} from './makeCompositor.js';
import {
  MAKE_TIMELINE_EFFECTS,
  clipTimelineLabel,
  clipTimelineSignature,
  createClipFromLocalFile,
  describeTimelineEdits,
  getClipTimelineDurationMs,
  getClipTrimEndMs,
  getClipTrimStartMs,
  normalizeMakeClip,
  renderTimelineClipsForExport,
  seekVideoToTimelineStart,
  timelineEffectCssFilter,
  timelinePreviewTimeReachedEnd,
  updateClipTimeline,
} from './makeTimelineModel.js';
import './make.css';

const EMPTY_INPUT_STATE = Object.freeze({
  status: 'idle',
  cameraStream: null,
  screenStream: null,
  micStream: null,
  error: null,
  warning: null,
  startedAt: null,
});

const EMPTY_RECORDER_STATE = Object.freeze({
  status: 'idle',
  error: null,
  mimeType: '',
  startedAtMs: 0,
  activeName: '',
});

const MODE_ICONS = Object.freeze({
  camera: '●',
  screen: '▣',
  screen_pip: '◰',
  camera_background: '✂',
  audio_only: '≋',
});

const PREVIEW_TIMELINE_EFFECTS = Object.freeze([
  {
    value: 'none',
    label: 'Clean',
    copy: 'No extra timeline look.',
  },
  {
    value: 'pop',
    label: 'Pop',
    copy: 'Sharper contrast and color lift.',
  },
  {
    value: 'warm',
    label: 'Warm',
    copy: 'Warmer commentary look.',
  },
  {
    value: 'cool',
    label: 'Cool',
    copy: 'Clean tutorial tone.',
  },
  {
    value: 'mono',
    label: 'Mono',
    copy: 'High-contrast monochrome.',
  },
]);

export default function MakePage({ app }) {
  const canvasRef = useRef(null);
  const previewShellRef = useRef(null);
  const cameraVideoRef = useRef(null);
  const screenVideoRef = useRef(null);
  const backgroundVideoRef = useRef(null);
  const sequenceVideoRef = useRef(null);
  const sequenceAdvanceLockRef = useRef(false);
  const sequenceProgressTickRef = useRef(0);
  const replaceClipInputRef = useRef(null);
  const addClipInputRef = useRef(null);
  const backgroundVideoObjectUrlRef = useRef('');
  const backgroundImageObjectUrlRef = useRef('');
  const streamsRef = useRef(EMPTY_INPUT_STATE);
  const clipsRef = useRef([]);
  const recorderRef = useRef(null);
  const chunksRef = useRef([]);
  const recorderStreamRef = useRef(null);
  const countdownTimerRef = useRef(null);
  const countdownTokenRef = useRef(0);
  const subjectHudTimerRef = useRef(null);
  const subjectDragRef = useRef({
    active: false,
    pointerId: null,
    startX: 0,
    startY: 0,
    startOffsetX: 0,
    startOffsetY: 0,
  });

  const [draft, setDraft] = useState(() => readStoredMakeDraft());
  const [inputState, setInputState] = useState(EMPTY_INPUT_STATE);
  const [recorderState, setRecorderState] = useState(EMPTY_RECORDER_STATE);
  const [clips, setClips] = useState([]);
  const [selectedClipId, setSelectedClipId] = useState('');
  const [sequenceState, setSequenceState] = useState(() => createSequenceReviewState('idle'));
  const [deviceState, setDeviceState] = useState({
    status: 'idle',
    cameras: 0,
    microphones: 0,
    error: null,
  });
  const [showDeveloperPlan, setShowDeveloperPlan] = useState(false);
  const [clockTick, setClockTick] = useState(0);
  const [countdown, setCountdown] = useState(0);
  const [prompterRunning, setPrompterRunning] = useState(false);
  const [subjectHudVisible, setSubjectHudVisible] = useState(false);
  const [backgroundVideoUrl, setBackgroundVideoUrl] = useState('');
  const [backgroundImageUrl, setBackgroundImageUrl] = useState('');
  const [compositorState, setCompositorState] = useState(() => getMakeCompositorStatus());
  const [mediaDebug, setMediaDebug] = useState([]);
  const [makeExportState, setMakeExportState] = useState(() => createMakeExportUiState());
  const [previewDrawer, setPreviewDrawer] = useState('');
  const [subjectEditMode, setSubjectEditMode] = useState(false);
  const [previewTimelineActive, setPreviewTimelineActive] = useState(false);
  const timelineHistoryRef = useRef({ undo: [], redo: [] });
  const [timelineHistoryState, setTimelineHistoryState] = useState({ undoCount: 0, redoCount: 0 });

  useEffect(() => {
    if (previewDrawer) {
      setSubjectEditMode(false);
    }
  }, [previewDrawer]);

  const selectedMode = useMemo(() => findMakeMode(draft.selectedMode), [draft.selectedMode]);
  const outputPreset = useMemo(() => findOutputPreset(draft.outputPreset), [draft.outputPreset]);
  const makeExportClient = useMemo(() => createMakeExportClient(), []);
  const recorderMimeType = useMemo(() => selectRecorderMimeType(), []);
  const inputReady = inputState.status === 'ready';
  const isRecording = recorderState.status === 'recording';
  const isCountingDown = countdown > 0;
  const hasPrompterScript = Boolean(draft.scriptText.trim());
  const cutoutPreviewInteractive =
    draft.selectedMode === 'camera_background' ||
    draft.backgroundRemovalMode === 'person_cutout' ||
    draft.personCutoutEnabled === true ||
    (draft.selectedMode === 'screen_pip' && draft.pipCutoutEnabled === true);
  const canUseMedia = typeof navigator !== 'undefined' && Boolean(navigator.mediaDevices);
  const canRecord =
    inputReady &&
    !isRecording &&
    !isCountingDown &&
    typeof window.MediaRecorder === 'function' &&
    Boolean(canvasRef.current?.captureStream);
  const selectedClip = useMemo(
    () => clips.find((clip) => clip.id === selectedClipId) || clips[clips.length - 1] || null,
    [clips, selectedClipId],
  );

  const pushMediaDebug = useCallback((event, details = {}) => {
    const entry = {
      at: new Date().toISOString(),
      event,
      ...details,
    };

    console.info('[crablink:make:media]', entry);
    setMediaDebug((current) => [entry, ...current].slice(0, 16));
  }, []);
  const latestClip = clips[clips.length - 1] || null;
  const currentSequenceClip = clips[sequenceState.currentIndex] || clips[0] || null;
  const nextSequenceClip = clips[sequenceState.currentIndex + 1] || null;
  const sequenceApproved = sequenceState.status === 'approved';
  const makeExportBusy = makeExportState.status === 'exporting';
  const makeExportReady = Boolean(makeExportState.result?.source?.sourceHandle);
  const canExportSequence = sequenceApproved && clips.length > 0 && !isRecording && !makeExportBusy;
  const sequenceClipKey = useMemo(
    () => clips.map((clip) => clipTimelineSignature(clip)).join('|'),
    [clips],
  );
  const totalDurationMs = useMemo(
    () => clips.reduce((sum, clip) => sum + getClipTimelineDurationMs(clip), 0),
    [clips],
  );
  const recordingElapsedMs = useMemo(() => {
    if (!isRecording || !recorderState.startedAtMs) {
      return 0;
    }

    return Date.now() - recorderState.startedAtMs + clockTick * 0;
  }, [clockTick, isRecording, recorderState.startedAtMs]);

  const readiness = useMemo(
    () => deriveMakeReadiness({
      draft,
      clips,
      inputStatus: inputState.status,
      recorderStatus: recorderState.status,
    }),
    [clips, draft, inputState.status, recorderState.status],
  );

  const sessionPlan = useMemo(() => {
    const plan = buildMakeSessionPlan({
      draft,
      clips,
      inputStatus: inputState.status,
      recorderStatus: recorderState.status,
    });
    const timelineSummary = describeTimelineEdits(clips);

    return {
      ...plan,
      timeline: timelineSummary,
      clips: (plan.clips || []).map((clipPlan, index) => {
        const clip = clips[index] ? normalizeMakeClip(clips[index]) : null;

        return {
          ...clipPlan,
          timeline: clip
            ? {
                trimStartMs: clip.trimStartMs,
                trimEndMs: clip.trimEndMs,
                timelineDurationMs: getClipTimelineDurationMs(clip),
                effect: clip.timelineEffect,
                label: clipTimelineLabel(clip),
                localOnly: true,
              }
            : undefined,
        };
      }),
    };
  }, [clips, draft, inputState.status, recorderState.status]);

  const updateDraft = useCallback((patch) => {
    setDraft((current) =>
      createMakeDraft({
        ...current,
        ...patch,
      }),
    );
  }, []);

  const clearBackgroundVideoObjectUrl = useCallback(() => {
    if (backgroundVideoObjectUrlRef.current) {
      try {
        URL.revokeObjectURL(backgroundVideoObjectUrlRef.current);
      } catch (_error) {
        // Best-effort object URL cleanup.
      }
    }

    backgroundVideoObjectUrlRef.current = '';
    setBackgroundVideoUrl('');
  }, []);

  const clearBackgroundImageObjectUrl = useCallback(() => {
    if (backgroundImageObjectUrlRef.current) {
      try {
        URL.revokeObjectURL(backgroundImageObjectUrlRef.current);
      } catch (_error) {
        // Best-effort object URL cleanup.
      }
    }

    backgroundImageObjectUrlRef.current = '';
    setBackgroundImageUrl('');
  }, []);

  const chooseBackgroundImage = useCallback((file) => {
    if (!file) {
      return;
    }

    if (!file.type?.startsWith('image/')) {
      app?.notify?.({
        tone: 'warning',
        title: 'Choose an image',
        copy: 'Background image replacement expects a local image file.',
      });
      return;
    }

    clearBackgroundImageObjectUrl();
    clearBackgroundImageObjectUrl();
    clearBackgroundVideoObjectUrl();

    const objectUrl = URL.createObjectURL(file);
    backgroundImageObjectUrlRef.current = objectUrl;
    setBackgroundImageUrl(objectUrl);

    updateDraft({
      backgroundKind: 'image',
      backgroundImageDataUrl: '',
      backgroundImageName: file.name || 'local-background-image',
      backgroundVideoName: '',
    });
  }, [app, clearBackgroundImageObjectUrl, clearBackgroundVideoObjectUrl, updateDraft]);

  const chooseBackgroundVideo = useCallback((file) => {
    if (!file) {
      return;
    }

    if (!file.type?.startsWith('video/')) {
      app?.notify?.({
        tone: 'warning',
        title: 'Choose a video',
        copy: 'Background video replacement expects a local video file.',
      });
      return;
    }

    clearBackgroundVideoObjectUrl();

    const objectUrl = URL.createObjectURL(file);
    backgroundVideoObjectUrlRef.current = objectUrl;
    setBackgroundVideoUrl(objectUrl);
    updateDraft({
      backgroundKind: 'video',
      backgroundVideoName: file.name || 'local-background-video',
      backgroundImageDataUrl: '',
      backgroundImageName: '',
    });
  }, [app, clearBackgroundImageObjectUrl, clearBackgroundVideoObjectUrl, updateDraft]);

  const clearBackgroundMedia = useCallback(() => {
    clearBackgroundImageObjectUrl();
    clearBackgroundVideoObjectUrl();
    clearMakeCompositorState();
    updateDraft({
      backgroundKind: 'scene',
      backgroundImageDataUrl: '',
      backgroundImageName: '',
      backgroundVideoName: '',
    });
  }, [clearBackgroundImageObjectUrl, clearBackgroundVideoObjectUrl, updateDraft]);

  const clearSubjectHudTimer = useCallback(() => {
    if (subjectHudTimerRef.current) {
      window.clearTimeout(subjectHudTimerRef.current);
      subjectHudTimerRef.current = null;
    }
  }, []);

  const showSubjectHudBriefly = useCallback((durationMs = 1800) => {
    clearSubjectHudTimer();
    setSubjectHudVisible(true);

    subjectHudTimerRef.current = window.setTimeout(() => {
      setSubjectHudVisible(false);
      subjectHudTimerRef.current = null;
    }, durationMs);
  }, [clearSubjectHudTimer]);

  const updateSubjectTransform = useCallback((patchOrUpdater) => {
    setDraft((current) => {
      const patch =
        typeof patchOrUpdater === 'function'
          ? patchOrUpdater(current)
          : patchOrUpdater;

      return createMakeDraft({
        ...current,
        ...patch,
      });
    });
  }, []);

  const zoomSubject = useCallback((delta) => {
    showSubjectHudBriefly();

    updateSubjectTransform((current) => ({
      subjectScale: clamp(Number(current.subjectScale || 100) + delta, 60, 180, 100),
    }));
  }, [showSubjectHudBriefly, updateSubjectTransform]);

  const resetSubjectPreviewTransform = useCallback(() => {
    showSubjectHudBriefly();

    updateSubjectTransform({
      subjectScale: 100,
      subjectOffsetX: 0,
      subjectOffsetY: 0,
    });
  }, [showSubjectHudBriefly, updateSubjectTransform]);

  const beginSubjectDrag = useCallback((event) => {
    if (!subjectEditMode || previewDrawer || !cutoutPreviewInteractive || isRecording || event.button > 0) {
      return;
    }

    const rect = event.currentTarget.getBoundingClientRect();

    if (!rect.width || !rect.height) {
      return;
    }

    showSubjectHudBriefly(2400);

    subjectDragRef.current = {
      active: true,
      pointerId: event.pointerId,
      startX: event.clientX,
      startY: event.clientY,
      startOffsetX: Number(draft.subjectOffsetX || 0),
      startOffsetY: Number(draft.subjectOffsetY || 0),
      rectWidth: rect.width,
      rectHeight: rect.height,
    };

    try {
      event.currentTarget.setPointerCapture(event.pointerId);
    } catch (_error) {
      // Pointer capture is best effort.
    }

    event.preventDefault();
  }, [
    cutoutPreviewInteractive,
    draft.subjectOffsetX,
    draft.subjectOffsetY,
    isRecording,
    previewDrawer,
    showSubjectHudBriefly,
    subjectEditMode,
  ]);

  const moveSubjectDrag = useCallback((event) => {
    const drag = subjectDragRef.current;

    if (!drag.active || drag.pointerId !== event.pointerId) {
      return;
    }

    showSubjectHudBriefly(2400);

    const deltaX = event.clientX - drag.startX;
    const deltaY = event.clientY - drag.startY;

    /*
     * Preview drag is intentionally faster than 1:1 so creators can position
     * the cutout quickly on a trackpad. X direction must compensate for mirrored
     * camera drawing so the subject follows the cursor visually.
     */
    const dragSpeed = 2.45;
    const xDirection = draft.subjectMirror !== false ? -1 : 1;
    const yDirection = 1;
    const xUnits = (deltaX / Math.max(1, drag.rectWidth)) * (100 / 0.34) * dragSpeed * xDirection;
    const yUnits = (deltaY / Math.max(1, drag.rectHeight)) * (100 / 0.34) * dragSpeed * yDirection;

    updateSubjectTransform({
      subjectOffsetX: clamp(drag.startOffsetX + xUnits, -100, 100, 0),
      subjectOffsetY: clamp(drag.startOffsetY + yUnits, -100, 100, 0),
    });

    event.preventDefault();
  }, [draft.subjectMirror, showSubjectHudBriefly, updateSubjectTransform]);

  const endSubjectDrag = useCallback((event) => {
    const drag = subjectDragRef.current;

    if (drag.pointerId === event.pointerId) {
      subjectDragRef.current = {
        active: false,
        pointerId: null,
        startX: 0,
        startY: 0,
        startOffsetX: 0,
        startOffsetY: 0,
      };

      try {
        event.currentTarget.releasePointerCapture(event.pointerId);
      } catch (_error) {
        // Pointer capture release is best effort.
      }

      showSubjectHudBriefly();
    }
  }, [showSubjectHudBriefly]);

  const togglePrompterRun = useCallback(() => {
    if (!draft.teleprompterEnabled || !draft.scriptText.trim()) {
      setPrompterRunning(false);
      return;
    }

    setPrompterRunning((value) => !value);
  }, [draft.scriptText, draft.teleprompterEnabled]);

  const applyPreset = useCallback((presetValue) => {
    if (inputReady || isRecording || isCountingDown) {
      app?.notify?.({
        tone: 'info',
        title: 'Stop preview first',
        copy: 'Presets restart the capture recipe. Stop preview before changing the studio template.',
      });
      return;
    }

    setDraft((current) => applyMakePreset(current, presetValue));
  }, [app, inputReady, isCountingDown, isRecording]);

  const refreshDevices = useCallback(async () => {
    if (!navigator.mediaDevices?.enumerateDevices) {
      setDeviceState({
        status: 'unsupported',
        cameras: 0,
        microphones: 0,
        error: 'Device enumeration is unavailable in this WebView.',
      });
      return;
    }

    setDeviceState((current) => ({ ...current, status: 'loading', error: null }));

    try {
      const devices = await navigator.mediaDevices.enumerateDevices();

      setDeviceState({
        status: 'ready',
        cameras: devices.filter((device) => device.kind === 'videoinput').length,
        microphones: devices.filter((device) => device.kind === 'audioinput').length,
        error: null,
      });
    } catch (error) {
      setDeviceState({
        status: 'error',
        cameras: 0,
        microphones: 0,
        error: errorMessage(error),
      });
    }
  }, []);

  const cancelCountdown = useCallback(() => {
    countdownTokenRef.current += 1;

    if (countdownTimerRef.current) {
      window.clearTimeout(countdownTimerRef.current);
      countdownTimerRef.current = null;
    }

    setCountdown(0);
  }, []);

  const stopInputs = useCallback(() => {
    cancelCountdown();
    stopAllStreams(streamsRef.current);
    setInputState(EMPTY_INPUT_STATE);
  }, [cancelCountdown]);

  const startInputs = useCallback(async () => {
    stopAllStreams(streamsRef.current);

    const mode = selectedMode || findMakeMode(draft.selectedMode);
    const warnings = [];

    pushMediaDebug('start_inputs', {
      selectedMode: draft.selectedMode,
      needsCamera: mode.needsCamera,
      needsScreen: mode.needsScreen,
      includeMic: draft.includeMic,
      mediaDevices: Boolean(navigator.mediaDevices),
      getUserMedia: typeof navigator.mediaDevices?.getUserMedia === 'function',
      getDisplayMedia: typeof navigator.mediaDevices?.getDisplayMedia === 'function',
    });

    if (!canUseMedia) {
      const nextState = {
        ...EMPTY_INPUT_STATE,
        status: 'error',
        error: 'This WebView does not expose navigator.mediaDevices.',
      };

      streamsRef.current = nextState;
      setInputState(nextState);
      pushMediaDebug('media_devices_missing');
      return null;
    }

    setInputState({ ...EMPTY_INPUT_STATE, status: 'starting' });

    let cameraStream = null;
    let screenStream = null;
    let micStream = null;

    try {
      if (mode.needsScreen) {
        if (typeof navigator.mediaDevices.getDisplayMedia !== 'function') {
          throw new Error('Screen capture is unavailable in this WebView.');
        }

        pushMediaDebug('request_screen_start');

        screenStream = await navigator.mediaDevices.getDisplayMedia({
          video: {
            width: { ideal: outputPreset.width },
            height: { ideal: outputPreset.height },
            frameRate: { ideal: draft.targetFps },
          },
          audio: false,
        });

        pushMediaDebug('request_screen_ok', makeStreamFacts(screenStream));

        const screenTrack = screenStream.getVideoTracks()[0];

        if (screenTrack) {
          screenTrack.onended = () => {
            pushMediaDebug('screen_track_ended', makeTrackFacts(screenTrack));
            stopAllStreams(streamsRef.current);

            const nextState = {
              ...EMPTY_INPUT_STATE,
              status: 'idle',
              warning: 'Screen sharing ended from the system picker. Start preview again before recording.',
            };

            streamsRef.current = nextState;
            setInputState(nextState);
          };
        }
      }

      if (mode.needsCamera) {
        if (typeof navigator.mediaDevices.getUserMedia !== 'function') {
          const error = new Error('Camera capture is unavailable in this WebView.');

          if (mode.needsScreen) {
            warnings.push(error.message);
            pushMediaDebug('request_camera_unavailable_nonfatal', makeMediaErrorDetails(error));
          } else {
            throw error;
          }
        } else {
          try {
            pushMediaDebug('request_camera_start');

            cameraStream = await requestMakeCameraWithFallback({
              width: outputPreset.width,
              height: outputPreset.height,
              frameRate: draft.targetFps,
              pushMediaDebug,
            });

            pushMediaDebug('request_camera_ok', makeStreamFacts(cameraStream));

            for (const track of cameraStream.getVideoTracks()) {
              track.onended = () => {
                pushMediaDebug('camera_track_ended', makeTrackFacts(track));
              };
              track.onmute = () => {
                pushMediaDebug('camera_track_muted', makeTrackFacts(track));
              };
              track.onunmute = () => {
                pushMediaDebug('camera_track_unmuted', makeTrackFacts(track));
              };
            }
          } catch (error) {
            const details = makeMediaErrorDetails(error);

            if (mode.needsScreen) {
              warnings.push(`Camera PiP unavailable: ${details.summary}`);
              pushMediaDebug('request_camera_error_nonfatal_for_screen_pip', details);
              cameraStream = null;
            } else {
              pushMediaDebug('request_camera_error_fatal', details);
              throw error;
            }
          }
        }
      }

      if (draft.includeMic) {
        try {
          pushMediaDebug('request_mic_start');

          micStream = await navigator.mediaDevices.getUserMedia({
            video: false,
            audio: {
              echoCancellation: draft.echoCancellation,
              noiseSuppression: draft.noiseSuppression,
              autoGainControl: draft.autoGainControl,
            },
          });

          pushMediaDebug('request_mic_ok', makeStreamFacts(micStream));
        } catch (error) {
          const details = makeMediaErrorDetails(error);
          warnings.push(`Microphone unavailable: ${details.summary}`);
          pushMediaDebug('request_mic_error_nonfatal', details);
          micStream = null;
        }
      }

      if (mode.needsScreen && !screenStream) {
        throw new Error('Screen capture did not return a usable stream.');
      }

      if (!mode.needsScreen && mode.needsCamera && !cameraStream) {
        throw new Error('Camera capture did not return a usable stream.');
      }

      const nextState = {
        status: 'ready',
        cameraStream,
        screenStream,
        micStream,
        error: null,
        warning: warnings.join(' '),
        startedAt: new Date().toISOString(),
      };

      streamsRef.current = nextState;
      setInputState(nextState);
      refreshDevices();

      pushMediaDebug('inputs_ready', {
        camera: makeStreamFacts(cameraStream),
        screen: makeStreamFacts(screenStream),
        mic: makeStreamFacts(micStream),
        warning: nextState.warning,
      });

      return nextState;
    } catch (error) {
      const details = makeMediaErrorDetails(error);
      pushMediaDebug('start_inputs_error', details);
      stopAllStreams({ cameraStream, screenStream, micStream });

      const nextState = {
        ...EMPTY_INPUT_STATE,
        status: 'error',
        error: details.summary,
      };

      streamsRef.current = nextState;
      setInputState(nextState);
      return null;
    }
  }, [canUseMedia, draft, outputPreset, pushMediaDebug, refreshDevices, selectedMode]);

  const startRecordingNow = useCallback(() => {
    if (!canvasRef.current || !inputReady || isRecording) {
      return;
    }

    if (typeof window.MediaRecorder !== 'function') {
      setRecorderState({
        ...EMPTY_RECORDER_STATE,
        status: 'error',
        error: 'MediaRecorder is unavailable in this WebView.',
      });
      return;
    }

    if (typeof canvasRef.current.captureStream !== 'function') {
      setRecorderState({
        ...EMPTY_RECORDER_STATE,
        status: 'error',
        error: 'Canvas captureStream is unavailable in this WebView.',
      });
      return;
    }

    try {
      const fps = clamp(Number(draft.targetFps), 12, 60, 30);
      const canvasStream = canvasRef.current.captureStream(fps);
      const audioTracks = audioTracksFrom(inputState.micStream);

      for (const track of audioTracks) {
        canvasStream.addTrack(track);
      }

      const mimeType = recorderMimeType || undefined;
      const options = mimeType ? { mimeType } : undefined;
      const recorder = new window.MediaRecorder(canvasStream, options);
      const startedAtMs = Date.now();
      const clipName = buildClipName({ draft, index: clips.length + 1, mimeType });

      chunksRef.current = [];
      recorderStreamRef.current = canvasStream;
      recorderRef.current = recorder;

      recorder.ondataavailable = (event) => {
        if (event.data?.size > 0) {
          chunksRef.current.push(event.data);
        }
      };

      recorder.onerror = (event) => {
        setRecorderState((current) => ({
          ...current,
          status: 'error',
          error: errorMessage(event?.error || event),
        }));
      };

      recorder.onstop = () => {
        const chunks = chunksRef.current;
        const fallbackType = chunks[0]?.type || mimeType || 'video/webm';
        const blob = new Blob(chunks, { type: fallbackType });
        const objectUrl = URL.createObjectURL(blob);
        const durationMs = Date.now() - startedAtMs;
        const createdAt = new Date().toISOString();
        const id = createId('make-clip');

        stopRecorderStream(recorderStreamRef.current);
        recorderStreamRef.current = null;
        recorderRef.current = null;
        chunksRef.current = [];

        setClips((current) => [
          ...current,
          normalizeMakeClip({
            id,
            name: clipName,
            blob,
            mimeType: blob.type || fallbackType,
            type: blob.type || fallbackType,
            sizeBytes: blob.size,
            durationMs,
            createdAt,
            objectUrl,
            localOnly: true,
            sourceMode: draft.selectedMode,
          }),
        ]);
        setSelectedClipId(id);

        setRecorderState({
          status: 'idle',
          error: null,
          mimeType: blob.type || fallbackType,
          startedAtMs: 0,
          activeName: '',
        });
      };

      recorder.start(1000);
      setRecorderState({
        status: 'recording',
        error: null,
        mimeType: mimeType || 'browser-default',
        startedAtMs,
        activeName: clipName,
      });
    } catch (error) {
      stopRecorderStream(recorderStreamRef.current);
      recorderStreamRef.current = null;
      recorderRef.current = null;
      chunksRef.current = [];
      setRecorderState({
        ...EMPTY_RECORDER_STATE,
        status: 'error',
        error: errorMessage(error),
      });
    }
  }, [
    clips.length,
    draft,
    inputReady,
    inputState.micStream,
    isRecording,
    recorderMimeType,
  ]);

  const beginRecordingCountdown = useCallback(() => {
    if (!inputReady || isRecording || isCountingDown || !canvasRef.current) {
      return;
    }

    const token = countdownTokenRef.current + 1;
    countdownTokenRef.current = token;
    setCountdown(3);

    const tick = (value) => {
      countdownTimerRef.current = window.setTimeout(() => {
        if (countdownTokenRef.current !== token) {
          return;
        }

        if (value <= 1) {
          countdownTimerRef.current = null;
          setCountdown(0);
          startRecordingNow();
          return;
        }

        setCountdown(value - 1);
        tick(value - 1);
      }, 900);
    };

    tick(3);
  }, [inputReady, isCountingDown, isRecording, startRecordingNow]);

  const stopRecording = useCallback(() => {
    const recorder = recorderRef.current;

    if (recorder && recorder.state !== 'inactive') {
      recorder.stop();
    }
  }, []);

  const removeClip = useCallback((clipId) => {
    setClips((current) => {
      const clip = current.find((item) => item.id === clipId);
      revokeClipUrls(clip ? [clip] : []);

      if (clipId === selectedClipId) {
        setSelectedClipId('');
      }

      return current.filter((item) => item.id !== clipId);
    });
  }, [selectedClipId]);

  const retakeLastClip = useCallback(() => {
    setClips((current) => {
      const next = [...current];
      const clip = next.pop();

      if (clip) {
        revokeClipUrls([clip]);
      }

      setSelectedClipId(next[next.length - 1]?.id || '');
      return next;
    });
  }, []);

  const clearClips = useCallback(() => {
    revokeClipUrls(clips);
    timelineHistoryRef.current = { undo: [], redo: [] };
    setTimelineHistoryState({ undoCount: 0, redoCount: 0 });
    setClips([]);
    setSelectedClipId('');
    setSequenceState(createSequenceReviewState('idle'));
  }, [clips]);

  const refreshTimelineHistoryState = useCallback(() => {
    const history = timelineHistoryRef.current;
    setTimelineHistoryState({
      undoCount: history.undo.length,
      redoCount: history.redo.length,
    });
  }, []);

  const captureTimelineHistory = useCallback(() => {
    const snapshot = snapshotTimelineClips(clipsRef.current);

    if (!snapshot.length) {
      return;
    }

    const history = timelineHistoryRef.current;
    history.undo = [...history.undo, snapshot].slice(-40);
    history.redo = [];
    refreshTimelineHistoryState();
  }, [refreshTimelineHistoryState]);

  const commitTimelineClips = useCallback((updater, options = {}) => {
    const before = snapshotTimelineClips(clipsRef.current);
    const nextRaw = typeof updater === 'function' ? updater(before) : updater;
    const next = snapshotTimelineClips(nextRaw);

    if (makeTimelineClipArraySignature(before) === makeTimelineClipArraySignature(next)) {
      return false;
    }

    const history = timelineHistoryRef.current;
    history.undo = [...history.undo, before].slice(-40);
    history.redo = [];
    refreshTimelineHistoryState();

    setClips(next);

    if (options.selectClipId !== undefined) {
      setSelectedClipId(options.selectClipId || next[next.length - 1]?.id || '');
    }

    return true;
  }, [refreshTimelineHistoryState]);

  const undoTimeline = useCallback(() => {
    const history = timelineHistoryRef.current;
    const previous = history.undo.pop();

    if (!previous) {
      refreshTimelineHistoryState();
      return;
    }

    history.redo = [...history.redo, snapshotTimelineClips(clipsRef.current)].slice(-40);
    refreshTimelineHistoryState();

    const safePrevious = snapshotTimelineClips(previous);
    setClips(safePrevious);
    setSelectedClipId((current) => (
      safePrevious.some((clip) => clip.id === current) ? current : safePrevious[safePrevious.length - 1]?.id || ''
    ));
  }, [refreshTimelineHistoryState]);

  const redoTimeline = useCallback(() => {
    const history = timelineHistoryRef.current;
    const next = history.redo.pop();

    if (!next) {
      refreshTimelineHistoryState();
      return;
    }

    history.undo = [...history.undo, snapshotTimelineClips(clipsRef.current)].slice(-40);
    refreshTimelineHistoryState();

    const safeNext = snapshotTimelineClips(next);
    setClips(safeNext);
    setSelectedClipId((current) => (
      safeNext.some((clip) => clip.id === current) ? current : safeNext[safeNext.length - 1]?.id || ''
    ));
  }, [refreshTimelineHistoryState]);

  const splitTimelineAt = useCallback((selection) => {
    const clipId = selection?.clipId || '';
    const clip = clipsRef.current.find((item) => item.id === clipId);

    if (!clip) {
      return;
    }

    const trimStartMs = getClipTrimStartMs(clip);
    const trimEndMs = getClipTrimEndMs(clip);
    const splitMs = clamp(
      snapTimelineFrameMs(Number(selection?.atMs ?? selection?.focusMs ?? trimStartMs)),
      trimStartMs,
      trimEndMs,
      trimStartMs,
    );
    const minClipMs = 350;

    if (splitMs - trimStartMs < minClipMs || trimEndMs - splitMs < minClipMs) {
      app?.notify?.({
        tone: 'warning',
        title: 'Split needs more room',
        message: 'Choose a point with at least a small usable segment on both sides.',
      });
      return;
    }

    const rightClipId = makeTimelineSegmentId(clip.id, 'split');
    const changed = commitTimelineClips((current) => current.flatMap((item) => {
      if (item.id !== clip.id) {
        return [item];
      }

      const left = updateClipTimeline(item, { trimEndMs: splitMs });
      const right = cloneTimelineSegmentClip(item, {
        id: rightClipId,
        trimStartMs: splitMs,
        trimEndMs,
        segmentLabel: 'split',
      });

      return [left, right];
    }), { selectClipId: rightClipId });

    if (changed) {
      app?.notify?.({
        tone: 'success',
        title: 'Clip split',
        message: 'The selected local clip was split into two timeline segments.',
      });
    }
  }, [app, commitTimelineClips]);

  const deleteTimelineRange = useCallback((selection) => {
    const clipId = selection?.clipId || '';
    const clip = clipsRef.current.find((item) => item.id === clipId);

    if (!clip) {
      return;
    }

    const clipStartMs = getClipTrimStartMs(clip);
    const clipEndMs = getClipTrimEndMs(clip);
    const rawStartMs = snapTimelineFrameMs(Number(selection?.startMs ?? clipStartMs));
    const rawEndMs = snapTimelineFrameMs(Number(selection?.endMs ?? rawStartMs));
    const startMs = clamp(Math.min(rawStartMs, rawEndMs), clipStartMs, clipEndMs, clipStartMs);
    const endMs = clamp(Math.max(rawStartMs, rawEndMs), clipStartMs, clipEndMs, clipEndMs);
    const minClipMs = 350;

    if (endMs - startMs < 80) {
      app?.notify?.({
        tone: 'warning',
        title: 'Select more timeline',
        message: 'Drag across the clip to highlight a range before deleting.',
      });
      return;
    }

    const keepLeft = startMs - clipStartMs >= minClipMs;
    const keepRight = clipEndMs - endMs >= minClipMs;
    const currentIndex = clipsRef.current.findIndex((item) => item.id === clip.id);
    const fallbackClip = clipsRef.current[currentIndex + 1] || clipsRef.current[currentIndex - 1] || null;
    const rightClipId = makeTimelineSegmentId(clip.id, 'kept');
    const nextSelectedClipId = keepLeft && keepRight
      ? rightClipId
      : keepLeft || keepRight
        ? clip.id
        : fallbackClip?.id || '';

    const changed = commitTimelineClips((current) => current.flatMap((item) => {
      if (item.id !== clip.id) {
        return [item];
      }

      if (keepLeft && keepRight) {
        return [
          updateClipTimeline(item, { trimEndMs: startMs }),
          cloneTimelineSegmentClip(item, {
            id: rightClipId,
            trimStartMs: endMs,
            trimEndMs: clipEndMs,
            segmentLabel: 'kept',
          }),
        ];
      }

      if (keepLeft) {
        return [updateClipTimeline(item, { trimEndMs: startMs })];
      }

      if (keepRight) {
        return [updateClipTimeline(item, { trimStartMs: endMs, trimEndMs: clipEndMs })];
      }

      return [];
    }), { selectClipId: nextSelectedClipId });

    if (changed) {
      app?.notify?.({
        tone: 'success',
        title: 'Timeline range deleted',
        message: 'The highlighted local timeline range was removed.',
      });
    }
  }, [app, commitTimelineClips]);

  const updateSelectedClipTimeline = useCallback((patch) => {
    if (!selectedClip) {
      return;
    }

    commitTimelineClips((current) => current.map((clip) => (
      clip.id === selectedClip.id ? updateClipTimeline(clip, patch) : clip
    )), { selectClipId: selectedClip.id });
  }, [commitTimelineClips, selectedClip]);

  const updateClipTimelineById = useCallback((clipId, patch) => {
    if (!clipId) {
      return;
    }

    setClips((current) => current.map((clip) => (clip.id === clipId ? updateClipTimeline(clip, patch) : clip)));
  }, []);

  const moveSelectedClip = useCallback((direction) => {
    if (!selectedClip) {
      return;
    }

    commitTimelineClips((current) => {
      const index = current.findIndex((clip) => clip.id === selectedClip.id);
      const nextIndex = index + direction;

      if (index < 0 || nextIndex < 0 || nextIndex >= current.length) {
        return current;
      }

      const next = [...current];
      const [clip] = next.splice(index, 1);
      next.splice(nextIndex, 0, clip);
      return next;
    }, { selectClipId: selectedClip.id });
  }, [commitTimelineClips, selectedClip]);

  const requestAddTimelineClip = useCallback(() => {
    if (isRecording) {
      return;
    }

    addClipInputRef.current?.click?.();
  }, [isRecording]);

  const addTimelineClipsFromFiles = useCallback(async (event) => {
    const files = Array.from(event.target.files || []).filter(Boolean);
    event.target.value = '';

    if (!files.length || isRecording) {
      return;
    }

    const importedClips = [];

    try {
      const baseIndex = clipsRef.current.length;

      for (const [index, file] of files.entries()) {
        const clip = await createClipFromLocalFile(file, {
          id: createId('make-clip'),
          fallbackName: buildClipName({
            draft,
            index: baseIndex + index + 1,
            mimeType: file.type || 'video/webm',
          }),
        });

        importedClips.push(normalizeMakeClip({
          ...clip,
          sourceMode: 'timeline_import',
          importedAt: new Date().toISOString(),
        }));
      }

      if (!importedClips.length) {
        return;
      }

      commitTimelineClips((current) => [
        ...current,
        ...importedClips,
      ], { selectClipId: importedClips[0].id });

      setSelectedClipId(importedClips[0].id);
      setSequenceState(createSequenceReviewState('idle'));

      app?.notify?.({
        tone: 'success',
        title: importedClips.length === 1 ? 'Video added' : 'Videos added',
        message: importedClips.length === 1
          ? 'The selected local video was added to the Make timeline.'
          : `${importedClips.length} local videos were added to the Make timeline.`,
      });
    } catch (error) {
      revokeClipUrls(importedClips);

      app?.notify?.({
        tone: 'danger',
        title: 'Could not add video',
        message: errorMessage(error),
      });
    }
  }, [app, commitTimelineClips, draft, isRecording]);

  const requestReplaceSelectedClip = useCallback(() => {
    if (!selectedClip || isRecording) {
      return;
    }

    replaceClipInputRef.current?.click?.();
  }, [isRecording, selectedClip]);

  const replaceSelectedClipFromFile = useCallback(async (event) => {
    const file = event.target.files?.[0] || null;
    event.target.value = '';

    if (!file || !selectedClip) {
      return;
    }

    try {
      const replacement = await createClipFromLocalFile(file, {
        id: selectedClip.id,
        fallbackName: selectedClip.name || 'replacement-clip',
      });

      setClips((current) => current.map((clip) => {
        if (clip.id !== selectedClip.id) {
          return clip;
        }

        revokeClipUrls([clip]);
        return normalizeMakeClip({
          ...replacement,
          timelineEffect: selectedClip.timelineEffect || 'none',
          sourceClipId: selectedClip.sourceClipId || selectedClip.id,
        });
      }));
      setSelectedClipId(selectedClip.id);
      app?.notify?.({
        tone: 'success',
        title: 'Clip replaced',
        message: 'The timeline slot now points to the new local video blob.',
      });
    } catch (error) {
      app?.notify?.({
        tone: 'danger',
        title: 'Could not replace clip',
        message: errorMessage(error),
      });
    }
  }, [app, selectedClip]);

  const playSequence = useCallback(() => {
    if (!clips.length || isRecording) {
      return;
    }

    setSequenceState(createSequenceReviewState('playing', {
      currentIndex: 0,
      currentClipId: clips[0]?.id || '',
    }));
  }, [clips, isRecording]);

  const pauseSequence = useCallback(() => {
    const video = sequenceVideoRef.current;

    if (video) {
      video.pause();
    }

    setSequenceState((current) => ({
      ...current,
      status: current.status === 'approved' ? 'approved' : 'paused',
      error: null,
    }));
  }, []);

  const restartSequence = useCallback(() => {
    if (!clips.length || isRecording) {
      return;
    }

    setSequenceState(createSequenceReviewState('playing', {
      currentIndex: 0,
      currentClipId: clips[0]?.id || '',
    }));
  }, [clips, isRecording]);

  const handleSequenceClipEnded = useCallback((endedClip = null) => {
    const endedClipId = String(endedClip?.id || '').trim();

    if (sequenceAdvanceLockRef.current) {
      return;
    }

    sequenceAdvanceLockRef.current = true;

    setSequenceState((current) => {
      const currentClip = clips[current.currentIndex] || null;

      if (endedClipId && currentClip?.id && currentClip.id !== endedClipId) {
        return current;
      }

      const nextIndex = current.currentIndex + 1;

      if (nextIndex >= clips.length) {
        return {
          ...current,
          status: 'reviewed',
          currentIndex: Math.max(0, clips.length - 1),
          currentClipId: currentClip?.id || endedClipId || '',
          currentClipProgressPct: 100,
          totalProgressPct: 100,
          reviewedAt: new Date().toISOString(),
          error: null,
        };
      }

      const nextClip = clips[nextIndex] || null;
      const previousProgress = calculateSequenceTimelineProgress(clips, nextIndex, nextClip, null);

      return {
        ...current,
        status: 'playing',
        currentIndex: nextIndex,
        currentClipId: nextClip?.id || '',
        currentClipProgressPct: 0,
        totalProgressPct: previousProgress.totalProgressPct,
        currentClipElapsedMs: 0,
        totalElapsedMs: previousProgress.totalElapsedMs,
        error: null,
      };
    });

    window.setTimeout(() => {
      sequenceAdvanceLockRef.current = false;
    }, 120);
  }, [clips]);

  const handleSequenceClipTimeUpdate = useCallback((event, eventClip = null) => {
    const clip = eventClip || clips[sequenceState.currentIndex] || null;
    const video = event?.currentTarget || sequenceVideoRef.current;

    if (sequenceState.status !== 'playing' || !clip || !video) {
      return;
    }

    if (video !== sequenceVideoRef.current) {
      return;
    }

    const expectedUrl = String(clip.objectUrl || '');
    const actualUrl = String(video.currentSrc || video.src || '');

    if (expectedUrl && actualUrl && actualUrl !== expectedUrl) {
      return;
    }

    const trimStartSeconds = getClipTrimStartMs(clip) / 1000;

    if (Number.isFinite(video.currentTime) && video.currentTime + 0.05 < trimStartSeconds) {
      return;
    }

    const clipIndex = clips.findIndex((item) => item?.id === clip.id);
    const safeClipIndex = clipIndex >= 0 ? clipIndex : sequenceState.currentIndex;
    const reachedEnd = timelinePreviewTimeReachedEnd(video, clip);
    const progress = calculateSequenceTimelineProgress(clips, safeClipIndex, clip, video);

    const now = Date.now();
    if (reachedEnd || now - sequenceProgressTickRef.current > 80) {
      sequenceProgressTickRef.current = now;
      setSequenceState((current) => {
        if (current.status !== 'playing' || current.currentIndex !== safeClipIndex) {
          return current;
        }

        return {
          ...current,
          currentClipId: clip.id || '',
          currentClipProgressPct: reachedEnd ? 100 : progress.currentClipProgressPct,
          totalProgressPct: reachedEnd ? progress.totalProgressAtClipEndPct : progress.totalProgressPct,
          currentClipElapsedMs: reachedEnd ? progress.currentClipDurationMs : progress.currentClipElapsedMs,
          totalElapsedMs: reachedEnd ? progress.totalElapsedAtClipEndMs : progress.totalElapsedMs,
          error: null,
        };
      });
    }

    if (reachedEnd) {
      try {
        video.pause();
      } catch (_error) {
        // Ignore local preview pause failures.
      }
      handleSequenceClipEnded(clip);
    }
  }, [clips, handleSequenceClipEnded, sequenceState.currentIndex, sequenceState.status]);

  const handleSequenceClipReady = useCallback((event, eventClip = null) => {
    const clip = eventClip || clips[sequenceState.currentIndex] || null;
    const video = event?.currentTarget || sequenceVideoRef.current;

    if (sequenceState.status !== 'playing' || !clip || !video) {
      return;
    }

    if (video !== sequenceVideoRef.current) {
      return;
    }

    const expectedClip = clips[sequenceState.currentIndex] || null;
    if (expectedClip?.id && clip.id && expectedClip.id !== clip.id) {
      return;
    }

    requestSequenceVideoPlay(video, setSequenceState, clip);
  }, [clips, sequenceState.currentIndex, sequenceState.status]);

  const approveSequence = useCallback(() => {
    if (!clips.length || sequenceState.status !== 'reviewed') {
      return;
    }

    setSequenceState((current) => ({
      ...current,
      status: 'approved',
      approvedAt: new Date().toISOString(),
      approvedClipIds: clips.map((clip) => clip.id),
      error: null,
    }));
  }, [clips, sequenceState.status]);

  const exportApprovedSequence = useCallback(async () => {
    if (!sequenceApproved) {
      app?.notify?.({
        tone: 'info',
        title: 'Approve the sequence first',
        message: 'Play the full clip sequence and approve it before exporting one MP4.',
      });
      return;
