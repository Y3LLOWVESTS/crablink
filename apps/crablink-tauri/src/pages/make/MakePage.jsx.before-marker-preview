  const resetDraft = useCallback(() => {
    clearStoredMakeDraft();
    setDraft(createMakeDraft());
  }, []);

  useEffect(() => {
    writeStoredMakeDraft(draft);
  }, [draft]);

  useEffect(() => {
    setSequenceState(createSequenceReviewState(clips.length ? 'draft' : 'idle'));
