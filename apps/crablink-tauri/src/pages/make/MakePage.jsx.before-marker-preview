    if (!clips.length) {
      return;
    }

    if (!makeExportClient.available) {
      app?.notify?.({
        tone: 'warning',
        title: 'Tauri export is unavailable',
        message: 'MP4 export requires the CrabLink Tauri runtime.',
      });
      return;
    }

    setMakeExportState(createMakeExportUiState('exporting', {
      progressPercent: 1,
      detail: 'Preparing export session.',
    }));

    try {
      const updateExportProgress = (event) => {
        setMakeExportState((current) => ({
          ...current,
          status: 'exporting',
          progressPercent: event.progressPercent || current.progressPercent || 1,
          detail: event.detail || current.detail,
          session: event.session || current.session,
          error: null,
        }));
      };

      const exportClips = await renderTimelineClipsForExport({
        clips,
        width: outputPreset.width,
        height: outputPreset.height,
        fps: draft.targetFps,
        mimeType: recorderMimeType,
        onProgress: updateExportProgress,
      });

      const result = await makeExportClient.exportApprovedClips({
        clips: exportClips,
        title: draft.title || 'CrabLink Make export',
        targetFileName: `${draft.title || 'crablink-make-export'}.mp4`,
        width: outputPreset.width,
        height: outputPreset.height,
        fps: draft.targetFps,
        onProgress: updateExportProgress,
      });

      const handoff = writeLatestMakeExportHandoff(result);

      setMakeExportState(createMakeExportUiState('ready', {
        progressPercent: 100,
        detail: 'MP4 is ready for the Video page.',
        result,
        handoff,
      }));

      app?.notify?.({
        tone: 'success',
        title: 'MP4 export ready',
        message: 'The approved sequence was exported and registered as a local video source.',
      });
    } catch (error) {
      setMakeExportState(createMakeExportUiState('error', {
        error: errorMessage(error),
        detail: 'MP4 export failed.',
      }));

      app?.notify?.({
        tone: 'danger',
        title: 'MP4 export failed',
        message: errorMessage(error),
        ttlMs: 9000,
      });
    }
  }, [app, clips, draft, makeExportClient, outputPreset, recorderMimeType, sequenceApproved]);

  const copyPlan = useCallback(async () => {
    const plan = writeLatestMakeSessionPlan({
      ...sessionPlan,
      sequenceReview: {
        status: sequenceState.status,
        reviewedAt: sequenceState.reviewedAt || '',
        approvedAt: sequenceState.approvedAt || '',
        approvedClipIds: sequenceState.approvedClipIds || [],
      },
