    try {
      await navigator.clipboard.writeText(JSON.stringify(plan, null, 2));
      app?.notify?.({
        tone: 'success',
        title: 'Make plan copied',
        copy: 'Session plan copied to clipboard.',
      });
    } catch (_error) {
      app?.notify?.({
        tone: 'info',
        title: 'Make plan stored',
        copy: 'Session plan was stored in sessionStorage.',
      });
    }
  }, [app, sequenceState, sessionPlan]);

  const openVideoPage = useCallback(() => {
    if (!makeExportReady) {
      app?.notify?.({
        tone: 'info',
        title: 'Export MP4 first',
        message: 'Export the approved sequence so Video can load the fresh local source handle.',
