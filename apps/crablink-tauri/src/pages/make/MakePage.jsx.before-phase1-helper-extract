  if (typeof URL !== 'undefined' && typeof Blob !== 'undefined' && clip?.blob instanceof Blob) {
    objectUrl = URL.createObjectURL(clip.blob);
  }

  const baseName = clip?.name || 'clip';

  return updateClipTimeline({
    ...clip,
