  });
}

function getAudioTrackLayoutDurationMs(track = {}) {
  const durationMs = Math.max(0, Number(track.durationMs || 0));
  const trimStartMs = Math.max(0, Number(track.trimStartMs || 0));
  const trimEndMs = Math.max(
    trimStartMs,
    Number(track.trimEndMs || durationMs || trimStartMs + 1000),
  );

  return Math.max(
    100,
    Number(track.effectiveDurationMs || 0) ||
      (trimEndMs - trimStartMs) ||
      durationMs ||
      1000,
  );
}

function getAudioTrackInterval(track = {}, overrideOffsetMs = null) {
  const startMs = Math.max(
    0,
    Number(overrideOffsetMs == null ? track.offsetMs || 0 : overrideOffsetMs),
  );
  const durationMs = getAudioTrackLayoutDurationMs(track);

  return {
    startMs,
    endMs: startMs + durationMs,
    durationMs,
    centerMs: startMs + (durationMs / 2),
  };
}

function audioIntervalsOverlap(a, b) {
  return a.startMs < b.endMs - 40 && b.startMs < a.endMs - 40;
}

function resolveAudioTrackOverlapBySlotSwap(nextTracks = [], movedTrackId = '', beforeTracks = []) {
  const movedTrack = nextTracks.find((track) => track?.id === movedTrackId) || null;

  if (!movedTrack) {
    return nextTracks;
  }

  const movedInterval = getAudioTrackInterval(movedTrack);
  const overlapping = nextTracks.some((track) => (
    track?.id !== movedTrackId &&
    audioIntervalsOverlap(movedInterval, getAudioTrackInterval(track))
  ));

  if (!overlapping) {
    return nextTracks;
  }

  const beforeById = new Map((beforeTracks || []).filter(Boolean).map((track) => [track.id, track]));
  const slotStarts = [...nextTracks]
    .map((track) => ({
      id: track.id,
      startMs: Math.max(0, Number((beforeById.get(track.id) || track)?.offsetMs || 0)),
    }))
    .sort((a, b) => a.startMs - b.startMs || String(a.id).localeCompare(String(b.id)))
    .map((slot) => slot.startMs);

  const others = nextTracks
    .filter((track) => track?.id !== movedTrackId)
    .sort((a, b) => {
      const aInterval = getAudioTrackInterval(a);
      const bInterval = getAudioTrackInterval(b);

      return aInterval.startMs - bInterval.startMs || String(a.id).localeCompare(String(b.id));
    });

  const movedCenter = movedInterval.centerMs;
  let targetIndex = 0;

  for (const other of others) {
    if (movedCenter > getAudioTrackInterval(other).centerMs) {
      targetIndex += 1;
    }
  }

  const reordered = [...others];
  reordered.splice(targetIndex, 0, movedTrack);

  return reordered.map((track, index) => ({
    ...track,
    offsetMs: Math.max(0, Math.round(Number(slotStarts[index] ?? track.offsetMs ?? 0) / 250) * 250),
  }));
}

function probeLocalAudioDurationMs(objectUrl, timeoutMs = 5000) {
  if (!objectUrl || typeof Audio !== 'function') {
    return Promise.resolve(0);
  }

  return new Promise((resolve) => {
    const audio = new Audio();
    let settled = false;

    const finish = (value) => {
      if (settled) {
        return;
      }

      settled = true;

      try {
        audio.removeAttribute('src');
        audio.load?.();
      } catch (_error) {
        // Best-effort metadata cleanup.
      }

      resolve(Math.max(0, Number(value || 0)));
    };

    const timer = setTimeout(() => finish(0), timeoutMs);

    audio.preload = 'metadata';
    audio.onloadedmetadata = () => {
      clearTimeout(timer);
      finish(Number.isFinite(audio.duration) ? Math.round(audio.duration * 1000) : 0);
    };
    audio.onerror = () => {
      clearTimeout(timer);
      finish(0);
    };
    audio.src = objectUrl;
  });
}

async function requestMakeCameraWithFallback({ width, height, frameRate, pushMediaDebug }) {
  const attempts = [
    {
      label: 'ideal-output-camera',
      constraints: {
        video: {
          width: { ideal: width },
          height: { ideal: height },
          frameRate: { ideal: frameRate },
        },
        audio: false,
      },
    },
    {
      label: 'balanced-pip-camera',
      constraints: {
        video: {
          width: { ideal: 640 },
          height: { ideal: 360 },
          frameRate: { ideal: 24 },
        },
        audio: false,
      },
    },
    {
      label: 'plain-camera',
      constraints: {
        video: true,
        audio: false,
      },
    },
  ];

  let lastError = null;

  for (const attempt of attempts) {
    try {
      pushMediaDebug?.('request_camera_attempt_start', { attempt: attempt.label });
      const stream = await navigator.mediaDevices.getUserMedia(attempt.constraints);
      pushMediaDebug?.('request_camera_attempt_ok', {
        attempt: attempt.label,
        stream: makeStreamFacts(stream),
      });
      return stream;
    } catch (error) {
      lastError = error;
      pushMediaDebug?.('request_camera_attempt_error', {
        attempt: attempt.label,
        ...makeMediaErrorDetails(error),
      });
    }
  }

  throw lastError || new Error('Camera unavailable.');
}

function makeStreamFacts(stream) {
  if (!stream) {
    return {
      present: false,
      id: '',
      active: false,
      tracks: [],
    };
  }

  return {
    present: true,
    id: stream.id || '',
    active: Boolean(stream.active),
    tracks: stream.getTracks?.().map(makeTrackFacts) || [],
  };
}

function makeTrackFacts(track) {
  if (!track) {
    return {
      kind: '',
      label: '',
      enabled: false,
      muted: false,
      readyState: '',
      settings: {},
    };
  }

  let settings = {};

  try {
    settings = track.getSettings?.() || {};
  } catch (_error) {
    settings = {};
  }

  return {
    kind: track.kind || '',
    label: track.label || '',
    enabled: Boolean(track.enabled),
    muted: Boolean(track.muted),
    readyState: track.readyState || '',
    settings,
  };
}

function makeMediaErrorDetails(error) {
  const name = error?.name || '';
  const message = error?.message || String(error || 'Unknown error');
  const summary = name ? `${name}: ${message}` : message;

  return {
    name,
    message,
    summary,
  };
}

function errorMessage(error) {
  if (!error) {
    return 'Unknown error';
  }

  return error.message || error.name || String(error);
}