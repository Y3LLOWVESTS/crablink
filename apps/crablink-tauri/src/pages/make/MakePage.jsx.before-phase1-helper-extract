  );

  useEffect(() => {
    const video = backgroundVideoRef.current;

    if (!video || !backgroundVideoUrl) {
      return undefined;
    }

    video.src = backgroundVideoUrl;
    video.loop = true;
    video.muted = true;
    video.playsInline = true;

    const playPromise = video.play?.();

    if (playPromise?.catch) {
      playPromise.catch(() => {
        // Browser may defer autoplay until preview starts; the compositor will retry when ready.
      });
    }

    return () => {
      try {
        video.pause();
        video.removeAttribute('src');
        video.load?.();
      } catch (_error) {
