    if (!rect || rect.width <= 0 || durationMs <= 100) {
      return;
    }

    event.preventDefault();
    event.stopPropagation();

    try {
      event.currentTarget.setPointerCapture(event.pointerId);
    } catch (_error) {
      // Pointer capture is best effort in the WebView.
    }

    setSelectedTimelineMediaKind('audio');
    setSelectedAudioTrackId(track.id);
    setTrimEditorClipId('');
    setTimelineTool('select');
    resetTimelineCursorSelection();

    const startX = Number(event.clientX || 0);
    const dragStartAudioTracks = preparedAudioTracks.map((item) => ({ ...item }));
    const startTrimStartMs = clamp(Number(track.trimStartMs || 0), 0, durationMs, 0);
    const startTrimEndMs = clamp(Number(track.trimEndMs || durationMs), startTrimStartMs + 100, durationMs, durationMs);
    const pxToMs = durationMs / Math.max(1, rect.width);

    const nextPatchForClientX = (clientX) => {
      const deltaMs = Math.round(((Number(clientX || startX) - startX) * pxToMs) / 250) * 250;

      if (edge === 'start') {
        return {
          trimStartMs: clamp(startTrimStartMs + deltaMs, 0, Math.max(0, startTrimEndMs - 100), startTrimStartMs),
        };
      }

      return {
        trimEndMs: clamp(startTrimEndMs + deltaMs, Math.min(durationMs, startTrimStartMs + 100), durationMs, startTrimEndMs),
      };
    };

    const handleMove = (moveEvent) => {
      setAudioTrimDrag(`${track.id}:${edge}`);
      onUpdateAudioTrackTiming(track.id, nextPatchForClientX(moveEvent.clientX), { history: false });
      moveEvent.preventDefault();
    };

    const handleEnd = (endEvent) => {
      window.removeEventListener('pointermove', handleMove);
      window.removeEventListener('pointerup', handleEnd);
      window.removeEventListener('pointercancel', handleCancel);
      setAudioTrimDrag(null);
      onUpdateAudioTrackTiming(track.id, nextPatchForClientX(endEvent.clientX), { history: true, beforeAudioTracks: dragStartAudioTracks });
      endEvent.preventDefault();
    };

    const handleCancel = () => {
      window.removeEventListener('pointermove', handleMove);
      window.removeEventListener('pointerup', handleEnd);
      window.removeEventListener('pointercancel', handleCancel);
      setAudioTrimDrag(null);
    };

    setAudioTrimDrag(`${track.id}:${edge}`);
    window.addEventListener('pointermove', handleMove);
    window.addEventListener('pointerup', handleEnd, { once: true });
    window.addEventListener('pointercancel', handleCancel, { once: true });
