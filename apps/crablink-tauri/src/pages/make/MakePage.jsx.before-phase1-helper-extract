    );
    const ordered = [];

    for (const key of timelinePlaybackItemOrder) {
      if (isLocalTimelineItemKey(key)) {
        const clip = localClipByKey.get(key);

        if (clip) ordered.push(clip);

        continue;
      }

      if (isLinkedVideoTimelineItemKey(key)) {
        const clip = linkedPreviewByKey.get(key);

        if (clip) ordered.push(clip);
