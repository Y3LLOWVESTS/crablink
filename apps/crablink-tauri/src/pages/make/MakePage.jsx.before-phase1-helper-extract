              disabled={editTimelineButtonDisabled}
              title={editTimelineButtonTitle}
            >
              {editTimelineButtonLabel}
            </button>
            <button type="button" onClick={() => setTimelineZoomBounded((current) => current - 0.25)} disabled={timelineZoom <= 1} title="Zoom timeline out" aria-label="Zoom timeline out">−</button>
            <button type="button" onClick={() => setTimelineZoomBounded((current) => current + 0.25)} disabled={!timelineHasItems || timelineZoom >= 6} title="Zoom timeline in" aria-label="Zoom timeline in">+</button>
            <button
              type="button"
              onClick={handleTimelinePlayClick}
              disabled={timelinePlayDisabled}
              title={timelinePlayTitle}
