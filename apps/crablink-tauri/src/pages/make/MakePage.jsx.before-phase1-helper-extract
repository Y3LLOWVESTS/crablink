  };

  const stopTimelinePreview = () => {
    const video = timelinePreviewVideoRef.current;

    try {
      video?.pause?.();
    } catch (_error) {
      // Best-effort local preview cleanup.
    }

    setTimelinePreview(null);
  };

  const resetTimelineCursorSelection = () => {
    setTimelineSelection(null);
    stopTimelinePreview();
  };

  const previewTimelineSelection = (selection) => {
    if (!selection?.clipId) {
      stopTimelinePreview();
      return;
    }

    const clip = clips.find((item) => item.id === selection.clipId) || null;

    if (!clip) {
      stopTimelinePreview();
      return;
    }

    const trimStartMs = getClipTrimStartMs(clip);
    const trimEndMs = getClipTrimEndMs(clip);
    const startMs = clamp(Number(selection.startMs ?? selection.focusMs ?? trimStartMs), trimStartMs, trimEndMs, trimStartMs);
    const endMs = clamp(Number(selection.endMs ?? selection.focusMs ?? startMs), trimStartMs, trimEndMs, trimEndMs);
    const focusMs = clamp(Number(selection.focusMs ?? startMs), trimStartMs, trimEndMs, startMs);

    const video = timelinePreviewVideoRef.current;
    try {
      video?.pause?.();
    } catch (_error) {
      // Best-effort local preview cleanup.
    }

    setTimelinePreview({
      visible: true,
      status: 'frame',
      clipId: clip.id,
      mode: selection.mode || 'point',
      focusMs,
      startMs: Math.min(startMs, endMs),
      endMs: Math.max(startMs, endMs),
      progressPct: getTimelinePreviewProgressPct(clip, focusMs),
      updatedAt: Date.now(),
    });
  };

  const commitTimelineSelection = (selection) => {
    setTimelineSelection(selection);
    previewTimelineSelection(selection);
  };

  const beginTimelineCursorDrag = (event, clip) => {
    if (!cursorToolActive || !clip?.id || isRecording || trimEditorActive) {
      return;
    }

    if (Number.isFinite(event.button) && event.button !== 0) {
      return;
    }

    const captureEl = event.currentTarget;
    const shell = captureEl.closest('.make-preview-mini-clip');
    const rect = shell?.getBoundingClientRect?.();
    const trimStartMs = getClipTrimStartMs(clip);
    const trimEndMs = getClipTrimEndMs(clip);
    const visibleDurationMs = Math.max(1, trimEndMs - trimStartMs);

    if (!rect || rect.width <= 0 || trimEndMs <= trimStartMs) {
      return;
    }

    event.preventDefault();
    event.stopPropagation();

    onSelectClip(clip.id);
    setPreviewDrawer('');
    setTrimEditorClipId('');
    onTimelineHoverChange?.(true);

    const dragMinPx = 4;
    const rangeMinMs = 80;
    const anchorClientX = Number(event.clientX || rect.left);

    const pointerToVisiblePct = (clientX) => (
      clamp(((Number(clientX || rect.left) - rect.left) / Math.max(1, rect.width)) * 100, 0, 100, 0)
    );

    const pctToMs = (pct) => (
      clamp(snapTimelineFrameMs(trimStartMs + ((clamp(pct, 0, 100, 0) / 100) * visibleDurationMs)), trimStartMs, trimEndMs, trimStartMs)
    );

    const commitSelection = (selection) => {
      if (typeof commitTimelineSelection === 'function') {
        commitTimelineSelection(selection);
        return;
      }

      setTimelineSelection(selection);
    };

    const anchorPct = pointerToVisiblePct(anchorClientX);
    const anchorMs = pctToMs(anchorPct);

    const applySelection = (clientX, forceRange = false) => {
      const focusPct = pointerToVisiblePct(clientX);
      const focusMs = pctToMs(focusPct);
      const draggedPx = Math.abs(Number(clientX || anchorClientX) - anchorClientX);

      let startPct = Math.min(anchorPct, focusPct);
      let endPct = Math.max(anchorPct, focusPct);
      let startMs = Math.min(anchorMs, focusMs);
      let endMs = Math.max(anchorMs, focusMs);
      let rangeMs = Math.max(0, endMs - startMs);
      let visualWidthPct = Math.max(0, endPct - startPct);

      const shouldBeRange = forceRange || draggedPx >= dragMinPx || rangeMs >= rangeMinMs || visualWidthPct >= 0.75;

      if (shouldBeRange && rangeMs > 0 && rangeMs < rangeMinMs) {
        if (focusMs >= anchorMs) {
          endMs = clamp(startMs + rangeMinMs, trimStartMs, trimEndMs, trimEndMs);
        } else {
          startMs = clamp(endMs - rangeMinMs, trimStartMs, trimEndMs, trimStartMs);
        }

        startPct = sourceMsToVisiblePct(clip, startMs);
        endPct = sourceMsToVisiblePct(clip, endMs);
        rangeMs = Math.max(0, endMs - startMs);
        visualWidthPct = Math.max(0, endPct - startPct);
      }

      if (shouldBeRange && visualWidthPct > 0 && visualWidthPct < 1.4) {
        if (focusPct >= anchorPct) {
          endPct = clamp(startPct + 1.4, 0, 100, 100);
        } else {
          startPct = clamp(endPct - 1.4, 0, 100, 0);
        }

        visualWidthPct = Math.max(0, endPct - startPct);
      }

      commitSelection({
        clipId: clip.id,
        anchorMs,
        focusMs,
        startMs,
        endMs,
        rangeMs,
        anchorPct,
        focusPct,
        startPct,
        endPct,
        visualLeftPct: startPct,
        visualWidthPct,
        mode: shouldBeRange && rangeMs >= rangeMinMs ? 'range' : 'point',
      });
    };

    const handleMove = (moveEvent) => {
      applySelection(moveEvent.clientX, Math.abs(Number(moveEvent.clientX || anchorClientX) - anchorClientX) >= dragMinPx);
      moveEvent.preventDefault();
      moveEvent.stopPropagation();
    };

    const handleEnd = (endEvent) => {
      const finalClientX = Number.isFinite(endEvent?.clientX) ? endEvent.clientX : anchorClientX;
      applySelection(finalClientX, Math.abs(finalClientX - anchorClientX) >= dragMinPx);

      captureEl.removeEventListener('pointermove', handleMove);
      captureEl.removeEventListener('pointerup', handleEnd);
      captureEl.removeEventListener('pointercancel', handleEnd);
      window.removeEventListener('pointermove', handleMove);
      window.removeEventListener('pointerup', handleEnd);
      window.removeEventListener('pointercancel', handleEnd);
      document.removeEventListener('pointermove', handleMove);
      document.removeEventListener('pointerup', handleEnd);
      document.removeEventListener('pointercancel', handleEnd);
    };

    captureEl.addEventListener('pointermove', handleMove, { passive: false });
    captureEl.addEventListener('pointerup', handleEnd, { once: true });
    captureEl.addEventListener('pointercancel', handleEnd, { once: true });
    window.addEventListener('pointermove', handleMove, { passive: false });
    window.addEventListener('pointerup', handleEnd, { once: true });
    window.addEventListener('pointercancel', handleEnd, { once: true });
    document.addEventListener('pointermove', handleMove, { passive: false });
    document.addEventListener('pointerup', handleEnd, { once: true });
    document.addEventListener('pointercancel', handleEnd, { once: true });

    try {
      captureEl.setPointerCapture(event.pointerId);
    } catch (_error) {
      // Pointer capture is best effort. Window/document listeners still cover the drag.
    }

    applySelection(anchorClientX, false);
  };

  const splitAtTimelineSelection = () => {
    if (!canSplitTimelineSelection || !timelineSelection) {
      return;
    }

    onSplitTimelineAt?.({
      clipId: timelineSelection.clipId,
      atMs: timelineSelection.focusMs,
    });
    setTimelineSelection(null);
    stopTimelinePreview();
  };

  const deleteSelectedTimelineRange = () => {
    if (!canDeleteTimelineSelection || !timelineSelection) {
      return;
    }

    const startMs = timelineSelectionStartMs;
    const endMs = timelineSelectionEndMs;

    onDeleteTimelineRange?.({
      clipId: timelineSelection.clipId,
      startMs,
      endMs,
    });

    setTimelineSelection(null);
    stopTimelinePreview();
  };

  const playTimelineRangeLoop = () => {
    if (!timelineRangeLoopAvailable || !timelineSelectionClip || !timelineSelection) {
      return false;
    }

    if (sequencePlaying) {
      onPauseSequence?.();
    }

    const startMs = clamp(timelineSelectionStartMs, getClipTrimStartMs(timelineSelectionClip), getClipTrimEndMs(timelineSelectionClip), getClipTrimStartMs(timelineSelectionClip));
    const endMs = clamp(timelineSelectionEndMs, startMs, getClipTrimEndMs(timelineSelectionClip), getClipTrimEndMs(timelineSelectionClip));

    if (endMs - startMs < 80) {
      return false;
    }

    setTimelinePreview({
      visible: true,
      status: 'looping',
      clipId: timelineSelectionClip.id,
      mode: 'range',
      focusMs: startMs,
      startMs,
      endMs,
      progressPct: getTimelinePreviewProgressPct(timelineSelectionClip, startMs),
      updatedAt: Date.now(),
    });

    window.requestAnimationFrame(() => {
      seekTimelinePreviewVideo(startMs, { play: true });
    });

    return true;
  };

  const pauseTimelineRangeLoop = () => {
    const video = timelinePreviewVideoRef.current;

    try {
      video?.pause?.();
    } catch (_error) {
      // Best-effort local preview cleanup.
    }

    setTimelinePreview((current) => current
      ? {
          ...current,
          status: 'frame',
          focusMs: Number.isFinite(video?.currentTime) ? Math.round(video.currentTime * 1000) : current.focusMs,
          updatedAt: Date.now(),
        }
      : current);
  };

  const handleTimelinePlayClick = () => {
    if (timelineLoopPlaying) {
      pauseTimelineRangeLoop();
      return;
    }

    if (sequencePlaying) {
      onPauseSequence?.();
      return;
    }

    if (timelineRangeLoopAvailable && playTimelineRangeLoop()) {
      return;
    }

    stopTimelinePreview();
    onPlaySequence?.();
  };

  const handleTimelinePreviewTimeUpdate = (event) => {
    const video = event.currentTarget;

    if (!timelinePreviewClip || !timelinePreviewActive || !video) {
      return;
    }

    const sourceMs = Number.isFinite(video.currentTime)
      ? Math.round(video.currentTime * 1000)
      : Number(timelinePreview?.focusMs || getClipTrimStartMs(timelinePreviewClip));

    if (timelinePreview?.status === 'looping') {
      const startMs = clamp(Number(timelinePreview.startMs || getClipTrimStartMs(timelinePreviewClip)), getClipTrimStartMs(timelinePreviewClip), getClipTrimEndMs(timelinePreviewClip), getClipTrimStartMs(timelinePreviewClip));
      const endMs = clamp(Number(timelinePreview.endMs || getClipTrimEndMs(timelinePreviewClip)), startMs, getClipTrimEndMs(timelinePreviewClip), getClipTrimEndMs(timelinePreviewClip));

      if (sourceMs + 34 >= endMs) {
        setTimelinePreview((current) => current
          ? {
              ...current,
              focusMs: startMs,
              progressPct: getTimelinePreviewProgressPct(timelinePreviewClip, startMs),
              updatedAt: Date.now(),
            }
          : current);

        seekTimelinePreviewVideo(startMs, { play: true });
        return;
      }
    }

    setTimelinePreview((current) => current
      ? {
          ...current,
          focusMs: sourceMs,
          progressPct: getTimelinePreviewProgressPct(timelinePreviewClip, sourceMs),
        }
      : current);
  };

  const timelinePlayDisabled = !hasClips || isRecording || trimEditorActive || (cursorToolActive && !timelineRangeLoopAvailable);
  const timelinePlayTitle = timelineLoopPlaying
    ? 'Pause selected range loop'
    : timelineRangeLoopAvailable
      ? 'Play only the highlighted range as a loop'
      : sequencePlaying
        ? 'Pause sequence playback'
        : 'Play timeline sequence';

  const drawerEyebrow = previewDrawer === 'effects' ? 'Effects' : previewDrawer === 'modes' ? 'Modes' : 'Settings';
  const drawerTitle = previewDrawer === 'effects'
    ? 'Look and clip style'
    : previewDrawer === 'modes'
      ? 'Video mode switcher'
      : 'Studio setup';

  return (
    <div
      className={`make-preview-chrome ${activeDrawer ? 'has-open-drawer' : ''} ${isRecording ? 'is-recording' : ''} ${sequenceActive ? 'is-sequence-active' : ''} ${timelinePreviewActive ? 'has-timeline-preview' : ''} ${timelineLoopPlaying ? 'is-range-looping' : ''} ${trimEditorActive ? 'is-trimming-clip' : ''} ${cursorToolActive ? 'is-timeline-cursor' : ''} ${previewClipMoveDrag ? 'is-moving-timeline-item' : ''}`}
      style={{ '--make-timeline-zoom': timelineZoom }}
      aria-label="Preview controls. These controls are not recorded into the canvas."
    >
      <div
        className="make-preview-control-stack"
        aria-label="Preview action buttons"
        onPointerDown={(event) => event.stopPropagation()}
        onPointerMove={(event) => event.stopPropagation()}
        onPointerUp={(event) => event.stopPropagation()}
        onClick={(event) => event.stopPropagation()}
      >
        <button
          className={`make-preview-round-button make-preview-mode-button ${previewDrawer === 'modes' ? 'is-active' : ''}`}
          type="button"
          aria-label={`Switch video mode. Current mode: ${selectedMode?.label || selectedModeLabel}`}
          title={`Switch video mode · ${selectedMode?.label || selectedModeLabel}`}
          onPointerDown={(event) => event.stopPropagation()}
          onClick={(event) => {
            event.stopPropagation();
            toggleDrawer('modes');
          }}
        >
          <MakePreviewIcon name="puzzle" />
        </button>

        <button
          className={`make-preview-round-button ${previewDrawer === 'settings' ? 'is-active' : ''}`}
          type="button"
          aria-label="Open studio settings"
          title="Studio settings"
          onPointerDown={(event) => event.stopPropagation()}
          onClick={(event) => {
            event.stopPropagation();
            toggleDrawer('settings');
          }}
        >
          <MakePreviewIcon name="settings" />
        </button>

        <button
          className={`make-preview-round-button ${previewDrawer === 'effects' ? 'is-active' : ''}`}
          type="button"
          aria-label="Open effects"
          title="Effects"
          onPointerDown={(event) => event.stopPropagation()}
          onClick={(event) => {
            event.stopPropagation();
            toggleDrawer('effects');
          }}
        >
          <MakePreviewIcon name="effects" />
        </button>

        {subjectEditAvailable && (
          <button
            className={`make-preview-round-button make-preview-subject-button ${subjectEditMode ? 'is-active' : ''}`}
            type="button"
            aria-label={subjectEditMode ? 'Stop moving subject' : 'Move cutout subject'}
            title={subjectEditMode ? 'Stop moving subject' : 'Move cutout subject'}
            disabled={isRecording || isCountingDown || Boolean(previewDrawer) || trimEditorActive}
            onPointerDown={(event) => event.stopPropagation()}
            onClick={(event) => {
              event.preventDefault();
              event.stopPropagation();
              onToggleSubjectEdit?.();
            }}
          >
            <MakePreviewIcon name="move" />
          </button>
        )}

        <button
          className={`make-preview-record-button ${isRecording ? 'is-recording' : ''} ${isCountingDown ? 'is-countdown' : ''}`}
          type="button"
          aria-label={recordTitle}
          title={recordTitle}
          disabled={recordDisabled}
          onClick={handleRecordClick}
        >
          <span className="make-preview-record-glyph" aria-hidden="true">
            <MakePreviewIcon name={isRecording ? 'stop' : inputReady ? 'record' : 'play'} />
          </span>
          <span className="make-preview-record-label">{recordLabel}</span>
        </button>
      </div>

      {timelinePreviewActive && timelinePreviewClip && (
        <div
          className={`make-preview-marker-layer ${timelineLoopPlaying ? 'is-looping' : 'is-frame-preview'}`}
          aria-label="Timeline marker preview"
          onPointerDown={(event) => event.stopPropagation()}
          onClick={(event) => event.stopPropagation()}
        >
          <video
            key={`${timelinePreviewClip.id || ''}:${timelinePreviewClip.objectUrl || ''}`}
            ref={timelinePreviewVideoRef}
            className="make-preview-marker-video"
            src={timelinePreviewClip.objectUrl}
            playsInline
            preload="auto"
            style={{ filter: timelineEffectCssFilter(timelinePreviewClip.timelineEffect) }}
            onLoadedMetadata={() => {
              const targetMs = timelinePreview?.status === 'looping'
                ? Number(timelinePreview?.startMs || getClipTrimStartMs(timelinePreviewClip))
                : Number(timelinePreview?.focusMs || getClipTrimStartMs(timelinePreviewClip));
              seekTimelinePreviewVideo(targetMs, { play: timelinePreview?.status === 'looping' });
            }}
            onLoadedData={() => {
              if (timelinePreview?.status !== 'looping') {
                seekTimelinePreviewVideo(Number(timelinePreview?.focusMs || getClipTrimStartMs(timelinePreviewClip)));
              }
            }}
            onTimeUpdate={handleTimelinePreviewTimeUpdate}
            onEnded={() => {
              if (timelinePreview?.status === 'looping') {
                seekTimelinePreviewVideo(Number(timelinePreview?.startMs || getClipTrimStartMs(timelinePreviewClip)), { play: true });
              }
            }}
          />

          <div className="make-preview-marker-status">
            <span>{timelineLoopPlaying ? 'Looping range' : 'I-marker preview'}</span>
            <strong>{timelinePreviewClip.name || 'Selected clip'}</strong>
            <small>
              {timelineLoopPlaying
                ? `${formatTimelinePreciseTimeMs(timelinePreview?.startMs || 0)} – ${formatTimelinePreciseTimeMs(timelinePreview?.endMs || 0)}`
                : formatTimelinePreciseTimeMs(getTimelineAbsolutePositionMs(
                    clips,
                    timelinePreviewClip.id,
                    Number(timelinePreview?.focusMs || getClipTrimStartMs(timelinePreviewClip)),
                  ))}
            </small>
          </div>
        </div>
      )}

      <div
        className="make-preview-mini-timeline"
        aria-label="Preview timeline overlay"
        onPointerEnter={() => onTimelineHoverChange?.(true)}
        onPointerLeave={() => onTimelineHoverChange?.(false)}
        onPointerDown={(event) => event.stopPropagation()}
        onClick={(event) => event.stopPropagation()}
        onFocus={() => onTimelineHoverChange?.(true)}
        onBlur={() => onTimelineHoverChange?.(false)}
      >
        <div className="make-preview-mini-timeline-head">
          <span>{trimEditorActive ? 'Trim clip' : 'Timeline'}</span>
          <strong>
            {trimEditorActive && editedClip
              ? `${editedClip.name || 'Selected clip'} · drag the clip edges`
              : cursorToolActive
                ? timelineSelection?.mode === 'range'
                  ? `Range selected · ${formatDurationMs(timelineSelectionRangeMs)}`
                  : timelineSelection
                    ? 'I cursor placed · Split is ready'
                    : 'I cursor · click to split, drag to delete'
                : timelineSummaryLabel}
          </strong>

          <div className="make-preview-mini-actions" aria-label="Preview sequence actions">
            <button type="button" onClick={onTimelineUndo} disabled={!timelineCanUndo || isRecording} title="Undo timeline action">Undo</button>
            <button type="button" onClick={onTimelineRedo} disabled={!timelineCanRedo || isRecording} title="Redo timeline action">Redo</button>
            <button
              className={`make-preview-timeline-cursor-button ${cursorToolActive ? 'is-active' : ''}`}
              type="button"
              onClick={() => {
                setPreviewDrawer('');
                setTrimEditorClipId('');
                setTimelineTool((current) => (current === 'cursor' ? 'select' : 'cursor'));
                resetTimelineCursorSelection();
              }}
              disabled={!hasClips || isRecording}
              title="I cursor: click to choose a split point, or drag to select a range"
            >
              I
            </button>
            <button type="button" onClick={splitAtTimelineSelection} disabled={!canSplitTimelineSelection || isRecording} title="Split selected clip at the I cursor">Split</button>
            <button type="button" onClick={deleteSelectedTimelineRange} disabled={!canDeleteTimelineSelection || isRecording} title="Delete highlighted timeline range">Delete</button>
            <button
              className={`make-preview-timeline-edit ${trimEditorActive || audioEditActive ? 'is-active' : ''}`}
              type="button"
              onClick={() => {
                if (audioEditActive) {
                  setSelectedTimelineMediaKind('audio');
                  setSelectedAudioTrackId(selectedAudioTrack?.id || '');
                  setTrimEditorClipId('');
                  setTimelineTool('select');
                  resetTimelineCursorSelection();
                  return;
