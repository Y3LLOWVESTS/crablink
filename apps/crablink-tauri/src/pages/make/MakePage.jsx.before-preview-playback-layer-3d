          const safeEndMs = clamp(
            Number(next.trimEndMs || durationMs),
            Math.min(durationMs, safeStartMs + 100),
            durationMs,
            durationMs,
          );

          next.trimStartMs = safeStartMs;
          next.trimEndMs = safeEndMs;
          next.effectiveDurationMs = Math.max(0, safeEndMs - safeStartMs);
