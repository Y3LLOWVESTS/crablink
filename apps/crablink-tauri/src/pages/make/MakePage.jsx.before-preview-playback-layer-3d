    const applySelection = (clientX, forceRange = false) => {
      const focusPct = pointerToVisiblePct(clientX);
      const focusMs = pctToMs(focusPct);
      const draggedPx = Math.abs(Number(clientX || anchorClientX) - anchorClientX);

      let startPct = Math.min(anchorPct, focusPct);
      let endPct = Math.max(anchorPct, focusPct);
      let startMs = Math.min(anchorMs, focusMs);
      let endMs = Math.max(anchorMs, focusMs);
      let rangeMs = Math.max(0, endMs - startMs);
      let visualWidthPct = Math.max(0, endPct - startPct);

      const shouldBeRange = forceRange || draggedPx >= dragMinPx || rangeMs >= rangeMinMs || visualWidthPct >= 0.75;

      if (shouldBeRange && rangeMs > 0 && rangeMs < rangeMinMs) {
        if (focusMs >= anchorMs) {
          endMs = clamp(startMs + rangeMinMs, trimStartMs, trimEndMs, trimEndMs);
        } else {
          startMs = clamp(endMs - rangeMinMs, trimStartMs, trimEndMs, trimStartMs);
        }

        startPct = sourceMsToVisiblePct(clip, startMs);
        endPct = sourceMsToVisiblePct(clip, endMs);
        rangeMs = Math.max(0, endMs - startMs);
        visualWidthPct = Math.max(0, endPct - startPct);
      }

      if (shouldBeRange && visualWidthPct > 0 && visualWidthPct < 1.4) {
        if (focusPct >= anchorPct) {
          endPct = clamp(startPct + 1.4, 0, 100, 100);
        } else {
          startPct = clamp(endPct - 1.4, 0, 100, 0);
        }

        visualWidthPct = Math.max(0, endPct - startPct);
      }

      commitSelection({
        clipId: clip.id,
        anchorMs,
        focusMs,
        startMs,
        endMs,
        rangeMs,
        anchorPct,
        focusPct,
        startPct,
        endPct,
        visualLeftPct: startPct,
        visualWidthPct,
        mode: shouldBeRange && rangeMs >= rangeMinMs ? 'range' : 'point',
      });
    };

    const handleMove = (moveEvent) => {
      applySelection(moveEvent.clientX, Math.abs(Number(moveEvent.clientX || anchorClientX) - anchorClientX) >= dragMinPx);
      moveEvent.preventDefault();
      moveEvent.stopPropagation();
    };

    const handleEnd = (endEvent) => {
      const finalClientX = Number.isFinite(endEvent?.clientX) ? endEvent.clientX : anchorClientX;
      applySelection(finalClientX, Math.abs(finalClientX - anchorClientX) >= dragMinPx);

      captureEl.removeEventListener('pointermove', handleMove);
      captureEl.removeEventListener('pointerup', handleEnd);
      captureEl.removeEventListener('pointercancel', handleEnd);
      window.removeEventListener('pointermove', handleMove);
      window.removeEventListener('pointerup', handleEnd);
      window.removeEventListener('pointercancel', handleEnd);
      document.removeEventListener('pointermove', handleMove);
      document.removeEventListener('pointerup', handleEnd);
      document.removeEventListener('pointercancel', handleEnd);
    };

    captureEl.addEventListener('pointermove', handleMove, { passive: false });
    captureEl.addEventListener('pointerup', handleEnd, { once: true });
    captureEl.addEventListener('pointercancel', handleEnd, { once: true });
    window.addEventListener('pointermove', handleMove, { passive: false });
    window.addEventListener('pointerup', handleEnd, { once: true });
    window.addEventListener('pointercancel', handleEnd, { once: true });
    document.addEventListener('pointermove', handleMove, { passive: false });
    document.addEventListener('pointerup', handleEnd, { once: true });
    document.addEventListener('pointercancel', handleEnd, { once: true });

    try {
      captureEl.setPointerCapture(event.pointerId);
    } catch (_error) {
      // Pointer capture is best effort. Window/document listeners still cover the drag.
    }

    applySelection(anchorClientX, false);
  };

  const splitAtTimelineSelection = () => {
    if (!canSplitTimelineSelection || !timelineSelection) {
      return;
    }

    onSplitTimelineAt?.({
      clipId: timelineSelection.clipId,
      atMs: timelineSelection.focusMs,
    });
    setTimelineSelection(null);
    stopTimelinePreview();
  };

  const deleteSelectedTimelineRange = () => {
    if (!canDeleteTimelineSelection || !timelineSelection) {
      return;
    }

    const startMs = timelineSelectionStartMs;
    const endMs = timelineSelectionEndMs;

    onDeleteTimelineRange?.({
      clipId: timelineSelection.clipId,
      startMs,
      endMs,
    });

    setTimelineSelection(null);
    stopTimelinePreview();
  };

  const playTimelineRangeLoop = () => {
    if (!timelineRangeLoopAvailable || !timelineSelectionClip || !timelineSelection) {
      return false;
    }

    if (sequencePlaying) {
      onPauseSequence?.();
    }

    const startMs = clamp(timelineSelectionStartMs, getClipTrimStartMs(timelineSelectionClip), getClipTrimEndMs(timelineSelectionClip), getClipTrimStartMs(timelineSelectionClip));
    const endMs = clamp(timelineSelectionEndMs, startMs, getClipTrimEndMs(timelineSelectionClip), getClipTrimEndMs(timelineSelectionClip));

    if (endMs - startMs < 80) {
      return false;
    }

    setTimelinePreview({
      visible: true,
      status: 'looping',
      clipId: timelineSelectionClip.id,
      mode: 'range',
      focusMs: startMs,
      startMs,
      endMs,
      progressPct: getTimelinePreviewProgressPct(timelineSelectionClip, startMs),
      updatedAt: Date.now(),
    });

    window.requestAnimationFrame(() => {
      seekTimelinePreviewVideo(startMs, { play: true });
    });

    return true;
  };

  const pauseTimelineRangeLoop = () => {
    const video = timelinePreviewVideoRef.current;

    try {
      video?.pause?.();
    } catch (_error) {
