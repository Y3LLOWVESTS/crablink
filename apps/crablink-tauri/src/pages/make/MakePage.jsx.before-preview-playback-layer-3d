      if (mode.needsScreen) {
        if (typeof navigator.mediaDevices.getDisplayMedia !== 'function') {
          throw new Error('Screen capture is unavailable in this WebView.');
        }

        pushMediaDebug('request_screen_start');

        screenStream = await navigator.mediaDevices.getDisplayMedia({
          video: {
            width: { ideal: outputPreset.width },
            height: { ideal: outputPreset.height },
            frameRate: { ideal: draft.targetFps },
          },
          audio: false,
        });

        pushMediaDebug('request_screen_ok', makeStreamFacts(screenStream));

        const screenTrack = screenStream.getVideoTracks()[0];

        if (screenTrack) {
          screenTrack.onended = () => {
            pushMediaDebug('screen_track_ended', makeTrackFacts(screenTrack));
            stopAllStreams(streamsRef.current);

            const nextState = {
              ...EMPTY_INPUT_STATE,
              status: 'idle',
              warning: 'Screen sharing ended from the system picker. Start preview again before recording.',
            };

