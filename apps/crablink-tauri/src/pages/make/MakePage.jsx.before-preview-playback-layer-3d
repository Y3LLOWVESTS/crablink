        const next = {
          ...track,
          ...patch,
        };

        if (Object.prototype.hasOwnProperty.call(patch, 'offsetMs')) {
          const requestedOffsetMs = Number(patch.offsetMs);
          const currentAudioEndMs = current.reduce((max, item) => {
            const itemOffsetMs = Math.max(0, Number(item?.offsetMs || 0));
