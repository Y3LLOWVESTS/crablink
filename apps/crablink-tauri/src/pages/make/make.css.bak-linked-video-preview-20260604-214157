}

.make-project-prime,
.make-form-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 0.85rem;
}

.make-disclosure {
  border: 1px solid var(--cl-border);
  border-radius: 24px;
  background: var(--make-panel);
}

.make-disclosure summary {
  display: flex;
  gap: 0.75rem;
  align-items: center;
  justify-content: space-between;
  padding: 0.95rem 1rem;
  color: var(--cl-text);
  cursor: pointer;
  font-weight: 950;
}

.make-disclosure summary small {
  color: var(--cl-muted);
  font-size: 0.78rem;
  font-weight: 750;
}

.make-disclosure-body {
  display: grid;
  gap: 0.9rem;
  padding: 0 1rem 1rem;
}

.make-toggle-grid {
  display: grid;
  grid-template-columns: repeat(4, minmax(0, 1fr));
  gap: 0.65rem;
}

.make-check-toggle {
  display: flex;
  align-items: center;
  gap: 0.5rem;
  min-width: 0;
  padding: 0.72rem 0.8rem;
  border: 1px solid var(--cl-border);
  border-radius: 16px;
  background: rgba(0, 0, 0, 0.05);
  color: var(--cl-text);
  font-size: 0.84rem;
  font-weight: 850;
}

[data-theme='dark'] .make-check-toggle {
  background: rgba(255, 255, 255, 0.025);
}

.make-check-toggle input {
  width: 1rem;
  height: 1rem;
  accent-color: var(--make-accent-strong);
}

.make-handoff {
  display: grid;
  gap: 1rem;
}

.make-finish-hero {
  display: grid;
  gap: 0.32rem;
  padding: 0.95rem;
  border: 1px solid rgba(20, 184, 166, 0.30);
  border-radius: 22px;
  background:
    radial-gradient(circle at 0% 0%, rgba(20, 184, 166, 0.15), transparent 48%),
    var(--make-panel);
}

.make-finish-hero strong {
  color: var(--cl-text);
  font-size: 1.05rem;
}

.make-finish-hero p {
  max-width: 68rem;
  margin: 0;
  color: var(--cl-muted);
  line-height: 1.5;
}

.make-handoff-steps {
  display: grid;
  gap: 0.65rem;
}

.make-handoff-step {
  display: grid;
  grid-template-columns: auto minmax(0, 1fr);
  gap: 0.75rem;
  align-items: center;
  padding: 0.7rem;
  border: 1px solid var(--cl-border);
  border-radius: 18px;
  background: var(--make-panel);
}

.make-handoff-step span {
  display: grid;
  width: 1.7rem;
  height: 1.7rem;
  place-items: center;
  border-radius: 999px;
  background: var(--make-accent-strong);
  color: #04110f;
  font-size: 0.78rem;
  font-weight: 950;
}

.make-handoff-step p {
  margin: 0;
  color: var(--cl-muted);
