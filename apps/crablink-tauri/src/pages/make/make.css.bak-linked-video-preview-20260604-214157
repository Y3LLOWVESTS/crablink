}

.make-tone-success {
  border-color: rgba(20, 184, 166, 0.34);
}

.make-tone-warning {
  border-color: rgba(245, 158, 11, 0.34);
}

.make-tone-danger {
  border-color: rgba(239, 68, 68, 0.34);
}

.make-stat-grid {
  display: grid;
  grid-template-columns: repeat(1, minmax(0, 1fr));
  gap: 0.65rem;
}

.make-stat-grid-two {
  grid-template-columns: repeat(2, minmax(0, 1fr));
}

.make-boundary-list {
  display: grid;
  gap: 0.5rem;
  margin: 0;
  padding-left: 1.1rem;
  color: var(--cl-muted);
  line-height: 1.45;
}

.make-boundary-list li::marker {
  color: var(--make-accent-strong);
}

.make-pipeline-list {
  display: grid;
  gap: 0.45rem;
}

.make-pipeline-list span {
  display: flex;
  align-items: center;
  gap: 0.55rem;
  padding: 0.65rem 0.75rem;
  border: 1px solid var(--cl-border);
  border-radius: 16px;
  background: var(--make-panel);
  color: var(--cl-text);
  font-size: 0.86rem;
  font-weight: 850;
}

.make-pipeline-list span::before {
  width: 0.55rem;
  height: 0.55rem;
  border-radius: 999px;
  background: var(--make-accent-strong);
  box-shadow: 0 0 0 5px var(--make-glow);
  content: '';
}

.make-side-copy {
  margin: 0;
  color: var(--cl-muted);
  line-height: 1.5;
}

@media (max-width: 1280px) {
  .make-command-deck {
    grid-template-columns: 1fr;
  }

  .make-command-actions {
    justify-content: flex-start;
  }

  .make-preset-grid {
    grid-template-columns: repeat(3, minmax(0, 1fr));
  }

  .make-prompter-toggle-row {
    grid-template-columns: 1fr;
  }

  .make-mode-deck {
    grid-template-columns: repeat(2, minmax(0, 1fr));
  }

  .make-mode-card:last-child {
    grid-column: 1 / -1;
  }
}

@media (max-width: 980px) {
  .make-side-stack {
    position: static;
    max-height: none;
    overflow: visible;
    padding-right: 0;
  }

  .make-project-prime,
  .make-form-grid,
  .make-toggle-grid,
  .make-sequence-grid,
  .make-selected-clip {
    grid-template-columns: 1fr;
  }

  .make-command-actions .cl-button,
  .make-handoff-actions .cl-button,
  .make-button-row .cl-button {
    flex: 1 1 auto;
  }
}

@media (max-width: 680px) {
  .make-preview-canvas {
    max-height: 58vh;
  }

  .make-preset-grid,
  .make-mode-deck,
  .make-stat-grid-two {
    grid-template-columns: 1fr;
  }

  .make-section-kicker {
    align-items: start;
    flex-direction: column;
  }

  .make-preview-topbar {
    max-width: calc(100% - 2rem);
  }

  .make-prompter-overlay {
    right: 0.75rem;
    left: 0.75rem;
    padding: 0.65rem 0.75rem;
  }

  .make-prompter-top {
    top: 5.9rem;
  }

  .make-prompter-bottom {
    bottom: 5.8rem;
  }

  .make-prompter-controls {
    right: 0.75rem;
    bottom: 0.75rem;
    left: 0.75rem;
    justify-content: space-between;
  }

  .make-prompter-editor-head {
    flex-direction: column;
  }

  .make-recording-badge {
    top: auto;
    right: 1rem;
    bottom: 1rem;
  }

  .make-command-stats {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
  }
}
/* Make Studio person cutout/background replacement controls — append to make.css. */

.make-cutout-card {
  display: grid;
  gap: 1rem;
  padding: 1rem;
  border: 1px solid rgba(148, 163, 184, 0.24);
  border-radius: 24px;
  background:
    radial-gradient(circle at 0% 0%, rgba(20, 184, 166, 0.14), transparent 30%),
    linear-gradient(135deg, rgba(15, 23, 42, 0.66), rgba(2, 6, 23, 0.46));
  box-shadow: 0 22px 60px rgba(2, 6, 23, 0.18);
}

.make-cutout-head {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 1rem;
}

.make-cutout-head h3 {
  margin: 0.1rem 0 0;
  font-size: 1rem;
}

.make-cutout-head p {
  max-width: 62rem;
  margin: 0.35rem 0 0;
  color: var(--cl-muted, #94a3b8);
  font-size: 0.88rem;
  line-height: 1.5;
}

.make-cutout-grid {
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 0.85rem;
  align-items: stretch;
}

.make-switch-row {
  display: flex;
  align-items: flex-start;
  gap: 0.8rem;
  min-height: 100%;
  padding: 0.85rem;
  border: 1px solid rgba(148, 163, 184, 0.22);
  border-radius: 18px;
  background: rgba(15, 23, 42, 0.38);
}

.make-switch-row-tight {
  align-items: center;
}

.make-switch-row input[type='checkbox'] {
  width: 1.05rem;
  height: 1.05rem;
  margin-top: 0.12rem;
  accent-color: var(--make-accent-strong);
}

.make-switch-row strong {
  display: block;
  color: var(--cl-text, #f8fafc);
  font-size: 0.9rem;
}

.make-switch-row small {
  display: block;
  margin-top: 0.22rem;
  color: var(--cl-muted, #94a3b8);
  font-size: 0.78rem;
  line-height: 1.35;
}

.make-background-picker-row {
  display: flex;
  flex-wrap: wrap;
  align-items: center;
  gap: 0.7rem;
}

.make-background-picker {
  position: relative;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-height: 2.4rem;
  padding: 0.62rem 0.85rem;
  border: 1px solid rgba(148, 163, 184, 0.28);
  border-radius: 999px;
  color: var(--cl-text, #f8fafc);
  background: rgba(15, 23, 42, 0.54);
  cursor: pointer;
  font-size: 0.84rem;
  font-weight: 700;
}

.make-background-picker:hover {
  border-color: rgba(20, 184, 166, 0.58);
  background: rgba(20, 184, 166, 0.13);
}

.make-background-picker input {
  position: absolute;
  inset: 0;
  opacity: 0;
  cursor: pointer;
}

.make-background-picker input:disabled {
  cursor: not-allowed;
}

.make-cutout-foot {
  display: flex;
  flex-wrap: wrap;
  gap: 0.65rem;
  color: var(--cl-muted, #94a3b8);
  font-size: 0.78rem;
}

.make-cutout-foot span {
  padding: 0.36rem 0.58rem;
  border: 1px solid rgba(148, 163, 184, 0.18);
  border-radius: 999px;
  background: rgba(2, 6, 23, 0.34);
}

.make-cutout-foot strong {
  color: var(--cl-text, #f8fafc);
}

@media (max-width: 1100px) {
  .make-cutout-grid {
    grid-template-columns: repeat(2, minmax(0, 1fr));
  }
}

@media (max-width: 760px) {
  .make-cutout-head {
    flex-direction: column;
  }

  .make-cutout-grid {
    grid-template-columns: 1fr;
  }
}


/* Make Studio cutout range controls — object URL/image patch. */
.make-range-control {
  display: grid;
  grid-template-columns: minmax(0, 1fr) auto;
  align-items: center;
  gap: 0.75rem;
  min-height: 2.45rem;
}

.make-range-input {
  width: 100%;
  min-width: 0;
  accent-color: var(--make-accent-strong, #14b8a6);
  cursor: pointer;
  pointer-events: auto;
}

.make-range-input:disabled {
  cursor: not-allowed;
  opacity: 0.55;
}

.make-range-value {
  min-width: 4.25rem;
  padding: 0.35rem 0.55rem;
  border: 1px solid rgba(148, 163, 184, 0.2);
  border-radius: 999px;
  color: var(--cl-text, #f8fafc);
  background: rgba(2, 6, 23, 0.42);
  font-size: 0.78rem;
  text-align: center;
}

.make-cutout-grid .make-range-control {
  padding: 0.72rem 0.85rem;
  border: 1px solid rgba(148, 163, 184, 0.18);
  border-radius: 18px;
  background: rgba(15, 23, 42, 0.28);
}


/* Make Studio direct preview controls.
   These are DOM overlays above the canvas, so canvas.captureStream() never records them. */
.make-subject-overlay {
  position: absolute;
  inset: 0;
  z-index: 9;
  cursor: grab;
  touch-action: none;
  user-select: none;
}

.make-subject-overlay:active {
  cursor: grabbing;
}

.make-subject-overlay.is-disabled {
  cursor: default;
  pointer-events: none;
}

.make-subject-drag-hint {
  position: absolute;
  left: 50%;
  bottom: 5.2rem;
  display: inline-flex;
  align-items: center;
  gap: 0.45rem;
  padding: 0.42rem 0.68rem;
  border: 1px solid rgba(148, 163, 184, 0.28);
  border-radius: 999px;
  color: rgba(248, 250, 252, 0.88);
  background: rgba(2, 6, 23, 0.58);
  box-shadow: 0 18px 40px rgba(2, 6, 23, 0.22);
  font-size: 0.78rem;
  opacity: 0;
  transform: translate(-50%, 8px);
  transition: opacity 160ms ease, transform 160ms ease;
  pointer-events: none;
}

.make-subject-drag-hint span {
  width: 0.48rem;
  height: 0.48rem;
  border-radius: 999px;
  background: var(--make-accent-strong, #14b8a6);
  box-shadow: 0 0 0 0.3rem rgba(20, 184, 166, 0.18);
}

.make-subject-overlay.is-visible .make-subject-drag-hint {
  opacity: 1;
  transform: translate(-50%, 0);
}

.make-subject-zoom-popover {
  position: absolute;
  left: 50%;
  top: 50%;
  display: inline-flex;
  align-items: center;
  gap: 0.5rem;
  padding: 0.48rem;
  border: 1px solid rgba(148, 163, 184, 0.28);
  border-radius: 999px;
  background: rgba(2, 6, 23, 0.72);
  box-shadow: 0 24px 60px rgba(2, 6, 23, 0.38);
  backdrop-filter: blur(14px);
  opacity: 0;
  transform: translate(-50%, -50%) scale(0.92);
  transition: opacity 160ms ease, transform 160ms ease;
  pointer-events: none;
}

.make-subject-zoom-popover.is-visible {
  opacity: 1;
  transform: translate(-50%, -50%) scale(1);
  pointer-events: auto;
}

.make-subject-zoom-popover button {
  display: inline-grid;
  place-items: center;
  width: 2.45rem;
  height: 2.45rem;
  border: 1px solid rgba(148, 163, 184, 0.28);
  border-radius: 999px;
  color: #f8fafc;
  background: rgba(15, 23, 42, 0.88);
  cursor: pointer;
  font-size: 1.45rem;
  font-weight: 900;
  line-height: 1;
}

.make-subject-zoom-popover button:hover:not(:disabled) {
  border-color: rgba(20, 184, 166, 0.68);
  background: rgba(20, 184, 166, 0.22);
}

.make-subject-zoom-popover button:disabled {
  cursor: not-allowed;
  opacity: 0.5;
}

.make-subject-zoom-popover span {
  min-width: 3.6rem;
  color: #f8fafc;
  font-size: 0.85rem;
  font-weight: 800;
  text-align: center;
}

.make-subject-transform-readout {
  position: absolute;
  right: 1.2rem;
  bottom: 5.2rem;
  padding: 0.38rem 0.58rem;
  border: 1px solid rgba(148, 163, 184, 0.22);
  border-radius: 999px;
  color: rgba(248, 250, 252, 0.82);
  background: rgba(2, 6, 23, 0.58);
  font-size: 0.74rem;
  font-weight: 800;
  opacity: 0;
  transform: translateY(8px);
  transition: opacity 160ms ease, transform 160ms ease;
  pointer-events: none;
}

.make-subject-transform-readout.is-visible {
  opacity: 1;
  transform: translateY(0);
}

.make-debug-event-list {
  display: grid;
  gap: 0.45rem;
  max-height: 280px;
  overflow: auto;
}

.make-debug-event-list > span {
  color: var(--cl-muted, #858585);
  font-size: 0.85rem;
  font-weight: 700;
}

.make-debug-event-list details {
  border: 1px solid var(--cl-border, rgba(120, 120, 120, 0.24));
  border-radius: 12px;
  padding: 0.55rem 0.65rem;
  background: color-mix(in srgb, var(--cl-card, #ffffff) 76%, var(--cl-bg, #f5f5f5) 24%);
}

[data-theme='dark'] .make-debug-event-list details {
  background: rgba(255, 255, 255, 0.035);
}

.make-debug-event-list summary {
  cursor: pointer;
  color: var(--cl-text, #f5f5f5);
  font-size: 0.78rem;
  font-weight: 850;
}

.make-debug-event-list pre {
  white-space: pre-wrap;
  overflow-wrap: anywhere;
  margin: 0.55rem 0 0;
  color: var(--cl-muted, #a8a8a8);
  font-size: 0.72rem;
  line-height: 1.45;
}


.make-export-status {
