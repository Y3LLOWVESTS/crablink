  padding-right: 0.15rem;
  scrollbar-width: thin;
}

.make-side-card .cl-card-body {
  display: grid;
  gap: 0.85rem;
}

.make-side-hero-stat {
  display: grid;
  gap: 0.2rem;
  padding: 0.95rem;
  border: 1px solid rgba(20, 184, 166, 0.32);
  border-radius: 22px;
  background:
    radial-gradient(circle at 10% 0%, rgba(20, 184, 166, 0.16), transparent 50%),
    var(--make-panel);
}

.make-side-hero-stat strong {
  color: var(--cl-text);
  font-size: 1.7rem;
  line-height: 1;
}

.make-side-hero-stat span {
  color: var(--cl-muted);
  font-weight: 850;
}

.make-compact-status-list {
  display: grid;
  gap: 0.55rem;
}

.make-compact-status {
  display: grid;
  grid-template-columns: minmax(0, 0.9fr) auto;
  gap: 0.15rem 0.6rem;
  padding: 0.72rem 0.78rem;
  border: 1px solid var(--cl-border);
  border-radius: 18px;
  background: rgba(0, 0, 0, 0.04);
}

[data-theme='dark'] .make-compact-status {
  background: rgba(255, 255, 255, 0.025);
}

.make-compact-status span {
  color: var(--cl-muted);
  font-size: 0.72rem;
  font-weight: 950;
  letter-spacing: 0.07em;
  text-transform: uppercase;
}

.make-compact-status strong {
  color: var(--cl-text);
  font-weight: 950;
  text-align: right;
}

.make-compact-status small {
  grid-column: 1 / -1;
