.make-export-status-head {
  display: flex;
  gap: 0.75rem;
  align-items: center;
  justify-content: space-between;
}

.make-export-status-head strong {
  color: var(--cl-text);
}

.make-export-status-head span,
.make-export-status p {
  margin: 0;
