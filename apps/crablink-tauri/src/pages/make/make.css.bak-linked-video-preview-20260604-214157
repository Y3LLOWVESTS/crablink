}

.make-prompter-editor-head {
  display: flex;
  gap: 1rem;
  align-items: start;
  justify-content: space-between;
}

.make-prompter-editor-head h3,
.make-prompter-editor-head p {
  margin: 0;
}

.make-prompter-editor-head h3 {
  color: var(--cl-text);
  font-size: 1rem;
  font-weight: 950;
}

.make-prompter-editor-head span {
