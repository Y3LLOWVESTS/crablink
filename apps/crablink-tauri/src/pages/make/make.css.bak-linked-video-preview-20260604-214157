  font-size: 0.76rem;
  font-weight: 950;
  letter-spacing: 0.08em;
  text-transform: uppercase;
}

.make-sequence-now strong {
  overflow: hidden;
  color: var(--cl-text);
  text-overflow: ellipsis;
  white-space: nowrap;
}

.make-approved-box {
  display: grid;
  gap: 0.22rem;
  padding: 0.78rem 0.85rem;
  border: 1px solid rgba(34, 197, 94, 0.38);
  border-radius: 18px;
  background: rgba(34, 197, 94, 0.10);
}

.make-approved-box strong {
  color: var(--cl-text);
}

.make-approved-box span {
  color: var(--cl-muted);
  line-height: 1.45;
}

.make-latest-decision {
  display: grid;
  gap: 0.18rem;
  padding: 0.72rem 0.78rem;
  border: 1px solid rgba(20, 184, 166, 0.34);
  border-radius: 18px;
  background: var(--make-accent-soft);
}

.make-latest-decision strong {
  color: var(--cl-text);
  font-size: 0.9rem;
}

.make-latest-decision span {
  color: var(--cl-muted);
  font-size: 0.78rem;
  font-weight: 800;
}

.make-prompter-editor {
  display: grid;
  gap: 0.85rem;
  padding: 0.95rem;
  border: 1px solid rgba(20, 184, 166, 0.28);
  border-radius: 24px;
  background:
