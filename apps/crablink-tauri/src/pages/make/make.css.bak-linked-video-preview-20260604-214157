/*
 * RO:WHAT — Styles for the route-owned crab://make local creator studio.
 * RO:WHY — App Integration; Concerns: DX/SEC; gives Make a flagship studio surface without backend authority.
 * RO:INTERACTS — MakePage.jsx, shared card/form/button/stat components, theme tokens.
 * RO:INVARIANTS — visual/local state only; no backend truth; no wallet, receipt, CID, or paid-entitlement styling claims.
 * RO:TEST — manual crab://make smoke in light/dark mode, camera/screen/PiP/audio-card modes.
 */

.make-page {
  --make-accent: #0f766e;
  --make-accent-strong: #14b8a6;
  --make-accent-soft: rgba(20, 184, 166, 0.12);
  --make-danger: #ef4444;
  --make-warning: #f59e0b;
  --make-glow: rgba(20, 184, 166, 0.24);
  --make-panel: rgba(255, 255, 255, 0.035);
  --make-panel-strong: rgba(255, 255, 255, 0.065);
}

.make-shell {
  display: grid;
  gap: 1rem;
}

.make-flagship-card {
  position: relative;
  overflow: hidden;
}

.make-flagship-card::before {
  position: absolute;
  inset: 0;
  z-index: 0;
  pointer-events: none;
  background:
    radial-gradient(circle at 12% 0%, rgba(20, 184, 166, 0.14), transparent 34%),
    radial-gradient(circle at 100% 8%, rgba(99, 102, 241, 0.12), transparent 32%);
  content: '';
}

.make-flagship-card > * {
  position: relative;
  z-index: 1;
}

.make-command-deck {
  position: relative;
  display: grid;
  grid-template-columns: minmax(0, 1.25fr) minmax(320px, 0.85fr) auto;
  gap: 1rem;
  align-items: center;
  padding: 1rem;
  border: 1px solid var(--cl-border);
  border-radius: 30px;
  background:
    radial-gradient(circle at 9% 0%, rgba(20, 184, 166, 0.22), transparent 30%),
    linear-gradient(135deg, rgba(255, 255, 255, 0.075), rgba(255, 255, 255, 0.025));
  box-shadow: 0 24px 80px rgba(0, 0, 0, 0.22);
}

[data-theme='dark'] .make-command-deck {
  background:
    radial-gradient(circle at 9% 0%, rgba(20, 184, 166, 0.20), transparent 30%),
    linear-gradient(135deg, rgba(255, 255, 255, 0.06), rgba(255, 255, 255, 0.018)),
    #050505;
}

.make-command-main {
  display: flex;
  gap: 0.9rem;
  align-items: center;
  min-width: 0;
}

.make-orb {
  display: grid;
  flex: 0 0 auto;
  width: 3.4rem;
  height: 3.4rem;
  place-items: center;
  border: 1px solid rgba(20, 184, 166, 0.38);
  border-radius: 22px;
  background:
    radial-gradient(circle at 35% 25%, rgba(255, 255, 255, 0.75), transparent 18%),
    linear-gradient(135deg, rgba(20, 184, 166, 0.88), rgba(15, 118, 110, 0.35));
  box-shadow: 0 0 0 8px var(--make-glow);
}

.make-orb span {
  width: 1.1rem;
  height: 1.1rem;
  border-radius: 999px;
  background: #06130f;
  box-shadow: inset 0 0 0 3px rgba(255, 255, 255, 0.32);
}

.make-command-main h2,
.make-command-main p,
.make-now-recording {
  margin: 0;
}

.make-command-main h2 {
  overflow: hidden;
  color: var(--cl-text);
  font-size: clamp(1.3rem, 1.8vw, 2.05rem);
  line-height: 1.05;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.make-command-main p {
  color: var(--cl-muted);
  line-height: 1.45;
}

.make-command-stats,
.make-command-actions,
.make-card-actions,
.make-button-row,
.make-clip-stats,
.make-handoff-actions {
  display: flex;
  flex-wrap: wrap;
  gap: 0.55rem;
  align-items: center;
}

.make-command-actions {
  justify-content: flex-end;
}

.make-stat-pill {
  display: inline-grid;
  gap: 0.15rem;
  min-width: 5.4rem;
  padding: 0.62rem 0.75rem;
  border: 1px solid var(--cl-border);
  border-radius: 18px;
  background: rgba(0, 0, 0, 0.16);
}

[data-theme='dark'] .make-stat-pill {
  background: rgba(255, 255, 255, 0.035);
}

.make-stat-pill small {
  color: var(--cl-muted);
  font-size: 0.68rem;
  font-weight: 950;
  letter-spacing: 0.07em;
  text-transform: uppercase;
}

.make-stat-pill strong {
  overflow: hidden;
  color: var(--cl-text);
  font-size: 0.92rem;
  font-weight: 950;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.make-now-recording {
  grid-column: 1 / -1;
  display: inline-flex;
  width: fit-content;
  align-items: center;
  gap: 0.45rem;
  padding: 0.45rem 0.65rem;
  border: 1px solid rgba(239, 68, 68, 0.36);
  border-radius: 999px;
  background: rgba(239, 68, 68, 0.11);
  color: var(--cl-text);
  font-size: 0.78rem;
  font-weight: 900;
}

.make-now-recording span {
  width: 0.5rem;
  height: 0.5rem;
  border-radius: 999px;
  background: var(--make-danger);
}

.make-preview-card .cl-card-body {
  display: grid;
  gap: 1rem;
}

.make-preview-shell {
  position: relative;
  overflow: hidden;
  width: 100%;
  border: 1px solid var(--cl-border);
  border-radius: 30px;
  background:
    radial-gradient(circle at 20% 20%, rgba(20, 184, 166, 0.18), transparent 34%),
    radial-gradient(circle at 80% 30%, rgba(99, 102, 241, 0.16), transparent 38%),
    #050508;
  box-shadow: 0 26px 80px rgba(0, 0, 0, 0.24);
}

.make-preview-canvas {
  display: block;
  width: 100%;
  max-height: min(68vh, 760px);
  aspect-ratio: 16 / 9;
  object-fit: contain;
  background: #050508;
}

.make-hidden-video {
  position: absolute;
  width: 1px;
  height: 1px;
  opacity: 0;
  pointer-events: none;
}

.make-preview-topbar {
  position: absolute;
  top: 1rem;
  left: 1rem;
  display: flex;
  flex-wrap: wrap;
  gap: 0.45rem;
  max-width: calc(100% - 10rem);
}

.make-preview-topbar span {
  padding: 0.45rem 0.62rem;
  border: 1px solid rgba(255, 255, 255, 0.14);
  border-radius: 999px;
  background: rgba(0, 0, 0, 0.55);
  color: #fff;
  font-size: 0.72rem;
  font-weight: 950;
  letter-spacing: 0.05em;
  text-transform: uppercase;
}

.make-recording-badge {
  position: absolute;
  top: 1rem;
  right: 1rem;
  display: inline-flex;
  align-items: center;
  gap: 0.5rem;
  padding: 0.55rem 0.75rem;
  border: 1px solid rgba(255, 255, 255, 0.18);
  border-radius: 999px;
  background: rgba(0, 0, 0, 0.68);
  color: #fff;
  font-size: 0.82rem;
  font-weight: 900;
  letter-spacing: 0.03em;
  text-transform: uppercase;
}

.make-recording-badge span {
  width: 0.62rem;
  height: 0.62rem;
  border-radius: 999px;
  background: var(--make-danger);
  box-shadow: 0 0 0 0 rgba(239, 68, 68, 0.78);
  animation: make-rec-pulse 1.15s infinite;
}

.make-prompter-overlay {
  position: absolute;
  z-index: 2;
  right: clamp(1rem, 8vw, 6rem);
  left: clamp(1rem, 8vw, 6rem);
  display: grid;
  gap: 0.42rem;
  padding: 0.85rem 1rem;
  border: 1px solid rgba(255, 255, 255, 0.18);
  border-radius: 24px;
  background:
    linear-gradient(180deg, rgba(0, 0, 0, 0.72), rgba(0, 0, 0, 0.50)),
    rgba(20, 184, 166, 0.10);
  color: #fff;
  pointer-events: none;
  box-shadow: 0 22px 64px rgba(0, 0, 0, 0.26);
  backdrop-filter: blur(10px);
}

.make-prompter-top {
  top: 4.75rem;
}

.make-prompter-bottom {
  bottom: 5.4rem;
}

.make-prompter-window {
  overflow: hidden;
  max-height: clamp(5rem, 20vw, 12rem);
  mask-image: linear-gradient(to bottom, transparent, #000 14%, #000 82%, transparent);
}

.make-prompter-overlay pre {
  margin: 0;
  color: #fff;
  font-family: inherit;
  font-size: clamp(1.05rem, 2vw, 2.15rem);
  font-weight: 900;
  line-height: 1.35;
  text-align: center;
  white-space: pre-wrap;
  transform: translateY(0);
}

.make-prompter-overlay.is-running pre {
  animation: make-prompter-scroll var(--make-prompter-duration, 72s) linear infinite;
}

.make-prompter-overlay span {
  color: rgba(255, 255, 255, 0.66);
  font-size: 0.66rem;
  font-weight: 950;
  letter-spacing: 0.08em;
  text-align: center;
  text-transform: uppercase;
}

.make-prompter-controls {
  position: absolute;
  right: 1rem;
  bottom: 1rem;
  z-index: 3;
  display: inline-flex;
  gap: 0.55rem;
  align-items: center;
  max-width: min(30rem, calc(100% - 2rem));
  padding: 0.48rem 0.55rem 0.48rem 0.72rem;
  border: 1px solid rgba(20, 184, 166, 0.36);
  border-radius: 999px;
  background: rgba(0, 0, 0, 0.68);
  color: rgba(255, 255, 255, 0.82);
  font-size: 0.72rem;
  font-weight: 950;
  letter-spacing: 0.06em;
  text-transform: uppercase;
  backdrop-filter: blur(10px);
}

.make-prompter-controls button {
  padding: 0.34rem 0.62rem;
  border: 0;
  border-radius: 999px;
  background: #fff;
  color: #050505;
  cursor: pointer;
  font: inherit;
}

@keyframes make-prompter-scroll {
  from {
    transform: translateY(22%);
  }

  to {
    transform: translateY(-76%);
  }
}

.make-countdown-overlay {
  position: absolute;
  inset: 0;
  z-index: 4;
  display: grid;
  place-items: center;
  background:
    radial-gradient(circle at 50% 46%, rgba(20, 184, 166, 0.24), transparent 22%),
    rgba(0, 0, 0, 0.62);
  color: #fff;
  text-align: center;
  backdrop-filter: blur(4px);
}

.make-countdown-overlay strong {
  display: grid;
  width: clamp(6rem, 16vw, 10rem);
  height: clamp(6rem, 16vw, 10rem);
  place-items: center;
  border: 1px solid rgba(255, 255, 255, 0.24);
  border-radius: 999px;
  background: rgba(0, 0, 0, 0.42);
  box-shadow: 0 0 0 14px rgba(20, 184, 166, 0.12);
  font-size: clamp(4rem, 10vw, 7rem);
  font-weight: 1000;
  line-height: 1;
}

.make-countdown-overlay span {
  margin-top: 1rem;
  color: rgba(255, 255, 255, 0.82);
  font-size: 0.82rem;
  font-weight: 950;
  letter-spacing: 0.08em;
  text-transform: uppercase;
}

@keyframes make-rec-pulse {
  0% { box-shadow: 0 0 0 0 rgba(239, 68, 68, 0.78); }
  70% { box-shadow: 0 0 0 10px rgba(239, 68, 68, 0); }
  100% { box-shadow: 0 0 0 0 rgba(239, 68, 68, 0); }
}

.make-preset-deck {
  display: grid;
  gap: 0.75rem;
  padding: 0.85rem;
  border: 1px solid var(--cl-border);
  border-radius: 26px;
  background:
    radial-gradient(circle at 0% 0%, rgba(20, 184, 166, 0.10), transparent 38%),
    var(--make-panel);
}

.make-section-kicker {
  display: flex;
  gap: 0.75rem;
  align-items: end;
  justify-content: space-between;
}

.make-section-kicker h3,
.make-section-kicker p {
  margin: 0;
}

.make-section-kicker h3 {
  color: var(--cl-text);
  font-size: 1rem;
}

.make-section-kicker small {
  color: var(--cl-muted);
  font-size: 0.76rem;
  font-weight: 850;
}

.make-preset-grid {
  display: grid;
  grid-template-columns: repeat(6, minmax(0, 1fr));
  gap: 0.6rem;
}

.make-preset-card {
  display: grid;
  align-content: start;
  gap: 0.36rem;
  min-height: 8.25rem;
  padding: 0.75rem;
  border: 1px solid var(--cl-border);
  border-radius: 20px;
  background:
    linear-gradient(145deg, rgba(255, 255, 255, 0.055), rgba(255, 255, 255, 0.018));
  color: var(--cl-text);
  cursor: pointer;
  text-align: left;
  transition:
    border-color 160ms ease,
    background 160ms ease,
    transform 160ms ease,
    box-shadow 160ms ease;
}

.make-preset-card:hover:not(:disabled),
.make-preset-card.is-active {
  border-color: rgba(20, 184, 166, 0.58);
  background:
    radial-gradient(circle at 0% 0%, rgba(20, 184, 166, 0.18), transparent 42%),
    var(--make-accent-soft);
  box-shadow: 0 18px 44px rgba(20, 184, 166, 0.10);
  transform: translateY(-1px);
}

.make-preset-card:disabled {
  cursor: not-allowed;
  opacity: 0.68;
}

.make-preset-eye {
  width: fit-content;
  padding: 0.22rem 0.45rem;
  border: 1px solid rgba(20, 184, 166, 0.28);
  border-radius: 999px;
  background: rgba(20, 184, 166, 0.10);
  color: var(--make-accent-strong);
  font-size: 0.62rem;
  font-weight: 950;
  letter-spacing: 0.07em;
  text-transform: uppercase;
}

.make-preset-card strong {
  color: var(--cl-text);
  font-size: 0.92rem;
  font-weight: 950;
}

.make-preset-card small {
  display: -webkit-box;
  overflow: hidden;
  color: var(--cl-muted);
  font-size: 0.72rem;
  line-height: 1.35;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 3;
}

.make-mode-deck {
  display: grid;
  grid-template-columns: repeat(5, minmax(0, 1fr));
  gap: 0.7rem;
}

.make-mode-card {
  display: grid;
  grid-template-columns: auto minmax(0, 1fr);
  gap: 0.65rem;
  align-items: center;
  min-height: 5.8rem;
  padding: 0.78rem;
  border: 1px solid var(--cl-border);
  border-radius: 22px;
  background: var(--make-panel);
  color: var(--cl-text);
  cursor: pointer;
  text-align: left;
  transition:
    border-color 160ms ease,
    background 160ms ease,
    transform 160ms ease,
    box-shadow 160ms ease;
}

.make-mode-card:hover:not(:disabled),
.make-mode-card.is-active {
  border-color: rgba(20, 184, 166, 0.55);
  background: var(--make-accent-soft);
  box-shadow: 0 16px 40px rgba(20, 184, 166, 0.08);
  transform: translateY(-1px);
}

.make-mode-card:disabled {
  cursor: not-allowed;
  opacity: 0.72;
}

.make-mode-icon {
  display: grid;
  width: 2.1rem;
  height: 2.1rem;
  place-items: center;
  border: 1px solid rgba(20, 184, 166, 0.32);
  border-radius: 15px;
  background: rgba(20, 184, 166, 0.10);
  color: var(--make-accent-strong);
  font-weight: 950;
}

.make-mode-text {
  display: grid;
  gap: 0.22rem;
  min-width: 0;
}

.make-mode-text strong {
  color: var(--cl-text);
  font-size: 0.9rem;
  font-weight: 950;
}

.make-mode-text small {
  display: -webkit-box;
  overflow: hidden;
  color: var(--cl-muted);
  font-size: 0.73rem;
  line-height: 1.35;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
}

.make-alert {
  margin: 0;
  padding: 0.8rem 0.9rem;
  border: 1px solid var(--cl-border);
  border-radius: 18px;
  color: var(--cl-text);
  font-weight: 750;
  line-height: 1.45;
}

.make-alert-danger {
  border-color: rgba(239, 68, 68, 0.4);
  background: rgba(239, 68, 68, 0.11);
}

.make-alert-warning {
  border-color: rgba(245, 158, 11, 0.42);
  background: rgba(245, 158, 11, 0.12);
}

.make-timeline-card .cl-card-body,
.make-sequence-card .cl-card-body,
.make-project-card .cl-card-body,
.make-handoff-card .cl-card-body {
  display: grid;
  gap: 1rem;
}

.make-timeline-summary {
  display: flex;
  flex-wrap: wrap;
  gap: 0.55rem;
  align-items: center;
}

.make-empty-timeline {
  display: grid;
  gap: 0.5rem;
  justify-items: center;
  padding: 1.35rem;
  border: 1px dashed var(--cl-border);
  border-radius: 24px;
  background:
    radial-gradient(circle at 50% 0%, rgba(20, 184, 166, 0.10), transparent 45%),
    var(--make-panel);
  color: var(--cl-muted);
  text-align: center;
}

.make-empty-timeline strong {
  color: var(--cl-text);
}

.make-empty-timeline p {
  max-width: 42rem;
  margin: 0;
}

.make-empty-timeline-art {
  display: flex;
  gap: 0.35rem;
  align-items: end;
  height: 2.6rem;
}

.make-empty-timeline-art span {
  width: 4.8rem;
  border: 1px solid rgba(20, 184, 166, 0.28);
  border-radius: 12px;
  background: rgba(20, 184, 166, 0.10);
}

.make-empty-timeline-art span:nth-child(1) { height: 1.4rem; }
.make-empty-timeline-art span:nth-child(2) { height: 2.3rem; }
.make-empty-timeline-art span:nth-child(3) { height: 1.75rem; }

.make-timeline-layout {
  display: grid;
  gap: 1rem;
}

.make-clip-strip {
  display: grid;
  grid-auto-columns: minmax(210px, 1fr);
  grid-auto-flow: column;
  gap: 0.7rem;
  overflow-x: auto;
  padding-bottom: 0.25rem;
  scrollbar-width: thin;
}

.make-strip-item {
  display: grid;
  gap: 0.25rem;
  min-width: 0;
  padding: 0.78rem;
  border: 1px solid var(--cl-border);
  border-radius: 20px;
  background: var(--make-panel);
  color: var(--cl-text);
  cursor: pointer;
  text-align: left;
}

.make-strip-item.is-selected {
  border-color: rgba(20, 184, 166, 0.62);
  background: var(--make-accent-soft);
  box-shadow: inset 0 0 0 1px rgba(20, 184, 166, 0.18);
}

.make-strip-number {
  display: grid;
  width: 1.6rem;
  height: 1.6rem;
  place-items: center;
  border-radius: 999px;
  background: var(--make-accent-strong);
  color: #04110f;
  font-size: 0.75rem;
  font-weight: 950;
}

.make-strip-name {
  overflow: hidden;
  color: var(--cl-text);
  font-weight: 950;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.make-strip-meta {
  color: var(--cl-muted);
  font-size: 0.78rem;
  font-weight: 800;
}

.make-selected-clip {
  display: grid;
  grid-template-columns: minmax(220px, 0.46fr) minmax(0, 1fr);
  gap: 0.9rem;
  padding: 0.85rem;
  border: 1px solid var(--cl-border);
  border-radius: 24px;
  background: var(--make-panel);
}

.make-selected-clip video {
  width: 100%;
  min-height: 190px;
  border: 1px solid var(--cl-border);
  border-radius: 20px;
  background: #000;
  object-fit: cover;
}

.make-selected-clip-body {
  display: grid;
  align-content: start;
  gap: 0.6rem;
  min-width: 0;
}

.make-selected-clip-body h3,
.make-selected-clip-body p {
  margin: 0;
}

.make-selected-clip-body h3 {
  overflow: hidden;
  color: var(--cl-text);
  font-size: 1.1rem;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.make-selected-clip-body p {
  color: var(--cl-muted);
  line-height: 1.5;
}

.make-sequence-grid {
  display: grid;
  grid-template-columns: minmax(260px, 0.58fr) minmax(0, 1fr);
  gap: 0.95rem;
  align-items: stretch;
}

.make-sequence-player-shell {
  display: grid;
  min-height: 260px;
  overflow: hidden;
  border: 1px solid var(--cl-border);
  border-radius: 24px;
  background:
    radial-gradient(circle at 50% 0%, rgba(20, 184, 166, 0.12), transparent 50%),
    #000;
}

.make-sequence-player-shell video {
  width: 100%;
  height: 100%;
  min-height: 260px;
  background: #000;
  object-fit: contain;
}

.make-sequence-monitor-shell {
  min-height: 220px;
  background:
    radial-gradient(circle at 30% 20%, rgba(20, 184, 166, 0.22), transparent 42%),
    linear-gradient(145deg, rgba(15, 23, 42, 0.94), rgba(2, 6, 23, 0.98));
}

.make-sequence-monitor-copy {
  display: grid;
  gap: 0.45rem;
  place-content: center;
  min-height: 220px;
  padding: 1.2rem;
  color: #fff;
  text-align: center;
}

.make-sequence-monitor-copy span {
  color: rgba(153, 246, 228, 0.86);
  font-size: 0.72rem;
  font-weight: 950;
  letter-spacing: 0.10em;
  text-transform: uppercase;
}

.make-sequence-monitor-copy strong {
  font-size: clamp(1rem, 2vw, 1.35rem);
  font-weight: 950;
}

.make-sequence-monitor-copy small {
  color: rgba(255, 255, 255, 0.66);
  font-weight: 850;
}

.make-sequence-empty {
  display: grid;
  gap: 0.35rem;
  place-content: center;
  padding: 1.2rem;
  color: var(--cl-muted);
  text-align: center;
}

.make-sequence-empty strong {
  color: var(--cl-text);
}

.make-sequence-panel {
  display: grid;
  align-content: start;
  gap: 0.75rem;
  min-width: 0;
  padding: 0.95rem;
  border: 1px solid var(--cl-border);
  border-radius: 24px;
  background: var(--make-panel);
}

.make-sequence-panel p {
  margin: 0;
  color: var(--cl-muted);
  line-height: 1.5;
}

.make-sequence-status-row {
  display: flex;
  flex-wrap: wrap;
  gap: 0.55rem;
  align-items: center;
  justify-content: space-between;
}

.make-sequence-status-row span,
.make-sequence-help {
