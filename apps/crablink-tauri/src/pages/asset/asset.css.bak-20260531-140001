/* Image manifest facts -------------------------------------------------------
   Displays intentional CrabLink image metadata as neat boxes instead of one
   long public-description blob. */

.asset-image-manifest-panel {
  display: grid;
  gap: 0.85rem;
  min-width: 0;
}

.asset-image-manifest-header {
  display: flex;
  flex-wrap: wrap;
  gap: 0.75rem;
  align-items: flex-start;
  justify-content: space-between;
  min-width: 0;
}

.asset-image-manifest-header > div:first-child {
  display: grid;
  gap: 0.2rem;
  min-width: min(100%, 260px);
}

.asset-image-manifest-header span,
.asset-image-manifest-fact span {
  display: block;
  color: var(--cl-muted, #626262);
  font-size: 0.72rem;
  font-weight: 950;
  letter-spacing: 0.06em;
  text-transform: uppercase;
}

.asset-image-manifest-header strong {
  color: var(--cl-text, #111111);
  font-size: 1rem;
  font-weight: 950;
  overflow-wrap: anywhere;
}

.asset-image-manifest-badges {
  display: flex;
  flex-wrap: wrap;
  gap: 0.45rem;
  justify-content: flex-end;
}

.asset-image-manifest-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 0.65rem;
  min-width: 0;
}

.asset-image-manifest-fact {
  display: grid;
  gap: 0.3rem;
  min-width: 0;
  padding: 0.72rem;
  border: 1px solid var(--asset-border-soft);
  border-radius: 16px;
  background: var(--asset-soft-bg);
}

.asset-image-manifest-fact.is-wide {
  grid-column: 1 / -1;
}

.asset-image-manifest-fact strong {
  color: var(--cl-text, #111111);
  font-size: 0.95rem;
  font-weight: 850;
  line-height: 1.45;
  overflow-wrap: anywhere;
}

.asset-image-manifest-note {
  margin: 0;
  color: var(--cl-muted, #626262);
  font-size: 0.86rem;
  line-height: 1.5;
}

@media (max-width: 760px) {
  .asset-image-manifest-grid {
    grid-template-columns: 1fr;
  }

  .asset-image-manifest-badges {
    justify-content: flex-start;
  }
}
/* Resolved image asset layout ------------------------------------------------
   The .image route uses the generic asset resolver, but it should not look like
   a generic backend diagnostics template. */

.asset-page.is-image-asset-page {
  width: min(1600px, 100%);
}

.asset-image-resolved-view {
  gap: 1rem;
}

.asset-image-top-grid {
  display: grid;
  grid-template-columns: minmax(0, 1.35fr) minmax(320px, 0.65fr);
  gap: 1rem;
  align-items: start;
  min-width: 0;
}

.asset-image-preview-card,
.asset-image-access-column,
.asset-image-mini-summary {
  min-width: 0;
}

.asset-image-access-column {
  display: grid;
  gap: 1rem;
}

.asset-image-preview-card .asset-image-preview-shell {
  min-height: clamp(320px, 54vh, 680px);
}

.asset-image-preview-card .asset-preview-empty {
  min-height: clamp(320px, 50vh, 620px);
}

.asset-image-mini-summary .asset-copy-actions {
  margin-top: 0.8rem;
}

.asset-detail-grid-muted {
  opacity: 0.92;
}

.asset-detail-grid-muted .cl-card {
  box-shadow: none;
}

@media (max-width: 1180px) {
  .asset-image-top-grid {
    grid-template-columns: 1fr;
  }
}

@media (max-width: 760px) {
  .asset-image-preview-card .asset-copy-actions,
  .asset-image-access-column .asset-copy-actions {
    width: 100%;
  }

  .asset-image-preview-card .asset-copy-actions .cl-button,
  .asset-image-access-column .asset-copy-actions .cl-copy-button {
    width: 100%;
  }
}

/* Professional resolved image layout -----------------------------------------
   Display-only refinement: no wallet/storage/index mutation and no paid-byte
   bypass. The image page is now product-first while technical truth remains
   available lower on the page. */

.asset-image-professional-view {
  gap: 1rem;
}

.asset-image-product-hero {
  display: grid;
  grid-template-columns: minmax(0, 1.55fr) minmax(360px, 0.45fr);
  gap: 1rem;
  align-items: start;
  min-width: 0;
}

.asset-image-product-preview,
.asset-image-access-column,
.asset-image-status-card {
  min-width: 0;
}

.asset-image-access-column {
  display: grid;
  gap: 1rem;
}

.asset-image-product-preview .asset-image-preview-shell,
.asset-image-product-preview .asset-preview-empty {
  min-height: clamp(360px, 58vh, 760px);
}

.asset-image-locked-preview {
  background:
    radial-gradient(circle at 50% 20%, color-mix(in srgb, var(--cl-warning, #a65f00) 7%, transparent), transparent 44%),
    var(--asset-soft-bg);
}

.asset-image-status-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 0.55rem;
}

.asset-image-status-grid > div {
  display: grid;
  gap: 0.2rem;
  min-width: 0;
  padding: 0.72rem;
  border: 1px solid var(--asset-border-soft);
  border-radius: 16px;
  background: var(--asset-soft-bg);
}

.asset-image-status-grid span,
.asset-image-manifest-document-header span,
.asset-image-manifest-callout span,
.asset-image-manifest-document-field span,
.asset-image-technical-details > summary span {
  display: block;
  color: var(--cl-muted, #626262);
  font-size: 0.72rem;
  font-weight: 950;
  letter-spacing: 0.065em;
  text-transform: uppercase;
}

.asset-image-status-grid strong {
  color: var(--cl-text, #111111);
  font-size: 1.18rem;
  font-weight: 980;
  overflow-wrap: anywhere;
}

.asset-image-status-actions {
  display: flex;
  flex-wrap: wrap;
  gap: 0.45rem;
  margin-top: 0.8rem;
}

.asset-image-status-note {
  margin: 0.8rem 0 0;
  color: var(--cl-muted, #626262);
  font-size: 0.88rem;
  line-height: 1.45;
}

.asset-image-manifest-document {
  display: grid;
  gap: 1rem;
  min-width: 0;
  padding: 1rem;
  border: 1px solid var(--asset-border-soft);
  border-radius: 28px;
  background:
    radial-gradient(circle at top left, color-mix(in srgb, var(--cl-success, #12805c) 7%, transparent), transparent 45%),
