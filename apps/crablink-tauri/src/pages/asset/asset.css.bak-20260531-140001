}

.asset-image-manifest-document-header {
  display: grid;
  grid-template-columns: minmax(0, 1fr) auto;
  gap: 1rem;
  align-items: start;
  min-width: 0;
}

.asset-image-manifest-title-stack {
  display: grid;
  gap: 0.35rem;
  min-width: 0;
}

.asset-image-manifest-title-stack h2 {
  margin: 0;
  color: var(--cl-text, #111111);
  font-size: clamp(1.6rem, 3vw, 3rem);
  font-weight: 980;
  letter-spacing: -0.055em;
  line-height: 1;
  overflow-wrap: anywhere;
}

.asset-image-manifest-title-stack p {
  max-width: 92ch;
  margin: 0;
  color: var(--cl-muted, #626262);
  font-size: 0.98rem;
  line-height: 1.55;
}

.asset-image-manifest-callout-grid {
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 0.65rem;
}

.asset-image-manifest-callout {
  display: grid;
  gap: 0.3rem;
  min-width: 0;
  padding: 0.82rem;
  border: 1px solid var(--asset-border-soft);
  border-radius: 18px;
  background: var(--asset-soft-bg);
}

.asset-image-manifest-callout strong {
  color: var(--cl-text, #111111);
  font-size: 1rem;
  font-weight: 930;
  overflow-wrap: anywhere;
}

.asset-image-manifest-document-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 0.65rem;
  min-width: 0;
}

.asset-image-manifest-document-field {
  display: grid;
  gap: 0.32rem;
  min-width: 0;
  padding: 0.78rem;
  border: 1px solid var(--asset-border-soft);
  border-radius: 18px;
  background: color-mix(in srgb, var(--asset-soft-bg) 82%, transparent);
}

.asset-image-manifest-document-field.is-wide {
  grid-column: 1 / -1;
}

.asset-image-manifest-document-field strong {
  color: var(--cl-text, #111111);
  font-size: 0.98rem;
  font-weight: 850;
  line-height: 1.48;
  overflow-wrap: anywhere;
  white-space: pre-wrap;
}

.asset-image-manifest-tag-row {
  display: flex;
  flex-wrap: wrap;
  gap: 0.45rem;
}

.asset-image-manifest-note {
  margin: 0;
  color: var(--cl-muted, #626262);
  font-size: 0.86rem;
  line-height: 1.5;
}

.asset-image-section-block {
  min-width: 0;
}

.asset-image-technical-stack {
  display: grid;
  gap: 0.85rem;
  min-width: 0;
}

.asset-image-technical-details {
  padding: 0.9rem;
  border: 1px solid var(--asset-border-soft);
  border-radius: 24px;
  background: color-mix(in srgb, var(--asset-panel-bg) 88%, transparent);
}

.asset-image-technical-details > summary {
  display: grid;
  gap: 0.2rem;
  cursor: pointer;
  list-style: none;
}

.asset-image-technical-details > summary::-webkit-details-marker {
  display: none;
}

.asset-image-technical-details > summary strong {
  color: var(--cl-text, #111111);
  font-size: 1rem;
  font-weight: 950;
}

.asset-image-technical-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 0.85rem;
  margin-top: 0.9rem;
}

.asset-image-technical-grid .cl-card {
  box-shadow: none;
}

.asset-image-technical-grid .asset-fact-grid {
  gap: 0.5rem;
}

.asset-image-technical-grid .asset-fact {
  padding: 0.62rem;
}

.asset-detail-grid-muted {
  opacity: 0.9;
}

@media (max-width: 1180px) {
  .asset-image-product-hero,
  .asset-image-manifest-document-header,
  .asset-image-technical-grid {
    grid-template-columns: 1fr;
  }

  .asset-image-manifest-badges {
