  .asset-image-status-actions,
  .asset-image-status-actions .cl-copy-button,
  .asset-image-product-preview .asset-copy-actions,
  .asset-image-product-preview .asset-copy-actions .cl-button {
    width: 100%;
  }
}

/* Final image manifest polish ------------------------------------------------
   Display-only refinements. Do not use these styles to imply local receipt,
   ownership, wallet, or paid-byte truth. */

.asset-image-manifest-certificate {
  border-radius: 24px;
  background:
    linear-gradient(180deg, color-mix(in srgb, var(--asset-panel-bg) 96%, white), var(--asset-panel-bg)),
    var(--asset-panel-bg);
}

.asset-image-manifest-identity-strip {
  display: grid;
  grid-template-columns: repeat(4, minmax(0, 1fr));
  gap: 0;
  overflow: hidden;
  border: 1px solid var(--asset-border-soft);
  border-radius: 18px;
  background: color-mix(in srgb, var(--asset-soft-bg) 74%, transparent);
}

.asset-image-manifest-identity-item {
  display: grid;
  gap: 0.24rem;
  min-width: 0;
  padding: 0.72rem 0.85rem;
  border-right: 1px solid var(--asset-border-soft);
}

.asset-image-manifest-identity-item:last-child {
  border-right: 0;
}

.asset-image-manifest-identity-item span {
  color: var(--cl-muted, #626262);
  font-size: 0.68rem;
  font-weight: 950;
  letter-spacing: 0.07em;
  text-transform: uppercase;
}

.asset-image-manifest-identity-item strong {
  color: var(--cl-text, #111111);
  font-size: 0.92rem;
  font-weight: 900;
  overflow-wrap: anywhere;
}

.asset-image-manifest-readable-grid {
  gap: 0.35rem 1rem;
  padding-top: 0.2rem;
}

.asset-image-manifest-readable-grid .asset-image-manifest-document-field {
  padding: 0.58rem 0;
  border: 0;
  border-top: 1px solid var(--asset-border-soft);
  border-radius: 0;
  background: transparent;
}

.asset-image-manifest-readable-grid .asset-image-manifest-document-field span {
  font-size: 0.68rem;
  letter-spacing: 0.08em;
}

.asset-image-manifest-readable-grid .asset-image-manifest-document-field strong {
  font-size: 0.96rem;
  line-height: 1.5;
}

.asset-content-view-card .asset-content-view-facts.is-compact {
  grid-template-columns: repeat(3, minmax(0, 1fr));
}

.asset-content-view-proof-details {
  margin-top: 0.75rem;
  padding: 0.72rem;
  border: 1px solid var(--asset-border-soft);
  border-radius: 18px;
  background: color-mix(in srgb, var(--asset-soft-bg) 78%, transparent);
}

.asset-content-view-proof-details > summary {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 0.75rem;
  cursor: pointer;
  list-style: none;
  color: var(--cl-text, #111111);
  font-weight: 950;
}

.asset-content-view-proof-details > summary::-webkit-details-marker {
  display: none;
}

.asset-content-view-proof-details > summary::after {
  content: 'Details';
  color: var(--cl-muted, #626262);
  font-size: 0.72rem;
  font-weight: 900;
  letter-spacing: 0.06em;
  text-transform: uppercase;
}

.asset-content-view-proof-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 0.5rem;
  margin-top: 0.65rem;
}

.asset-content-view-proof-grid .asset-fact {
  padding: 0.56rem;
  background: var(--asset-panel-bg);
}

.asset-content-view-json {
  margin-top: 0.75rem;
}

.asset-content-view-json > summary {
  color: var(--cl-muted, #626262);
  font-size: 0.86rem;
}

.asset-image-rendition-actions .cl-button,
.asset-image-rendition-actions .cl-copy-button,
.asset-image-rendition-actions button {
  min-height: 34px;
  padding: 0.42rem 0.7rem;
  font-size: 0.84rem;
}

.asset-image-rendition-row {
  grid-template-columns: minmax(135px, 0.68fr) minmax(240px, 1.75fr) minmax(180px, 0.85fr) minmax(220px, 0.88fr);
}

.asset-image-rendition-actions {
  gap: 0.35rem;
}

@media (max-width: 1180px) {
  .asset-image-manifest-identity-strip,
  .asset-content-view-card .asset-content-view-facts.is-compact,
  .asset-content-view-proof-grid {
    grid-template-columns: repeat(2, minmax(0, 1fr));
  }

  .asset-image-manifest-identity-item:nth-child(2n) {
    border-right: 0;
  }

  .asset-image-manifest-identity-item:nth-child(n + 3) {
    border-top: 1px solid var(--asset-border-soft);
  }
}

@media (max-width: 760px) {
  .asset-image-manifest-identity-strip,
  .asset-content-view-card .asset-content-view-facts.is-compact,
  .asset-content-view-proof-grid {
    grid-template-columns: 1fr;
  }

  .asset-image-manifest-identity-item {
    border-right: 0;
    border-top: 1px solid var(--asset-border-soft);
  }

  .asset-image-manifest-identity-item:first-child {
    border-top: 0;
  }
}



