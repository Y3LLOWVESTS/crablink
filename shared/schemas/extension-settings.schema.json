{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "CrabLink Extension Settings",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "gatewayUrl",
    "passportSubject",
    "walletAccount",
    "requestedUsername",
    "requestedHandle",
    "username",
    "handle",
    "usernameStatus",
    "profileCrabUrl",
    "publicProfileCid",
    "usernameUpdatedAt",
    "authToken",
    "requireSpendConfirm",
    "devMode",
    "requestTimeoutMs",
    "lastCrabUrl",
    "recentReceipts",
    "lastIdentityCheckAt",
    "lastBootstrapReceiptId",
    "lastStarterGrantIssued",
    "lastStarterGrantAmountMinorUnits",
    "lastStarterGrantReason",
    "lastStarterGrantLedgerBacked",
    "rocBalanceMinorUnits",
    "rocBalanceDisplay",
    "rocBalanceUpdatedAt",
    "rocLedgerBacked",
    "rocBalanceSource",
    "rocBalanceReason",
    "lastProductActionAt",
    "lastProductSchema",
    "lastProductCrabUrl",
    "lastProductB3Cid",
    "lastProductSiteName",
    "lastProductSummary"
  ],
  "properties": {
    "schemaVersion": {
      "type": "integer",
      "const": 3
    },
    "gatewayUrl": {
      "type": "string",
      "minLength": 1,
      "pattern": "^https?://"
    },
    "passportSubject": {
      "type": "string"
    },
    "walletAccount": {
      "type": "string"
    },
    "authToken": {
      "type": "string"
    },
    "requireSpendConfirm": {
      "type": "boolean"
    },
    "devMode": {
      "type": "boolean"
    },
    "requestTimeoutMs": {
      "type": "integer",
      "minimum": 1000,
      "maximum": 30000
    },
    "lastCrabUrl": {
      "type": "string"
    },
    "recentReceipts": {
      "type": "array",
      "maxItems": 20,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "id",
          "route",
          "action",
          "amountMinorUnits",
          "ledgerBacked",
          "source",
          "createdAt"
        ],
        "properties": {
          "id": {
            "type": "string"
          },
          "route": {
            "type": "string"
          },
          "action": {
            "type": "string"
          },
          "amountMinorUnits": {
            "type": "string",
            "pattern": "^[0-9]*$"
          },
          "ledgerBacked": {
            "type": "boolean"
          },
          "source": {
            "type": "string"
          },
          "createdAt": {
            "type": "string"
          }
        }
      }
    },
    "lastIdentityCheckAt": {
      "type": "string"
    },
    "lastBootstrapReceiptId": {
      "type": "string"
    },
    "lastStarterGrantIssued": {
      "type": "boolean"
    },
    "lastStarterGrantAmountMinorUnits": {
      "type": "string",
      "pattern": "^[0-9]*$"
    },
    "lastStarterGrantReason": {
      "type": "string"
    },
    "lastStarterGrantLedgerBacked": {
      "type": "boolean"
    },
    "rocBalanceMinorUnits": {
      "type": "string",
      "pattern": "^[0-9]*$"
    },
    "rocBalanceDisplay": {
      "type": "string"
    },
    "rocBalanceUpdatedAt": {
      "type": "string"
    },
    "rocLedgerBacked": {
      "type": "boolean"
    },
    "rocBalanceSource": {
      "type": "string"
    },
    "rocBalanceReason": {
      "type": "string"
    },
    "lastProductActionAt": {
      "type": "string"
    },
    "lastProductSchema": {
      "type": "string"
    },
    "lastProductCrabUrl": {
      "type": "string"
    },
    "lastProductB3Cid": {
      "type": "string"
    },
    "lastProductSiteName": {
      "type": "string"
    },
    "lastProductSummary": {
      "type": "string"
    },
    "requestedUsername": {
      "type": "string",
      "pattern": "^$|^[a-z0-9][a-z0-9_.-]{2,31}$"
    },
    "requestedHandle": {
      "type": "string",
      "pattern": "^$|^@[a-z0-9][a-z0-9_.-]{2,31}$"
    },
    "username": {
      "type": "string",
      "pattern": "^$|^[a-z0-9][a-z0-9_.-]{2,31}$"
    },
    "handle": {
      "type": "string",
      "pattern": "^$|^@[a-z0-9][a-z0-9_.-]{2,31}$"
    },
    "usernameStatus": {
      "type": "string",
      "enum": [
        "",
        "local_draft",
        "requested",
        "confirmed",
        "rejected",
        "unavailable",
        "backend_unknown"
      ]
    },
    "profileCrabUrl": {
      "type": "string"
    },
    "publicProfileCid": {
      "type": "string",
      "pattern": "^$|^b3:[0-9a-f]{64}$"
    },
    "usernameUpdatedAt": {
      "type": "string"
    }
  }
}