{
  "name": "@crablink/crablink-tauri",
  "version": "0.1.0",
  "private": true,
  "description": "CrabLink Tauri native client scaffold.",
  "type": "module",
  "scripts": {
    "dev": "vite --host 127.0.0.1 --port 1420",
    "build": "vite build",
    "preview": "vite preview --host 127.0.0.1 --port 1420",
    "tauri": "tauri",
    "tauri:dev": "tauri dev",
    "tauri:dev:mac-media": "tauri dev --config src-tauri/tauri.macos.dev-media.conf.json",
    "tauri:build": "tauri build",
    "check": "npm run build && cargo check --manifest-path src-tauri/Cargo.toml",
    "check:quickchain-phase5-anchor-boundary": "npm --prefix apps/crablink-tauri run check:quickchain-phase5-anchor-boundary",
    "check:quickchain-phase5-external-posture-boundary": "npm --prefix apps/crablink-tauri run check:quickchain-phase5-external-posture-boundary",
    "tv:dev": "npm --prefix apps/crablink-tv run dev",
    "tv:build": "npm --prefix apps/crablink-tv run build",
    "tv:check": "npm --prefix apps/crablink-tv run check",
    "tv:android:check": "node scripts/check-crablink-tv-android-tv-boundary.mjs",
    "tv:android:build:debug": "npm --prefix apps/crablink-tv run tauri -- android build --debug --target aarch64 --apk --ci",
    "tv:android:apk:check": "bash scripts/check-crablink-tv-debug-apk.sh",
    "tv:theme:check": "node scripts/check-crablink-tv-theme-default.mjs",
    "tv:android:build-task:check": "node scripts/check-crablink-tv-android-build-task.mjs",
    "tv:brand:check": "node scripts/check-crablink-tv-brand-assets.mjs",
    "tv:android:build:debug:armv7": "npm --prefix apps/crablink-tv run tauri -- android build --debug --target armv7 --apk --ci",
    "tv:android:apk:check:armv7": "EXPECTED_ANDROID_ABI=armeabi-v7a bash scripts/check-crablink-tv-debug-apk.sh",
    "tv:codebundle:check": "node scripts/check-crablink-tv-codebundle-boundary.mjs",
    "tv:focus:test": "npm --prefix apps/crablink-tv run test:focus",
    "tv:focus:check": "node scripts/check-crablink-tv-focus-boundary.mjs",
    "tv:route:test": "npm --prefix apps/crablink-tv run test:route",
    "tv:route:check": "node scripts/check-crablink-tv-route-boundary.mjs",
    "tv:settings:test": "npm --prefix apps/crablink-tv run test:settings",
    "tv:settings:check": "node scripts/check-crablink-tv-settings-boundary.mjs",
    "tv:pairing:test": "npm --prefix apps/crablink-tv run test:pairing",
    "tv:pairing:check": "node scripts/check-crablink-tv-pairing-boundary.mjs"
  },
  "dependencies": {
    "@tauri-apps/api": "^2",
    "react": "^18.2.0",
    "react-dom": "^18.2.0"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2",
    "@vitejs/plugin-react": "^4.3.0",
    "vite": "^5.4.0"
  },
  "license": "MIT OR Apache-2.0",
  "author": "Stevan White"
}
